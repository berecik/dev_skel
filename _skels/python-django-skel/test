#!/usr/bin/env bash
set -euo pipefail

# Test script for running project tests
# Usage: ./test [options]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Activate virtual environment if exists
if [[ -d ".venv" ]]; then
    source .venv/bin/activate
elif [[ -n "${VIRTUAL_ENV:-}" ]]; then
    : # Already in a virtual environment
fi

# Parse arguments
PYTEST_ARGS=""
while [[ $# -gt 0 ]]; do
    case $1 in
        --cov|--coverage)
            PYTEST_ARGS="$PYTEST_ARGS --cov --cov-report=term-missing"
            shift
            ;;
        --check)
            python manage.py check
            exit 0
            ;;
        -h|--help)
            echo "Usage: ./test [options] [pytest-args]"
            echo "Options:"
            echo "  --cov     Run with coverage"
            echo "  --check   Run Django system checks only"
            exit 0
            ;;
        *)
            PYTEST_ARGS="$PYTEST_ARGS $1"
            shift
            ;;
    esac
done

pytest $PYTEST_ARGS
