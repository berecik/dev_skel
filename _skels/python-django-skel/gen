#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMON_DIR="$SKEL_DIR/../_common"
MAIN_DIR="${1:-}"
PROJECT_SUBDIR_OVERRIDE="${2:-}"

if [[ -z "$MAIN_DIR" ]]; then
  echo "Usage: $(basename "$0") <main-dir> [service_subdir]" >&2
  exit 1
fi

# MAIN_DIR is already expected to be an absolute wrapper directory; Django app lives in service_subdir inside it
PROJECT_SUBDIR="${PROJECT_SUBDIR_OVERRIDE:-backend}"
PROJECT_DIR="$MAIN_DIR/$PROJECT_SUBDIR"

echo "[django] Generating into: $MAIN_DIR (project dir: $PROJECT_SUBDIR)"
mkdir -p "$PROJECT_DIR"

(
  cd "$PROJECT_DIR"
  python3 -m venv .venv
  . .venv/bin/activate
  pip install -q django python-dotenv gunicorn
  django-admin startproject myproject .
)

# Merge overlays into inner project directory
bash "$SKEL_DIR/merge" "$SKEL_DIR" "$PROJECT_DIR"

# Create wrapper-level README, Makefile, and thin scripts
bash "$COMMON_DIR/common-wrapper.sh" "$MAIN_DIR" "$PROJECT_SUBDIR" "Django Backend"

echo "[django] Done."
