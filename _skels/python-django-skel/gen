#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
RAW_TARGET="${1:-}"

if [[ -z "$RAW_TARGET" ]]; then
  echo "Usage: $(basename "$0") <target-path>"
  exit 1
fi

if [[ "$RAW_TARGET" = /* ]]; then
  TARGET="$RAW_TARGET"
else
  TARGET="$(pwd)/$RAW_TARGET"
fi

echo "[django] Generating into: $TARGET"
mkdir -p "$TARGET"

(
  cd "$TARGET"
  python3 -m venv .venv
  . .venv/bin/activate
  pip install -q django python-dotenv gunicorn
  django-admin startproject myproject .
)

bash "$SKEL_DIR/merge" "$SKEL_DIR" "$TARGET"

echo "[django] Done."
