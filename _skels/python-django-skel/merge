#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="${1:?skel_dir missing}"
TARGET_DIR="${2:?target_dir missing}"

echo "Merging additional files from $SKEL_DIR to $TARGET_DIR (Django)..."

# Files we always overwrite when present in the skel — every file in
# `myproject/{settings,urls}.py`, every file under `app/`, every
# test, plus `pyproject.toml` and `conftest.py`. If we did not
# overwrite them, an out-of-date generated project would carry stale
# code that no longer matches the current skel (missing app, missing
# JWT wiring, missing migrations, etc.).
#
# The `manage.py` + `myproject/{__init__,asgi,wsgi}.py` files are
# created by `django-admin startproject` and intentionally left
# untouched — those names embed the artifact id so changing them
# would break runserver / wsgi.
OVERWRITE_REGEX='^/(pyproject\.toml|conftest\.py|tests/.*\.py|app/.*\.py|myproject/(settings|urls)\.py)$'
EXCLUDE_REGEX='^/(Makefile|merge|gen|test_skel|deps|install-deps|AGENTS\.md|CLAUDE\.md|JUNIE-RULES\.md|manage\.py|myproject/(__init__|asgi|wsgi)\.py)$'

while IFS= read -r -d '' src; do
  rel="${src#"$SKEL_DIR"}"
  if [[ "$rel" =~ $EXCLUDE_REGEX ]]; then
    continue
  fi
  dst="$TARGET_DIR/$rel"
  if [[ "$rel" =~ $OVERWRITE_REGEX ]] || [[ ! -f "$dst" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "  + $rel"
  fi
done < <(find "$SKEL_DIR" -type f -print0)

echo "Done."
