#!/usr/bin/env bash
set -euo pipefail

# Skeleton test script - tests skeleton generation and project functionality

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/django-skel-test-XXXXXX")"
TARGET="$WORK_DIR/proj"

cleanup() {
  ./stop 2>/dev/null || true
  rm -rf "$WORK_DIR" || true
}
trap cleanup EXIT

echo "[test_skel] Generating Django project in $TARGET..."
"$SKEL_DIR/gen" "$TARGET"

cd "$TARGET"

. .venv/bin/activate
pip install -q pytest pytest-django

echo ""
echo "[test_skel] Running Django system checks..."
python manage.py check --verbosity 0

echo ""
echo "[test_skel] Running project tests via ./test script..."
./test -q

echo ""
echo "[test_skel] Building Docker image via ./build script..."
./build --tag=django-test:latest

echo ""
echo "[test_skel] Cleaning up Docker image..."
docker rmi django-test:latest 2>/dev/null || true

echo ""
echo "[test_skel] Django skeleton tests passed!"
