#!/usr/bin/env bash
set -euo pipefail

# End-to-end skeleton test: generates the project into a temp directory and
# verifies that imports succeed and pytest passes.
#
# This is the script invoked by `make test-django-bolt` from the repo root
# (after wiring) and by the global `make test-generators` target.

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/django-bolt-skel-test-XXXXXX")"
TARGET="$WORK_DIR/proj"

cleanup() {
  if [[ -d "$TARGET" ]]; then
    (cd "$TARGET" && ./stop 2>/dev/null || true)
  fi
  rm -rf "$WORK_DIR" || true
}
trap cleanup EXIT

echo "[test_skel] Generating django-bolt project in $TARGET..."
"$SKEL_DIR/gen" "$TARGET"

MAIN_DIR="$TARGET"
PROJECT_DIR="$MAIN_DIR/backend"

cd "$PROJECT_DIR"
# shellcheck disable=SC1091
. .venv/bin/activate
pip install -q pytest pytest-django

echo ""
echo "[test_skel] Running Django system checks..."
python manage.py check --verbosity 0

echo ""
echo "[test_skel] Running project tests via wrapper ./test script..."
cd "$MAIN_DIR"
./test -q

echo ""
echo "[test_skel] django-bolt skeleton tests passed!"
