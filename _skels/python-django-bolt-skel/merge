#!/usr/bin/env bash
set -euo pipefail

# Merge skeleton files into the target project directory.
#
# Excludes the dev_skel-side generator scripts (Makefile, gen, merge,
# test_skel, deps) and the rule docs that only make sense in the skel
# tree. We **do** ship `install-deps` so the generated service has a
# re-runnable virtualenv installer (and the wrapper-level service
# discovery uses it as a marker).

SKEL_DIR="${1:?skel_dir missing}"
TARGET_DIR="${2:?target_dir missing}"

echo "Merging files from $SKEL_DIR to $TARGET_DIR (Django-Bolt)..."

EXCLUDE_FILES_REGEX='^/(Makefile|gen|merge|test_skel|deps|AGENTS\.md|CLAUDE\.md|JUNIE-RULES\.md)$'

EXCLUDE_DIRS=(
  ".git"
  ".pytest_cache"
  "__pycache__"
  ".venv"
  "_scripts"
)

while IFS= read -r -d '' src; do
  rel="${src#"$SKEL_DIR"}"

  if [[ "$rel" =~ $EXCLUDE_FILES_REGEX ]]; then
    continue
  fi

  for d in "${EXCLUDE_DIRS[@]}"; do
    case "$rel" in
      */$d/*|*/$d|/$d/*|/$d) continue 2 ;;
    esac
  done

  dst="$TARGET_DIR/$rel"
  if [[ ! -f "$dst" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "  + $rel"
  fi
done < <(find "$SKEL_DIR" -type f -print0)

# manage.py needs to be executable in the generated project
chmod +x "$TARGET_DIR/manage.py" 2>/dev/null || true
chmod +x "$TARGET_DIR"/run "$TARGET_DIR"/run-dev "$TARGET_DIR"/test "$TARGET_DIR"/build "$TARGET_DIR"/build-dev "$TARGET_DIR"/stop "$TARGET_DIR"/install-deps 2>/dev/null || true

echo "Done."
