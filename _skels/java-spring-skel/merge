#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="${1:?skel_dir missing}"
TARGET_DIR="${2:?target_dir missing}"

echo "Merging additional files from $SKEL_DIR to $TARGET_DIR (Java Spring)..."

# Files we always overwrite when present in the skel — every Java
# source file, the test sources, the application properties, and the
# pom.xml define the wrapper-shared backend contract. If we did not
# overwrite them, an out-of-date generated project (or one that was
# scaffolded by Spring Initializr in an earlier gen run) would carry
# stale code that no longer matches the current skel.
OVERWRITE_REGEX='^/(pom\.xml|src/main/java/com/example/skel/.*\.java|src/main/resources/.*\.properties|src/test/java/com/example/skel/.*\.java)$'
EXCLUDE_REGEX='^/(Makefile|merge|gen|test_skel|deps|install-deps|AGENTS\.md|CLAUDE\.md|JUNIE-RULES\.md)$'

while IFS= read -r -d '' src; do
  rel="${src#"$SKEL_DIR"}"
  if [[ "$rel" =~ $EXCLUDE_REGEX ]]; then
    continue
  fi
  dst="$TARGET_DIR/$rel"
  if [[ "$rel" =~ $OVERWRITE_REGEX ]] || [[ ! -f "$dst" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "  + $rel"
  fi
done < <(find "$SKEL_DIR" -type f -print0)

echo "Done."
