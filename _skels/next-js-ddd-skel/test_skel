#!/usr/bin/env bash
set -euo pipefail

# Skeleton test script - tests skeleton generation and project functionality

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/next-js-skel-test-XXXXXX")"
TARGET="$WORK_DIR/proj"

cleanup() {
  ./stop 2>/dev/null || true
  rm -rf "$WORK_DIR" || true
}
trap cleanup EXIT

echo "[test_skel] Generating Next.js project in $TARGET..."
"$SKEL_DIR/gen" "$TARGET"

cd "$TARGET"

echo ""
echo "[test_skel] Running project tests via ./test script..."
./test

echo ""
echo "[test_skel] Building Docker image via ./build script..."
./build --tag=nextjs-test:latest

echo ""
echo "[test_skel] Cleaning up Docker image..."
docker rmi nextjs-test:latest 2>/dev/null || true

echo ""
echo "[test_skel] Next.js skeleton tests passed!"
