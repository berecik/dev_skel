#!/usr/bin/env bash
set -euo pipefail

# Run script for Next.js API backend
# Usage: ./run [mode]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

MODE="${1:-dev}"
PORT="3000"

case $MODE in
    dev)
        echo "Starting Next.js development server..."
        echo "  URL: http://localhost:$PORT"
        echo ""

        npm run dev
        ;;

    prod)
        echo "Starting Next.js production server..."
        npm run build && npm run start
        ;;

    docker)
        echo "Running in Docker..."

        if ! docker images js-app:latest --format "{{.Repository}}" | grep -q "js-app"; then
            echo "Image not found. Building..."
            ./build
        fi

        docker run --rm -p "${PORT}:3000" --name js-app js-app:latest
        ;;

    -h|--help)
        echo "Usage: ./run [mode]"
        echo ""
        echo "Modes:"
        echo "  dev     Development server with hot reload (default)"
        echo "  prod    Production server (builds first)"
        echo "  docker  Run in Docker container"
        exit 0
        ;;

    *)
        echo "Unknown mode: $MODE"
        exit 1
        ;;
esac
