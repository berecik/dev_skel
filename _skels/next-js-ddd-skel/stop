#!/usr/bin/env bash
set -euo pipefail

# Stop script for Next.js project
# Usage: ./stop

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

echo "Stopping services..."

# Stop Docker container if running
if docker ps -q -f name=js-app | grep -q .; then
    echo "Stopping Docker container..."
    docker stop js-app
fi

echo "Done"
