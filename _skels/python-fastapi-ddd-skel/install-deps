#!/usr/bin/env bash
# Dependency installer for Python FastAPI DDD skeleton
set -euo pipefail

# Colors
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

info() { echo -e "${GREEN}[INFO]${NC} $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }

detect_os() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    echo "macos"
  elif [[ -f /etc/os-release ]]; then
    . /etc/os-release
    case "$ID" in
      ubuntu|debian) echo "ubuntu" ;;
      arch|manjaro) echo "arch" ;;
      fedora|rhel|centos) echo "fedora" ;;
      *) echo "unknown" ;;
    esac
  else
    echo "unknown"
  fi
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

install_uv() {
  info "Installing uv (fast Python package manager)..."
  if command_exists curl; then
    curl -LsSf https://astral.sh/uv/install.sh | sh
  elif command_exists wget; then
    wget -qO- https://astral.sh/uv/install.sh | sh
  else
    warn "Neither curl nor wget found, installing uv via pip..."
    pip3 install uv
  fi
}

install_deps() {
  local os="$1"

  info "Installing Python dependencies for $os..."

  case "$os" in
    macos)
      if ! command_exists brew; then
        error "Homebrew is required but not installed. Visit https://brew.sh"
        exit 1
      fi
      info "Installing python3 and uv..."
      brew install python3 uv
      ;;

    ubuntu)
      info "Installing python3, python3-pip, and python3-venv..."
      sudo apt-get update
      sudo apt-get install -y python3 python3-pip python3-venv
      install_uv
      ;;

    arch)
      info "Installing python, python-pip, and uv..."
      sudo pacman -S --needed --noconfirm python python-pip uv
      ;;

    fedora)
      info "Installing python3 and python3-pip..."
      sudo dnf install -y python3 python3-pip
      install_uv
      ;;

    *)
      error "Unsupported OS: $os"
      exit 1
      ;;
  esac
}

verify_deps() {
  info "Verifying installations..."

  if command_exists python3; then
    info "Python: $(python3 --version)"
  else
    error "Python3 not found"
    return 1
  fi

  if command_exists uv; then
    info "uv: $(uv --version)"
  elif command_exists pip3; then
    warn "uv not found, but pip3 is available as fallback"
    info "pip: $(pip3 --version)"
  else
    error "Neither uv nor pip3 found"
    return 1
  fi

  if python3 -m venv --help >/dev/null 2>&1; then
    info "venv: available"
  else
    error "venv module not found"
    return 1
  fi

  info "All dependencies verified successfully!"
}

main() {
  local os
  os=$(detect_os)

  if [[ "$os" == "unknown" ]]; then
    error "Unable to detect OS"
    exit 1
  fi

  info "Detected OS: $os"

  # Check if dependencies are already installed
  if command_exists python3 && (command_exists uv || command_exists pip3) && python3 -m venv --help >/dev/null 2>&1; then
    info "Core dependencies already installed!"
    # Still try to install uv if missing
    if ! command_exists uv; then
      install_uv
    fi
    verify_deps
    return 0
  fi

  install_deps "$os"
  verify_deps
}

main "$@"
