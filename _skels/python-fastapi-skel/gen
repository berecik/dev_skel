#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMON_DIR="$SKEL_DIR/../_common"
RAW_TARGET="${1:-}"

if [[ -z "$RAW_TARGET" ]]; then
  echo "Usage: $(basename "$0") <target-path>"
  exit 1
fi

# Compute absolute main directory path (wrapper directory)
if [[ "$RAW_TARGET" = /* ]]; then
  MAIN_DIR="$RAW_TARGET"
else
  MAIN_DIR="$(pwd)/$RAW_TARGET"
fi

PROJECT_SUBDIR="backend"
PROJECT_DIR="$MAIN_DIR/$PROJECT_SUBDIR"

echo "[fastapi-ddd] Generating into: $MAIN_DIR (project dir: $PROJECT_SUBDIR)"
mkdir -p "$PROJECT_DIR"

# Merge skeleton files first into inner project directory
bash "$SKEL_DIR/merge" "$SKEL_DIR" "$PROJECT_DIR"

# Generate .env from example if not exists
if [[ ! -f "$PROJECT_DIR/.env" && -f "$PROJECT_DIR/.env.example" ]]; then
  cp "$PROJECT_DIR/.env.example" "$PROJECT_DIR/.env"
fi

# Create Python environment and install deps using uv
(
  cd "$PROJECT_DIR"

  # Check if uv is available
  if command -v uv >/dev/null 2>&1; then
    echo "[fastapi-ddd] Using uv for package management..."
    uv venv .venv
    uv pip install -q -r requirements.txt
  else
    echo "[fastapi-ddd] uv not found, falling back to pip..."
    python3 -m venv .venv
    . .venv/bin/activate
    pip install -q --upgrade pip
    pip install -q -r requirements.txt
  fi
)

# Create wrapper-level README, Makefile, and thin scripts
bash "$COMMON_DIR/common-wrapper.sh" "$MAIN_DIR" "$PROJECT_SUBDIR" "FastAPI DDD Backend"

echo "[fastapi-ddd] Done."
