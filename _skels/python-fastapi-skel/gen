#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
RAW_TARGET="${1:-}"

if [[ -z "$RAW_TARGET" ]]; then
  echo "Usage: $(basename "$0") <target-path>"
  exit 1
fi

# Compute absolute target path
if [[ "$RAW_TARGET" = /* ]]; then
  TARGET="$RAW_TARGET"
else
  TARGET="$(pwd)/$RAW_TARGET"
fi

echo "[fastapi] Generating into: $TARGET"
mkdir -p "$TARGET"

# Python environment and deps
(
  cd "$TARGET"
  python3 -m venv .venv
  . .venv/bin/activate
  pip install -q fastapi uvicorn sqlalchemy aiosqlite pydantic-settings alembic python-dotenv
)

# Merge skeleton files
bash "$SKEL_DIR/merge" "$SKEL_DIR" "$TARGET"

echo "[fastapi] Done."
