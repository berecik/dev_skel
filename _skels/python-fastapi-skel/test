#!/usr/bin/env bash
set -euo pipefail

# Test script for running project tests (supports venv and Poetry)
# Usage: ./test [options]
#   Options: --cov, --verbose, -v, -x, --quick

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Default values
COVERAGE=false
VERBOSE=""
QUICK=false
EXTRA_ARGS=()

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --cov|--coverage)
            COVERAGE=true
            shift
            ;;
        -v|--verbose)
            VERBOSE="-vv"
            shift
            ;;
        -x|--exitfirst)
            EXTRA_ARGS+=("-x")
            shift
            ;;
        --quick)
            QUICK=true
            shift
            ;;
        -h|--help)
            echo "Usage: ./test [options] [pytest-args]"
            echo ""
            echo "Options:"
            echo "  --cov, --coverage   Run with coverage report"
            echo "  -v, --verbose       Verbose output"
            echo "  -x, --exitfirst     Stop on first failure"
            echo "  --quick             Run only quick unit tests"
            echo ""
            echo "Examples:"
            echo "  ./test                    # Run all tests"
            echo "  ./test --cov              # Run with coverage"
            echo "  ./test --quick            # Run quick tests only"
            echo "  ./test app/users/tests/   # Run specific tests"
            exit 0
            ;;
        *)
            EXTRA_ARGS+=("$1")
            shift
            ;;
    esac
done

# Build pytest command - use venv if available, otherwise poetry
if [[ -f ".venv/bin/pytest" ]]; then
    PYTEST_CMD=".venv/bin/pytest"
elif command -v poetry &>/dev/null && poetry env info -p &>/dev/null 2>&1; then
    PYTEST_CMD="poetry run pytest"
else
    PYTEST_CMD="pytest"
fi

if [[ "$COVERAGE" == true ]]; then
    PYTEST_CMD="$PYTEST_CMD --cov=app --cov=core --cov-report=term-missing --cov-report=html"
fi

if [[ -n "$VERBOSE" ]]; then
    PYTEST_CMD="$PYTEST_CMD $VERBOSE"
fi

if [[ "$QUICK" == true ]]; then
    # Run only unit tests (fast)
    PYTEST_CMD="$PYTEST_CMD app/*/tests/unit/ core/tests/"
fi

# Add extra arguments
if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
    PYTEST_CMD="$PYTEST_CMD ${EXTRA_ARGS[*]}"
fi

echo "Running: $PYTEST_CMD"
echo ""

# Run tests
$PYTEST_CMD
