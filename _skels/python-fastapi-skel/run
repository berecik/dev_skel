#!/usr/bin/env bash
set -euo pipefail

# Run script for FastAPI project
# Usage: ./run [mode]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

MODE="${1:-dev}"
HOST="0.0.0.0"
PORT="8000"

case $MODE in
    dev)
        echo "Starting development server..."
        echo "  API docs: http://localhost:$PORT/docs"
        echo ""

        if [[ -d ".venv" ]]; then
            source .venv/bin/activate
        fi

        uvicorn app.main:app --reload --host "$HOST" --port "$PORT"
        ;;

    prod)
        echo "Starting production server..."

        if [[ -d ".venv" ]]; then
            source .venv/bin/activate
        fi

        uvicorn app.main:app --host "$HOST" --port "$PORT" --workers 4
        ;;

    docker)
        echo "Running in Docker..."

        if ! docker images fastapi-app:latest --format "{{.Repository}}" | grep -q "fastapi-app"; then
            echo "Image not found. Building..."
            ./build
        fi

        docker run --rm -p "${PORT}:8000" --name fastapi-app fastapi-app:latest
        ;;

    -h|--help)
        echo "Usage: ./run [mode]"
        echo ""
        echo "Modes:"
        echo "  dev     Development server with hot reload (default)"
        echo "  prod    Production server with multiple workers"
        echo "  docker  Run in Docker container"
        exit 0
        ;;

    *)
        echo "Unknown mode: $MODE"
        exit 1
        ;;
esac
