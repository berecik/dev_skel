#!/usr/bin/env bash
set -euo pipefail

# Build Docker image for FastAPI DDD project
# Uses uv for fast package installation with requirements from gen-requirements
# Usage: ./build [options]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Default values
TAG="fastapi-ddd:latest"
NO_CACHE=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --no-cache)
            NO_CACHE="--no-cache"
            shift
            ;;
        --tag=*)
            TAG="${1#*=}"
            shift
            ;;
        -h|--help)
            echo "Usage: ./build [options]"
            echo ""
            echo "Options:"
            echo "  --no-cache   Build without using cache"
            echo "  --tag=TAG    Tag for the image (default: fastapi-ddd:latest)"
            echo ""
            echo "Examples:"
            echo "  ./build                           # Build Docker image"
            echo "  ./build --tag=myapp:v1.0.0        # Build with custom tag"
            echo "  ./build --no-cache                # Rebuild without cache"
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
    esac
done

# Generate requirements.txt from pyproject.toml for Docker build
echo "Generating requirements from pyproject.toml..."
./gen-requirements -o requirements.txt

echo ""
echo "Building Docker image..."
echo "  Tag: $TAG"
echo ""

# Build the image
docker build \
    --tag "$TAG" \
    $NO_CACHE \
    .

echo ""
echo "Build complete: $TAG"

# Show image size
docker images "$TAG" --format "Size: {{.Size}}"
