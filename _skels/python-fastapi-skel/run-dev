#!/usr/bin/env bash
set -euo pipefail

# Run script for local development using Poetry
# Poetry virtual environment is in .venv directory
# Usage: ./run-dev [--host HOST] [--port PORT]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

HOST="0.0.0.0"
PORT="8000"

while [[ $# -gt 0 ]]; do
    case $1 in
        --host=*)
            HOST="${1#*=}"
            shift
            ;;
        --port=*)
            PORT="${1#*=}"
            shift
            ;;
        -h|--help)
            echo "Usage: ./run-dev [--host=HOST] [--port=PORT]"
            echo "  --host=HOST  Bind to host (default: 0.0.0.0)"
            echo "  --port=PORT  Bind to port (default: 8000)"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

# Generate .env if not exists
if [[ ! -f ".env" ]] && [[ -f ".env.example" ]]; then
    echo "Creating .env from .env.example..."
    cp .env.example .env
fi

# Build if .venv doesn't exist
if [[ ! -d ".venv" ]]; then
    ./build-dev
fi

echo "Starting development server..."
echo "  URL: http://${HOST}:${PORT}"
echo "  Docs: http://${HOST}:${PORT}/docs"
echo ""

poetry run uvicorn main:app --reload --host "$HOST" --port "$PORT"
