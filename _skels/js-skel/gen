#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMON_DIR="$SKEL_DIR/../_common"
MAIN_DIR="${1:-}"
PROJECT_SUBDIR_OVERRIDE="${2:-}"

if [[ -z "$MAIN_DIR" ]]; then
  echo "Usage: $(basename "$0") <main-dir> [service_subdir]" >&2
  exit 1
fi

# MAIN_DIR is already expected to be an absolute wrapper directory; Node app lives in service_subdir inside it
PROJECT_SUBDIR="${PROJECT_SUBDIR_OVERRIDE:-app}"
PROJECT_DIR="$MAIN_DIR/$PROJECT_SUBDIR"

echo "[js] Generating into: $MAIN_DIR (project dir: $PROJECT_SUBDIR)"
mkdir -p "$PROJECT_DIR"

(
  cd "$PROJECT_DIR"
  npm init -y >/dev/null 2>&1
)

# Merge overlays into inner project directory
bash "$SKEL_DIR/merge" "$SKEL_DIR" "$PROJECT_DIR"

(
  cd "$PROJECT_DIR"
  npm install >/dev/null 2>&1
)

# Create wrapper-level README, Makefile, and thin scripts
bash "$COMMON_DIR/common-wrapper.sh" "$MAIN_DIR" "$PROJECT_SUBDIR" "Node App"

echo "[js] Done."
