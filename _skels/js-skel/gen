#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
RAW_TARGET="${1:-}"

if [[ -z "$RAW_TARGET" ]]; then
  echo "Usage: $(basename "$0") <target-path>"
  exit 1
fi

if [[ "$RAW_TARGET" = /* ]]; then
  TARGET="$RAW_TARGET"
else
  TARGET="$(pwd)/$RAW_TARGET"
fi

echo "[js] Generating into: $TARGET"
mkdir -p "$TARGET"

(
  cd "$TARGET"
  npm init -y >/dev/null 2>&1
)

bash "$SKEL_DIR/merge" "$SKEL_DIR" "$TARGET"

(
  cd "$TARGET"
  npm install >/dev/null 2>&1
)

echo "[js] Done."
