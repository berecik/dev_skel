#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="${1:?skel_dir missing}"
TARGET_DIR="${2:?target_dir missing}"

echo "Merging overlays from $SKEL_DIR into $TARGET_DIR (ts-react-skel)..."

# Files to exclude from merge (generator-specific, not part of generated project)
EXCLUDE_FILES="Makefile merge gen test_skel deps install-deps"

EXCLUDE_DIRS=(
  ".git"
  "node_modules"
  ".pnpm-store"
  ".yarn"
)

# Files that should always overwrite (skeleton customizations).
#
# - `tsconfig.json`, `index.html` and `src/main.tsx` are included
#   because the upstream vite template (`react-swc-ts` in vite >= 8)
#   regressed to a vanilla-TS scaffold that omits JSX support and the
#   React entry point — we replace those bits with the
#   correctly-configured files shipped with the skeleton.
# - `src/App.tsx` / `src/App.test.tsx` / `src/App.css` / `src/config.ts`
#   ship as the canonical example (typed item repository + JWT auth
#   layer + react-hooks demo) so they always replace the vite scaffold's
#   demo content.
# - The `src/api/`, `src/auth/`, `src/hooks/` and `src/components/`
#   directories ship the supporting modules. The merge script copies
#   anything not already present, so we only need explicit overwrite
#   entries for files vite already wrote at the same path.
OVERWRITE_PATTERN="^/(vite\.config\.ts|tsconfig\.json|index\.html|src/App\.tsx|src/App\.css|src/App\.test\.tsx|src/setupTests\.ts|src/main\.tsx|src/config\.ts|src/api/items\.ts|src/auth/token-store\.ts|src/auth/use-auth-token\.ts|src/hooks/use-items\.ts|src/state/app-state-store\.ts|src/state/state-api\.ts|src/state/use-app-state\.ts|src/state/AppStateProvider\.tsx|src/components/LoginForm\.tsx|src/components/ItemForm\.tsx|src/components/ItemList\.tsx)$"

while IFS= read -r -d '' src; do
  rel="${src#"$SKEL_DIR"}"
  filename="$(basename "$rel")"

  # Skip excluded files (exact match on filename)
  skip=false
  for f in $EXCLUDE_FILES; do
    if [[ "$filename" == "$f" ]]; then
      skip=true
      break
    fi
  done
  if [[ "$skip" == true ]]; then
    continue
  fi

  # Skip excluded directories
  for d in "${EXCLUDE_DIRS[@]}"; do
    if [[ "$rel" == *"/$d/"* || "$rel" == *"/$d" || "$rel" == "/$d/"* || "$rel" == "/$d" ]]; then
      skip=true
      break
    fi
  done
  if [[ "$skip" == true ]]; then
    continue
  fi

  dst="$TARGET_DIR/$rel"
  should_copy=false

  # Check if file should always overwrite
  if [[ "$rel" =~ $OVERWRITE_PATTERN ]]; then
    should_copy=true
  elif [[ ! -f "$dst" ]]; then
    # Only copy if destination doesn't exist
    should_copy=true
  fi

  if [[ "$should_copy" == true ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "  + $rel"
  fi
done < <(find "$SKEL_DIR" -type f -print0)

echo "Done."
