#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="${1:?skel_dir missing}"
TARGET_DIR="${2:?target_dir missing}"

echo "Merging additional files from $SKEL_DIR to $TARGET_DIR (Go)..."

# Files we always overwrite when present in the skel — every Go
# source file, go.mod, and the test sources define the wrapper-shared
# backend contract. If we did not overwrite them, an out-of-date
# generated project would carry stale code that no longer matches the
# current skel. The dev_skel-side helper scripts are excluded so they
# do not leak into the generated project.
OVERWRITE_REGEX='^/(go\.mod|go\.sum|main\.go|internal/.*\.go|.*_test\.go)$'
EXCLUDE_REGEX='^/(Makefile|merge|gen|test_skel|deps|install-deps|AGENTS\.md|CLAUDE\.md|JUNIE-RULES\.md)$'

while IFS= read -r -d '' src; do
  rel="${src#"$SKEL_DIR"}"
  if [[ "$rel" =~ $EXCLUDE_REGEX ]]; then
    continue
  fi
  dst="$TARGET_DIR/$rel"
  if [[ "$rel" =~ $OVERWRITE_REGEX ]] || [[ ! -f "$dst" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "  + $rel"
  fi
done < <(find "$SKEL_DIR" -type f -print0)

echo "Done."
