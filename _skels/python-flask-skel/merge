#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="${1:?skel_dir missing}"
TARGET_DIR="${2:?target_dir missing}"

echo "Merging additional files from $SKEL_DIR to $TARGET_DIR (Flask)..."

# Files we always overwrite. The wrapper-shared backend stack lives in
# `app/` + `tests/` + `pyproject.toml`; if we did not overwrite those,
# an older generated project would carry stale code that no longer
# matches the current skel (missing User model, missing JWT
# decorator, missing /api/state routes, etc.).
OVERWRITE_REGEX='^/(app/.*\.py|tests/.*\.py|pyproject\.toml|run\.py)$'
EXCLUDE_REGEX='^/(Makefile|merge|gen|test_skel|deps|install-deps|AGENTS\.md|CLAUDE\.md|JUNIE-RULES\.md)$'

while IFS= read -r -d '' src; do
  rel="${src#"$SKEL_DIR"}"
  if [[ "$rel" =~ $EXCLUDE_REGEX ]]; then
    continue
  fi
  dst="$TARGET_DIR/$rel"
  if [[ "$rel" =~ $OVERWRITE_REGEX ]] || [[ ! -f "$dst" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "  + $rel"
  fi
done < <(find "$SKEL_DIR" -type f -print0)

echo "Done."
