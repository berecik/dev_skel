#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMON_DIR="$SKEL_DIR/../_common"
# shellcheck disable=SC1091
. "$COMMON_DIR/slug.sh"

MAIN_DIR="${1:-}"
SERVICE_NAME_RAW="${2:-}"

if [[ -z "$MAIN_DIR" ]]; then
  echo "Usage: $(basename "$0") <main-dir> [service-name]" >&2
  exit 1
fi

PROJECT_SUBDIR_OVERRIDE=""
if [[ -n "$SERVICE_NAME_RAW" ]]; then
  PROJECT_SUBDIR_OVERRIDE="$(slugify_service_name "$SERVICE_NAME_RAW")"
fi

# MAIN_DIR is already expected to be an absolute wrapper directory; Flask app lives in service_subdir inside it
PROJECT_SUBDIR="${PROJECT_SUBDIR_OVERRIDE:-backend}"
PROJECT_DIR="$MAIN_DIR/$PROJECT_SUBDIR"

echo "[flask] Generating into: $MAIN_DIR (project dir: $PROJECT_SUBDIR)"
mkdir -p "$PROJECT_DIR"

# Merge overlays into inner project directory FIRST so pyproject.toml
# (which lists every runtime + dev dep including PyJWT, bcrypt, and
# pytest) lands on disk before we install. Otherwise the venv would
# only get the inline runtime deps and the generated `./test` would
# fail with "pytest: command not found".
bash "$SKEL_DIR/merge" "$SKEL_DIR" "$PROJECT_DIR"

(
  cd "$PROJECT_DIR"
  python3 -m venv .venv
  # shellcheck disable=SC1091
  . .venv/bin/activate
  pip install -q --upgrade pip
  # `pip install -e .[dev]` installs every runtime dep declared in
  # pyproject.toml AND the [project.optional-dependencies] dev extras
  # (pytest, ruff, mypy). The generated project is dev-ready out of
  # the box — `./test` and the JWT-protected `/api/items` endpoints
  # work without a follow-up `./install-deps`.
  pip install -q -e ".[dev]"
)

# Create wrapper-level README, Makefile, and thin scripts
export SKEL_NAME="$(basename "$SKEL_DIR")"
bash "$COMMON_DIR/common-wrapper.sh" "$MAIN_DIR" "$PROJECT_SUBDIR" "Flask Backend"

echo "[flask] Done."
