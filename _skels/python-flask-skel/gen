#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMON_DIR="$SKEL_DIR/../_common"
RAW_TARGET="${1:-}"

if [[ -z "$RAW_TARGET" ]]; then
  echo "Usage: $(basename "$0") <target-path>"
  exit 1
fi

# MAIN_DIR is the wrapper directory; actual Flask app lives in backend/ inside it
if [[ "$RAW_TARGET" = /* ]]; then
  MAIN_DIR="$RAW_TARGET"
else
  MAIN_DIR="$(pwd)/$RAW_TARGET"
fi

PROJECT_SUBDIR="backend"
PROJECT_DIR="$MAIN_DIR/$PROJECT_SUBDIR"

echo "[flask] Generating into: $MAIN_DIR (project dir: $PROJECT_SUBDIR)"
mkdir -p "$PROJECT_DIR"

(
  cd "$PROJECT_DIR"
  python3 -m venv .venv
  . .venv/bin/activate
  pip install -q flask flask-sqlalchemy flask-migrate python-dotenv gunicorn
)

# Merge overlays into inner project directory
bash "$SKEL_DIR/merge" "$SKEL_DIR" "$PROJECT_DIR"

# Create wrapper-level README, Makefile, and thin scripts
bash "$COMMON_DIR/common-wrapper.sh" "$MAIN_DIR" "$PROJECT_SUBDIR" "Flask Backend"

echo "[flask] Done."
