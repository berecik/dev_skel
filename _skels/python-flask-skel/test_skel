#!/usr/bin/env bash
set -euo pipefail

# Skeleton test script - tests skeleton generation and project functionality

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/flask-skel-test-XXXXXX")"
TARGET="$WORK_DIR/proj"

cleanup() {
  ./stop 2>/dev/null || true
  rm -rf "$WORK_DIR" || true
}
trap cleanup EXIT

echo "[test_skel] Generating Flask project in $TARGET..."
"$SKEL_DIR/gen" "$TARGET"

cd "$TARGET"

. .venv/bin/activate
pip install -q pytest

echo ""
echo "[test_skel] Verifying imports..."
python - <<'PY'
import importlib
import sys
try:
    importlib.import_module('app')
    print('  OK: Flask import succeeded')
except Exception as e:
    print('  ERROR: Flask import failed:', e)
    sys.exit(1)
PY

echo ""
echo "[test_skel] Running project tests via ./test script..."
./test -q

echo ""
echo "[test_skel] Building Docker image via ./build script..."
./build --tag=flask-test:latest

echo ""
echo "[test_skel] Cleaning up Docker image..."
docker rmi flask-test:latest 2>/dev/null || true

echo ""
echo "[test_skel] Flask skeleton tests passed!"
