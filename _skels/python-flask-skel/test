#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/flask-skel-test-XXXXXX")"
TARGET="$WORK_DIR/proj"

cleanup() {
  rm -rf "$WORK_DIR" || true
}
trap cleanup EXIT

"$SKEL_DIR/gen" "$TARGET"

cd "$TARGET"

. . .venv/bin/activate
pip install -q pytest
pytest -q
python - <<'PY'
from app import create_app
app = create_app()
print('OK: Flask app created:', bool(app))
PY
echo "OK: Flask skeleton generated and tests ran."
