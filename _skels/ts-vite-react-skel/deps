#!/usr/bin/env bash
# Dependency installer for TypeScript Vite React skeleton
set -euo pipefail

# Colors
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

info() { echo -e "${GREEN}[INFO]${NC} $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }

# Detect OS
detect_os() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    echo "macos"
  elif [[ -f /etc/os-release ]]; then
    . /etc/os-release
    case "$ID" in
      ubuntu|debian) echo "ubuntu" ;;
      arch|manjaro) echo "arch" ;;
      fedora|rhel|centos) echo "fedora" ;;
      *) echo "unknown" ;;
    esac
  else
    echo "unknown"
  fi
}

# Check if command exists
command_exists() {
  command -v "$1" >/dev/null 2>&1
}

# Install dependencies based on OS
install_deps() {
  local os="$1"

  info "Installing Node.js dependencies for $os..."

  case "$os" in
    macos)
      if ! command_exists brew; then
        error "Homebrew is required but not installed. Visit https://brew.sh"
        exit 1
      fi
      info "Installing node..."
      brew install node
      ;;

    ubuntu)
      info "Installing nodejs and npm..."
      sudo apt-get update
      sudo apt-get install -y nodejs npm
      # Optionally install a newer version via NodeSource
      if [[ ! -f /etc/apt/sources.list.d/nodesource.list ]]; then
        warn "To get Node.js 20+, consider using NodeSource: https://github.com/nodesource/distributions"
      fi
      ;;

    arch)
      info "Installing nodejs and npm..."
      sudo pacman -S --needed --noconfirm nodejs npm
      ;;

    fedora)
      info "Installing nodejs and npm..."
      sudo dnf install -y nodejs npm
      ;;

    *)
      error "Unsupported OS: $os"
      exit 1
      ;;
  esac
}

# Verify installation
verify_deps() {
  info "Verifying installations..."

  if command_exists node; then
    info "Node.js: $(node --version)"
  else
    error "Node.js not found"
    return 1
  fi

  if command_exists npm; then
    info "npm: $(npm --version)"
  else
    error "npm not found"
    return 1
  fi

  # Check version meets requirements
  local node_version
  node_version=$(node --version | sed 's/v//' | cut -d. -f1)
  if [[ "$node_version" -lt 20 ]]; then
    warn "Node.js version is $node_version, but >= 20 is recommended"
  fi

  info "All dependencies verified successfully!"
}

# Main
main() {
  local os
  os=$(detect_os)

  if [[ "$os" == "unknown" ]]; then
    error "Unable to detect OS"
    exit 1
  fi

  info "Detected OS: $os"

  # Check if dependencies are already installed
  if command_exists node && command_exists npm; then
    info "All dependencies already installed!"
    verify_deps
    return 0
  fi

  install_deps "$os"
  verify_deps
}

main "$@"
