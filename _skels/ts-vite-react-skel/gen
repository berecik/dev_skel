#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
RAW_TARGET="${1:-}"

if [[ -z "$RAW_TARGET" ]]; then
  echo "Usage: $(basename "$0") <target-path>"
  exit 1
fi

if [[ "$RAW_TARGET" = /* ]]; then
  TARGET="$RAW_TARGET"
else
  TARGET="$(pwd)/$RAW_TARGET"
fi

PARENT_DIR="$(dirname "$TARGET")"
BASENAME="$(basename "$TARGET")"

echo "[vite-react] Generating into: $TARGET"
mkdir -p "$PARENT_DIR"

(
  cd "$PARENT_DIR"
  # Non-interactive Vite scaffolding
  printf 'n\nn\n' | npm create vite@latest "$BASENAME" -- --template react-ts >/dev/null 2>&1
)

(
  cd "$TARGET"
  npm install >/dev/null 2>&1
)

# Merge skeleton overlays (config, tests, etc.)
bash "$SKEL_DIR/merge" "$SKEL_DIR" "$TARGET"

(
  cd "$TARGET"
  npm install -D vitest @testing-library/react @testing-library/jest-dom jsdom >/dev/null 2>&1 || true
  npm pkg set scripts.test="vitest run" scripts.test:watch="vitest" >/dev/null 2>&1 || true
)

echo "[vite-react] Done."
