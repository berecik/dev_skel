#!/usr/bin/env bash
set -euo pipefail

# Build script for the Go service.
# Usage: ./build [options]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

TAG="go-app:latest"
NO_CACHE=""
PUSH=false
RELEASE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --no-cache)
            NO_CACHE="--no-cache"; shift ;;
        --push)
            PUSH=true; shift ;;
        --tag=*)
            TAG="${1#*=}"; shift ;;
        --release)
            RELEASE=true; shift ;;
        -h|--help)
            cat <<'EOF'
Usage: ./build [options]

Options:
  --release    Build the release binary into ./bin/app
  --no-cache   Build Docker without using cache
  --push       Push image to registry after build
  --tag=TAG    Tag for the image (default: go-app:latest)
EOF
            exit 0 ;;
        *) shift ;;
    esac
done

if [[ "$RELEASE" == true ]]; then
    echo "Building release binary..."
    mkdir -p bin
    # CGO_ENABLED=0 keeps the binary fully static so it can be
    # dropped into a `scratch` or `distroless:static` image.
    CGO_ENABLED=0 go build -ldflags="-s -w" -o bin/app .
    echo "Build complete. Binary at bin/app"
    exit 0
fi

if [[ ! -f "Dockerfile" ]]; then
    cat > Dockerfile <<'EOF'
# Multi-stage Docker build for the Go service.
FROM golang:1.22-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/app .

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app
COPY --from=builder /out/app /app/app
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["/app/app"]
EOF
    echo "Created Dockerfile"
fi

echo "Building Docker image: $TAG"
docker build --tag "$TAG" $NO_CACHE .

echo ""
echo "Build complete: $TAG"
docker images "$TAG" --format "Size: {{.Size}}"

if [[ "$PUSH" == true ]]; then
    echo "Pushing image..."
    docker push "$TAG"
fi
