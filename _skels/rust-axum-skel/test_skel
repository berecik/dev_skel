#!/usr/bin/env bash
set -euo pipefail

# Skeleton test script - tests skeleton generation and project functionality

SKEL_DIR="$(cd "$(dirname "$0")" && pwd)"
TMP_ROOT="${TMPDIR:-/tmp}"
WORK_DIR="$(mktemp -d "$TMP_ROOT/rust-axum-skel-test-XXXXXX")"
TARGET="$WORK_DIR/proj"

cleanup() {
  if [[ -d "$TARGET" ]]; then
    (
      cd "$TARGET" && ./stop 2>/dev/null || true
    )
  fi
  rm -rf "$WORK_DIR" || true
}
trap cleanup EXIT

echo "[test_skel] Generating Rust Axum project in $TARGET..."
"$SKEL_DIR/gen" "$TARGET"

MAIN_DIR="$TARGET"
PROJECT_DIR="$MAIN_DIR/service"

cd "$MAIN_DIR"

echo ""
echo "[test_skel] Running project tests via ./test script..."
./test

echo ""
echo "[test_skel] Building release binary via ./build --release..."
./build --release

echo ""
echo "[test_skel] Building Docker image via ./build script..."
./build --tag=axum-test:latest

echo ""
echo "[test_skel] Cleaning up Docker image..."
docker rmi axum-test:latest 2>/dev/null || true

echo ""
echo "[test_skel] Rust Axum skeleton tests passed!"
