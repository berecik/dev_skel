#!/usr/bin/env bash
set -euo pipefail

# Run script for local development
# Usage: ./run-dev [--host HOST] [--port PORT]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

export HOST="${HOST:-127.0.0.1}"
export PORT="${PORT:-8080}"

while [[ $# -gt 0 ]]; do
    case $1 in
        --host=*)
            export HOST="${1#*=}"
            shift
            ;;
        --port=*)
            export PORT="${1#*=}"
            shift
            ;;
        -h|--help)
            echo "Usage: ./run-dev [--host=HOST] [--port=PORT]"
            echo "  --host=HOST  Bind to host (default: 127.0.0.1)"
            echo "  --port=PORT  Bind to port (default: 8080)"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

echo "Starting Axum development server..."
echo "  URL: http://${HOST}:${PORT}"
echo ""

cargo run
