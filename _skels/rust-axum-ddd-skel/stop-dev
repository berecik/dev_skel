#!/usr/bin/env bash
set -euo pipefail

# Stop script for local development
# Usage: ./stop-dev

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

echo "Stopping local development server..."

# Find and kill rust-axum-skel processes
pkill -f "target/debug/rust-axum-skel" 2>/dev/null || true

echo "Done"
