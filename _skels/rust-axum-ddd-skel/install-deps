#!/usr/bin/env bash
# Install project dependencies for Rust Axum project
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${GREEN}[INFO]${NC} $*"; }
header() { echo -e "${BLUE}=== $* ===${NC}"; }

cd "$SCRIPT_DIR"

header "Installing Rust Axum Project Dependencies"

# Check if Cargo is available
if ! command -v cargo >/dev/null 2>&1; then
  echo "ERROR: cargo not found. Please install Rust first."
  echo "Run: ../skel-deps rust-axum-skel  (if using dev_skel structure)"
  exit 1
fi

info "Rust version: $(rustc --version)"
info "Cargo version: $(cargo --version)"

info "Fetching dependencies..."
cargo fetch

info "Building project (this will compile dependencies)..."
cargo build

header "Dependencies Installed Successfully"
info "Project is ready for development"
info "Run tests with: cargo test"
info "Run application with: cargo run"
info "Build for release with: cargo build --release"
