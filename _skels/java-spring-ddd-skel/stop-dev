#!/usr/bin/env bash
set -euo pipefail

# Stop script for local development
# Usage: ./stop-dev

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

echo "Stopping local development server..."

# Find and kill Spring Boot processes
pkill -f "spring-boot:run" 2>/dev/null || true
pkill -f "java.*java-spring-skel" 2>/dev/null || true

echo "Done"
