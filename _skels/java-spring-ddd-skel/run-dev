#!/usr/bin/env bash
set -euo pipefail

# Run script for local development
# Usage: ./run-dev [--port PORT]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

PORT="8080"

while [[ $# -gt 0 ]]; do
    case $1 in
        --port=*)
            PORT="${1#*=}"
            shift
            ;;
        -h|--help)
            echo "Usage: ./run-dev [--port=PORT]"
            echo "  --port=PORT  Server port (default: 8080)"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

echo "Starting Spring Boot development server..."
echo "  URL: http://localhost:${PORT}"
echo "  Health: http://localhost:${PORT}/actuator/health"
echo ""

./mvnw spring-boot:run -Dspring-boot.run.arguments="--server.port=$PORT"
