#!/usr/bin/env bash
set -euo pipefail

# Test script for running project tests
# Usage: ./test [options]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --package)
            mvn -q -DskipTests package
            exit 0
            ;;
        -h|--help)
            echo "Usage: ./test [options]"
            echo "Options:"
            echo "  --package   Build JAR without running tests"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

mvn test
