#!/usr/bin/env bash
# Check dependencies for Python FastAPI DDD skeleton
set -euo pipefail

# Colors
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

info() { echo -e "${GREEN}[INFO]${NC} $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

check_python() {
  if command_exists python3; then
    local version
    version=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
    local major minor
    major=$(echo "$version" | cut -d. -f1)
    minor=$(echo "$version" | cut -d. -f2)

    if [[ "$major" -ge 3 && "$minor" -ge 11 ]]; then
      info "Python: $(python3 --version)"
      return 0
    else
      warn "Python $version found, but 3.11+ recommended (3.14 preferred)"
      return 0
    fi
  else
    error "Python3 not found"
    return 1
  fi
}

check_uv() {
  if command_exists uv; then
    info "uv: $(uv --version)"
    return 0
  else
    warn "uv not found (will fall back to pip)"
    return 0
  fi
}

check_pip() {
  if command_exists pip3; then
    info "pip: $(pip3 --version 2>/dev/null | head -1)"
    return 0
  elif command_exists uv; then
    info "pip: not found (but uv is available)"
    return 0
  else
    error "Neither pip3 nor uv found"
    return 1
  fi
}

check_venv() {
  if python3 -m venv --help >/dev/null 2>&1; then
    info "venv: available"
    return 0
  else
    error "venv module not found"
    return 1
  fi
}

main() {
  local failed=0

  info "Checking dependencies for FastAPI DDD skeleton..."

  check_python || failed=1
  check_uv
  check_pip || failed=1
  check_venv || failed=1

  if [[ $failed -eq 0 ]]; then
    info "All dependencies satisfied!"
  else
    error "Some dependencies are missing"
    exit 1
  fi
}

main "$@"
