#!/usr/bin/env bash
set -euo pipefail

SKEL_DIR="${1:?skel_dir missing}"
TARGET_DIR="${2:?target_dir missing}"

echo "Merging files from $SKEL_DIR to $TARGET_DIR (FastAPI RAG)..."

# Files to exclude from merge (skeleton-specific files only). install-deps
# is intentionally NOT excluded so generated services keep a re-runnable
# virtualenv installer (and the wrapper-level discovery script uses it as
# a service marker).
EXCLUDE_FILES="Makefile|merge|gen|test_skel|deps"

# Directories to exclude entirely from merge
EXCLUDE_DIRS=(
  ".git"
  ".pytest_cache"
  "__pycache__"
  ".venv"
  "test-project"
)

while IFS= read -r -d '' src; do
  rel="${src#"$SKEL_DIR"}"

  # Skip excluded files
  case "$rel" in
    */$EXCLUDE_FILES|/$EXCLUDE_FILES) continue ;;
  esac

  # Skip excluded directories and their contents
  for d in "${EXCLUDE_DIRS[@]}"; do
    case "$rel" in
      */$d/*|*/$d|/$d/*|/$d) continue 2 ;;
    esac
  done

  dst="$TARGET_DIR/$rel"

  if [[ ! -f "$dst" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    echo "  + $rel"
  fi
done < <(find "$SKEL_DIR" -type f -print0)

echo "Done."
