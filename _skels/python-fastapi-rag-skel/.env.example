# Application
PROJECT_NAME=FastAPI RAG Project
PROJECT_ENV=development
DEBUG=True
SECRET_KEY=change-me-in-production

# Database (document metadata)
DATABASE_URL=sqlite:///./rag.db
DATABASE_TEST_URL=sqlite:///./test.db

# Server
SERVER_HOST=localhost
SERVER_PORT=8000

# Superuser
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=changeme
SUPERUSER_FULL_NAME=Admin User

# ----- RAG Configuration --------------------------------------------------- #

# Embedding provider: "huggingface" (default, local) or "openai"
RAG_EMBEDDING_PROVIDER=huggingface
# HuggingFace model (local, ~80MB download on first run)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# OpenAI embedding model (used when RAG_EMBEDDING_PROVIDER=openai)
RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM provider: "ollama" (default, local) or "openai"
RAG_LLM_PROVIDER=ollama
# Ollama settings
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_OLLAMA_MODEL=llama3.2
RAG_OLLAMA_TEMPERATURE=0.3
# OpenAI settings (used when RAG_LLM_PROVIDER=openai)
RAG_OPENAI_API_KEY=
RAG_OPENAI_MODEL=gpt-4o-mini

# Document chunking
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ChromaDB persistence directory
RAG_CHROMA_PERSIST_DIR=./chroma_data
RAG_CHROMA_COLLECTION=documents

# Upload directory
RAG_UPLOAD_DIR=./uploads

# Retrieval settings
RAG_TOP_K=5

# Conversation history: "memory" (in-process dict) or "sqlite"
RAG_HISTORY_BACKEND=memory
RAG_HISTORY_MAX_TURNS=10

# WebSocket auth: "required" or "optional"
RAG_WS_AUTH=optional
