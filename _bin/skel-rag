#!/usr/bin/env python3
"""skel-rag — local RAG helper CLI for dev_skel.

Thin entrypoint that adds ``_bin/`` to ``sys.path`` so the
``skel_rag`` package and its sibling modules (``skel_ai_lib``,
``dev_skel_lib``) all import cleanly, then dispatches to
:func:`skel_rag.cli.main`.

See ``skel-rag --help`` for the subcommand list.
"""

from __future__ import annotations

import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from skel_rag.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
