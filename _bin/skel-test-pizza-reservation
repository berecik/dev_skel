def _login(backend_url: str) -> Dict[str, str]:
    """Register (idempotent) + login, return the auth header dict.

    Mirrors steps 1-2 of the pizzeria HTTP exercise so V_reservation
    is self-contained. If the user already exists, register returns a
    409 / 400 which we ignore — the login is what matters.
    """
    http_request(
        "POST", f"{backend_url}/api/auth/register", body={
            "username": _pizzeria.TEST_USERNAME,
            "email": _pizzeria.TEST_EMAIL,
            "password": _pizzeria.TEST_PASSWORD,
            "password_confirm": _pizzeria.TEST_PASSWORD,
        },
    )
    status, body = http_request(
        "POST", f"{backend_url}/api/auth/login", body={
            "username": _pizzeria.TEST_USERNAME,
            "password": _pizzeria.TEST_PASSWORD,
        },
    )
    assert status == 200, f"V_reservation login failed: {status} {body}"
    token = (
        (body.get("access") or body.get("access_token") or body.get("token"))
        if isinstance(body, dict)
        else None
    )
    assert token, f"login response missing access token: {body}"
    return {"Authorization": f"Bearer {token}"}


def _probe_reservation_endpoint(
    backend_url: str, auth: Dict[str, str],
) -> Tuple[str, Dict[str, Any], Dict[str, Any], str]:
    """Find the endpoint + body shape ``./ai`` chose for reservations.

    Tries each ``(endpoint, body)`` combination in TWO transport
    modes:

    * ``json`` — body sent as JSON request body. The conventional
      FastAPI pattern for a Pydantic-typed POST endpoint.
    * ``query`` — body fields sent as URL query parameters. The
      common-but-buggy agent output where the route function declared
      ``param: type`` for each primitive instead of accepting a
      Pydantic model.

    Returns ``(endpoint, body, response_body, mode)``. The returned
    ``mode`` informs the persistence + negative-test phases so they
    use the same transport that worked here.

    Raises :class:`AssertionError` with a detailed log when nothing
    works.
    """
    from urllib.parse import urlencode
    tried: List[str] = []
    for endpoint in RESERVATION_ENDPOINT_CANDIDATES:
        for body in _candidate_bodies():
            # JSON body attempt
            status, resp = http_request(
                "POST", f"{backend_url}{endpoint}",
                body=body, headers=auth,
            )
            tried.append(
                f"  json   {endpoint} body={list(body.keys())} -> {status}"
            )
            if status in (200, 201):
                return (
                    endpoint, body,
                    resp if isinstance(resp, dict) else {},
                    "json",
                )
            # Query-string attempt (agent's primitive route-args pattern)
            qs = urlencode(
                {k: v for k, v in body.items() if isinstance(v, (str, int, float, bool))}
            )
            status, resp = http_request(
                "POST", f"{backend_url}{endpoint}?{qs}",
                headers=auth,
            )
            tried.append(
                f"  query  {endpoint}?{list(body.keys())} -> {status}"
            )
            if status in (200, 201):
                return (
                    endpoint, body,
                    resp if isinstance(resp, dict) else {},
                    "query",
                )
    raise AssertionError(
        "V_reservation: no candidate (endpoint, body, transport) accepted a "
        "valid reservation.\n" + "\n".join(tried)
    )


def verify_reservation_flow(backend_url: str) -> None:
    """Run V_reservation: book → persist → reject malformed.

    Three assertions:

    1. POST a valid reservation → 2xx, returns a body that includes
       the reservation's date/time fields (best-effort match — the
       server is allowed to normalise the field names as long as the
       round-tripped data is plausibly the same booking).
    2. POST with the date field missing → 4xx.
    3. POST with the date field set to garbage → 4xx.

    GET-based persistence verification is tried as a fourth step but
    treated as soft (warn-only) because not every reasonable
    implementation exposes a list endpoint.
    """
    print()
    print("V_reservation: book → persist → reject malformed...")

    from urllib.parse import urlencode

    auth = _login(backend_url)
    endpoint, accepted_body, response_body, mode = (
        _probe_reservation_endpoint(backend_url, auth)
    )
    print(
        f"  ✓ POST {endpoint} accepted "
        f"(transport={mode}, fields={list(accepted_body.keys())})"
    )

    # ---- 1. Persistence (soft) ----
    # If the response body included an id, try fetching it back.
    res_id = (
        response_body.get("id")
        or response_body.get("reservation_id")
        if isinstance(response_body, dict)
        else None
    )
    if res_id is not None:
        get_url = f"{backend_url}{endpoint.rstrip('/')}/{res_id}"
        status, detail = http_request("GET", get_url, headers=auth)
        if status == 200:
            print(f"  ✓ GET {endpoint}/{{id}} returns the booking")
        else:
            print(
                f"  · GET {endpoint}/{{id}} returned {status} "
                "(soft — not every impl exposes detail)"
            )
    else:
        # Fall back to listing.
        status, listing = http_request(
            "GET", f"{backend_url}{endpoint}", headers=auth,
        )
        if status == 200 and listing:
            print(f"  ✓ GET {endpoint} listing is non-empty")
        else:
            print(
                f"  · GET {endpoint} returned {status} "
                "(soft — list endpoint not required)"
            )

    def _post(payload: Dict[str, Any]) -> Tuple[int, Any]:
        """Re-use the transport mode that accepted the happy-path call."""
        if mode == "query":
            qs = urlencode({
                k: v for k, v in payload.items()
                if isinstance(v, (str, int, float, bool))
            })
            return http_request(
                "POST", f"{backend_url}{endpoint}?{qs}", headers=auth,
            )
        return http_request(
            "POST", f"{backend_url}{endpoint}",
            body=payload, headers=auth,
        )

    # ---- 2. Reject missing date ----
    missing = _invalidate_date(accepted_body, mode="missing")
    status, body = _post(missing)
    assert 400 <= status < 500, (
        f"V_reservation: expected 4xx on missing date, got {status}: "
        f"{body}"
    )
    print(f"  ✓ POST without date rejected ({status})")

    # ---- 3. Reject malformed date / time ----
    malformed = _invalidate_date(accepted_body, mode="malformed")
    status, body = _post(malformed)
    assert 400 <= status < 500, (
        f"V_reservation: expected 4xx on malformed date/time, got "
        f"{status}: {body}"
    )
    print(f"  ✓ POST with malformed date/time rejected ({status})")

    print("  === V_reservation passed ===")


