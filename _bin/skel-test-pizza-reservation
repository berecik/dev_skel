# Reservation HTTP probe candidates. ``./ai`` may legitimately choose
# any of these endpoint shapes; the verifier tries each in order until
# one accepts the canonical happy-path payload, then re-uses that shape
# for the negative tests so the "missing date" + "invalid format"
# rejections target the SAME endpoint as the success case.
RESERVATION_ENDPOINT_CANDIDATES: Tuple[str, ...] = (
    # Direct top-level routes (when the agent's router is mounted at
    # the app root via app/__init__.py).
    "/api/reservations",
    "/api/reservations/",
    "/api/bookings",
    "/api/bookings/",
    "/api/table-reservations",
    "/api/tables/reservations",
    # When the agent's router is mounted through ``app/routes.py``
    # (which is itself mounted at ``/api/v1``) and the router has
    # its own ``prefix="/api/reservations"``, the effective path
    # becomes ``/api/v1/api/reservations``. Also probe the variant
    # where the agent's router used ``prefix="/reservations"``.
    "/api/v1/api/reservations",
    "/api/v1/api/reservations/",
    "/api/v1/reservations",
    "/api/v1/reservations/",
    "/api/v1/bookings",
    "/api/v1/bookings/",
    "/api/v1/api/bookings",
    "/api/v1/api/bookings/",
)

# Body-shape candidates: ``./ai`` may pick any of these. The "valid"
# payload is built from one shape at a time until one is accepted.
def _candidate_bodies() -> List[Dict[str, Any]]:
    """Plausible POST bodies for a reservation endpoint.

    Ordered most-likely-first so the average case lands on the first
    attempt. Each body carries a future date + plausible time so the
    server should not reject on business-rule grounds (past date,
    closed hours).
    """
    return [
        # Most common: ISO date + HH:MM time string
        {"date": "2026-12-15", "time": "19:30", "party_size": 4,
         "name": "pizzeria-test-user"},
        # date + integer hour (the prompt says "time (hour)" which
        # some LMs read literally as just an hour-of-day)
        {"date": "2026-12-15", "hour": 19, "party_size": 4,
         "name": "pizzeria-test-user"},
        # Combined ISO 8601 datetime
        {"datetime": "2026-12-15T19:30:00", "party_size": 4,
         "name": "pizzeria-test-user"},
        # snake_case field names (Django-bolt-ish convention)
        {"reservation_date": "2026-12-15", "reservation_time": "19:30",
         "party_size": 4, "name": "pizzeria-test-user"},
        # FastAPI embedded-body convention where the agent declares
        # `reservation_datetime: datetime` as a route argument.
        {"reservation_datetime": "2026-12-15T19:30:00", "party_size": 4},
        # Single ``booking_datetime`` field (variation)
        {"booking_datetime": "2026-12-15T19:30:00", "party_size": 4},
        # When only the datetime field is present (no party_size /
        # name): some agents collapse the contract to a single field.
        {"reservation_datetime": "2026-12-15T19:30:00"},
    ]


# Same shape with the date field deliberately missing or malformed —
# we mutate the WORKING candidate at probe time rather than hand-coding
# a parallel list, so the negative case matches whichever shape ./ai
# generated.
def _invalidate_date(body: Dict[str, Any], *, mode: str) -> Dict[str, Any]:
    """Return a copy of *body* with the date corrupted in *mode*.

    Modes:
    * ``"missing"`` — drop every plausible date-bearing key.
    * ``"malformed"`` — replace each date-bearing key with garbage.
    """
    bad = dict(body)
    date_like_keys = (
        "date", "datetime", "reservation_date", "iso_date",
        "reservation_datetime", "booking_datetime",
    )
    for key in date_like_keys:
        if key in bad:
            if mode == "missing":
                del bad[key]
            else:
                bad[key] = "not-a-date"
    # When the body uses ``hour`` (integer) instead of a date string,
    # corrupt that too so the "malformed time" path is exercised.
    if mode == "malformed" and "hour" in bad:
        bad["hour"] = "noon"
    if mode == "malformed" and "time" in bad:
        bad["time"] = "ninety-nine o'clock"
    return bad


