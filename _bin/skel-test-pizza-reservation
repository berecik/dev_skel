def _restart_backend(
    backend_dir: Path, wrapper: Path, port: int, backend_url: str,
    startup_timeout: int,
):
    """(re)start the backend, wait for /docs, return (proc, log_fp, log_path)."""
    proc, log_fp, log_path = _start_backend(
        backend_dir, wrapper, port, backend_url,
    )
    if not wait_for_server(f"{backend_url}/docs", timeout_s=startup_timeout):
        tail = ""
        try:
            tail = log_path.read_text(encoding="utf-8")[-4000:]
        except OSError:
            pass
        proc.terminate()
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            proc.kill()
        if log_fp is not None:
            log_fp.close()
        raise RuntimeError(
            f"backend did not become ready in {startup_timeout}s.\n"
            f"---- log tail ----\n{tail}"
        )
    return proc, log_fp, log_path


def _stop_backend(proc, log_fp) -> None:
    """Gracefully stop a backend subprocess + close its log file."""
    if proc is not None and proc.poll() is None:
        proc.terminate()
        try:
            proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            proc.kill()
            try:
                proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                pass
    if log_fp is not None:
        try:
            log_fp.close()
        except OSError:
            pass


def _reset_shared_db(wrapper: Path, progress=print) -> None:
    """Delete the wrapper-shared SQLite database file.

    Necessary between the V_pizza baseline (Phase 2) and the V_pizza
    regression (Phase 5): the baseline registers the canonical test
    user, and the regression test's ``POST /api/auth/register`` would
    then fail with 400 "username already exists". Wiping the DB makes
    each phase's HTTP exercise self-contained.

    The default-account seeder runs at server startup, so admin/user
    fixtures are recreated automatically — there is no loss of
    fixture data.
    """
    db = wrapper / "_shared" / "db.sqlite3"
    if db.is_file():
        try:
            db.unlink()
            progress(f"  · wiped shared DB at {db.relative_to(wrapper.parent)}")
        except OSError as exc:
            progress(f"  · could not wipe shared DB: {exc!r}")


