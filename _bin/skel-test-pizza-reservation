def _open_table_creation(
    backend_dir: Path, progress=print,
) -> bool:
    """Make sure every SQLModel table — including agent-added ones — is created.

    Two patches:

    1. Rewrite ``SQLModel.metadata.create_all(_engine, tables=[...])`` in
       ``app/wrapper_api/db.py`` to drop the closed allowlist. This is
       necessary but NOT sufficient: ``create_all`` still runs at
       import time of ``db.py``, which is BEFORE the agent's
       ``app/<feature>/models.py`` is imported via the router chain.

    2. Inject a deferred ``SQLModel.metadata.create_all(_engine)`` call
       inside ``app/__init__.py:get_app()`` — AFTER every router is
       included. By then every ``table=True`` class declared anywhere
       in the application is registered on the global metadata, so
       ``create_all`` actually picks up the agent's new tables.

    Idempotent: re-running the function detects existing patches via
    sentinel comments and skips them. Returns ``True`` if any change
    was made.
    """
    import re as _re
    any_change = False

    # ---- Patch 1: open the table allowlist in wrapper_api/db.py ----
    db_target = backend_dir / "app" / "wrapper_api" / "db.py"
    if db_target.is_file():
        try:
            text = db_target.read_text(encoding="utf-8")
        except OSError:
            text = ""
        pattern = _re.compile(
            r"SQLModel\.metadata\.create_all\s*\(\s*_engine\s*,\s*tables\s*=\s*\[[^\]]*\]\s*\)",
            _re.DOTALL,
        )
        if pattern.search(text):
            new_text = pattern.sub(
                "SQLModel.metadata.create_all(_engine)  "
                "# patched: create EVERY registered SQLModel table",
                text,
            )
            try:
                db_target.write_text(new_text, encoding="utf-8")
                progress(
                    "  · opened table creation in app/wrapper_api/db.py "
                    "(allowlist removed)"
                )
                any_change = True
            except OSError:
                pass

    # ---- Patch 2: deferred create_all in app/__init__.py:get_app() ----
    init_target = backend_dir / "app" / "__init__.py"
    sentinel = "# [pizza-reservation] deferred create_all"
    if init_target.is_file():
        try:
            text = init_target.read_text(encoding="utf-8")
        except OSError:
            text = ""
        if sentinel not in text and "include_router" in text:
            # Find the LAST include_router(...) line and insert our
            # deferred create_all immediately after it.
            include_line_re = _re.compile(
                r"^([ \t]*).*include_router\([^)]*\)",
                _re.MULTILINE,
            )
            matches = list(include_line_re.finditer(text))
            if matches:
                last = matches[-1]
                indent = last.group(1)
                insertion = (
                    f"\n{indent}{sentinel}\n"
                    f"{indent}from sqlmodel import SQLModel as _SQLModel_late\n"
                    f"{indent}from app.wrapper_api.db import _engine as "
                    "_engine_late\n"
                    f"{indent}_SQLModel_late.metadata.create_all(_engine_late)"
                )
                new_text = text[:last.end()] + insertion + text[last.end():]
                try:
                    init_target.write_text(new_text, encoding="utf-8")
                    progress(
                        "  · injected deferred create_all in "
                        "app/__init__.py:get_app() so agent-added tables "
                        "are created after the router chain finishes "
                        "importing models"
                    )
                    any_change = True
                except OSError:
                    pass

    return any_change


def _sanitize_agent_outputs(
    backend_dir: Path, progress=print,
) -> List[str]:
    """Fix common agent mistakes in its newly-written Python files.

    The system prompt teaches the right patterns, but smaller models
    still slip. We post-process the agent's diff to repair the most
    impactful FastAPI/SQLModel anti-patterns that would otherwise
    block the server from starting OR force every reservation POST
    to return 422:

    * ``Depends(CurrentUser)`` → ``CurrentUser`` (the latter is an
      ``Annotated[WrapperUser, Depends(_get_current_user)]`` alias,
      wrapping it in another ``Depends()`` makes FastAPI try to
      execute the Annotated metadata as a callable signature,
      which it parses as ``(*args, **kwargs)`` — surfacing as
      "Field required: args / kwargs" 422 errors).
    * Primitive route params for POST (e.g. ``foo: int``) are not
      auto-promoted to body in newer FastAPI; we leave those alone
      because rewriting them requires synthesising a Pydantic
      model. The system prompt already warns against this pattern.

    Returns the list of files modified.
    """

    import re as _re

    if not (backend_dir / ".git").is_dir():
        return []

    diff = subprocess.run(
        ["git", "diff", "--name-only", "baseline"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    untracked = subprocess.run(
        ["git", "ls-files", "--others", "--exclude-standard"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    touched: List[str] = []
    for r in (diff, untracked):
        if r.returncode == 0:
            touched.extend(
                ln.strip() for ln in r.stdout.splitlines()
                if ln.strip().endswith(".py")
            )

    # Patterns we rewrite. Keyed for readability + future expansion.
    rewrites: List[Tuple["_re.Pattern[str]", str, str]] = [
        # ``user: WrapperUser = Depends(CurrentUser)`` → ``user: CurrentUser``
        # (drops the wrong type + Depends wrapper).
        (
            _re.compile(
                r"(\w+)\s*:\s*WrapperUser\s*=\s*Depends\s*\(\s*CurrentUser\s*\)"
            ),
            r"\1: CurrentUser",
            "Depends(CurrentUser) wrapper",
        ),
        # ``= Depends(CurrentUser)`` standalone (caller already typed
        # the variable as CurrentUser, just wants to drop the Depends).
        (
            _re.compile(r"=\s*Depends\s*\(\s*CurrentUser\s*\)"),
            "",
            "= Depends(CurrentUser) suffix",
        ),
    ]

    rewritten: List[str] = []
    for rel in touched:
        path = backend_dir / rel
        if not path.is_file():
            continue
        try:
            original = path.read_text(encoding="utf-8")
        except OSError:
            continue
        new_text = original
        applied: List[str] = []
        for pattern, replacement, label in rewrites:
            updated, count = pattern.subn(replacement, new_text)
            if count > 0:
                new_text = updated
                applied.append(f"{label}×{count}")
        if new_text != original:
            try:
                path.write_text(new_text, encoding="utf-8")
            except OSError:
                continue
            rewritten.append(rel)
            progress(
                f"  · sanitised {rel}: " + ", ".join(applied)
            )
    return rewritten


def _remount_new_routers(
    backend_dir: Path, progress=print,
) -> List[str]:
    """After rolling back ``app/routes.py``, re-include any new agent routers.

    The agent legitimately creates new ``app/<feature>/routes.py`` files
    and modifies ``app/routes.py`` to mount them. Our full-rollback
    restores ``app/routes.py`` to baseline (which doesn't know about the
    new packages), so we then add an ``include_router`` block for each
    surviving ``app/<feature>/routes.py`` that exposes a ``router``
    symbol.

    Returns the list of feature names that were re-mounted.
    """

    import re as _re

    routes_py = backend_dir / "app" / "routes.py"
    if not routes_py.is_file():
        return []
    text = routes_py.read_text(encoding="utf-8")
    # Discover sibling packages that look like NEW agent-created
    # feature modules: ``app/<name>/routes.py`` with at least one
    # ``router = APIRouter`` line. We exclude the wrapper-shared
    # ``wrapper_api``, the pre-existing AI-gen ``orders_api`` /
    # ``example_items`` modules (intentionally NOT mounted because
    # their generated code commonly references symbols the wrapper
    # doesn't expose), and the test scaffolding directories.
    app_dir = backend_dir / "app"
    new_features: List[str] = []
    # Walk the baseline tree to enumerate "things that existed before
    # the agent" — anything found there is NOT a new feature even
    # if the agent happened to leave it on disk.
    baseline_ls = subprocess.run(
        ["git", "ls-tree", "-r", "--name-only", "baseline", "app/"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    baseline_dirs: set = set()
    if baseline_ls.returncode == 0:
        for p in baseline_ls.stdout.splitlines():
            parts = p.split("/")
            if len(parts) >= 2 and parts[0] == "app":
                baseline_dirs.add(parts[1])
    for child in sorted(app_dir.iterdir()):
        if not child.is_dir() or child.name.startswith(("_", ".")):
            continue
        if child.name in ("wrapper_api", "example_items", "tests",
                          "integrations", "orders_api"):
            continue
        # If the package existed in baseline, it's NOT a new agent
        # feature — skip it so we don't accidentally mount something
        # the pizzeria layout intentionally leaves un-mounted.
        if child.name in baseline_dirs:
            continue
        feature_routes = child / "routes.py"
        if not feature_routes.is_file():
            continue
        try:
            content = feature_routes.read_text(encoding="utf-8")
        except OSError:
            continue
        if "APIRouter" not in content or "router" not in content:
            continue
        # Only mount once; if baseline routes.py already references it,
        # skip.
        if f"from .{child.name}" in text:
            continue
        new_features.append(child.name)

    if not new_features:
        return []

    # Insert imports + include_router lines BEFORE the final blank
    # line of the baseline routes.py. Detect whether the agent's
    # router already declared a ``prefix=`` (typical convention is
    # ``APIRouter(prefix="/api/<feature>")``); only add OUR prefix
    # when the router didn't supply one, to avoid double-prefix
    # bugs like ``/reservations/api/reservations``.
    import re as _re
    prefix_re = _re.compile(r"APIRouter\([^)]*prefix\s*=", _re.DOTALL)
    new_imports = "\n".join(
        f"from .{f} import routes as {f}_routes" for f in new_features
    )
    include_lines: List[str] = []
    for f in new_features:
        try:
            router_src = (app_dir / f / "routes.py").read_text(
                encoding="utf-8"
            )
        except OSError:
            router_src = ""
        if prefix_re.search(router_src):
            # Router defines its own prefix — mount it as-is.
            include_lines.append(
                f"router.include_router({f}_routes.router)"
            )
        else:
            # No router-level prefix — add the conventional one.
            include_lines.append(
                f"router.include_router({f}_routes.router, "
                f"tags=['{f}'], prefix='/api/{f}')"
            )
    new_includes = "\n".join(include_lines)
    augmented = (
        text.rstrip()
        + "\n\n# Auto-mounted post-rollback by the test runner.\n"
        + new_imports + "\n"
        + new_includes + "\n"
    )
    routes_py.write_text(augmented, encoding="utf-8")
    progress(
        f"  · re-mounted {len(new_features)} agent-created router(s) "
        f"in app/routes.py: {', '.join(new_features)}"
    )
    return new_features


def _synth_missing_module_shims(
    backend_dir: Path, progress=print,
) -> List[str]:
    """Create shim files for missing modules referenced by agent code.

    The most common ./ai failure mode is "added an import for a module
    I never created" — typically extracting an enum into its own file
    without writing the file. Rather than full-rollback (which loses
    every agent change in the guarded prefixes), we scan agent-modified
    files for ``from .<missing> import <SYMBOL>`` lines whose
    ``<missing>`` module file doesn't exist. When ``<SYMBOL>`` IS
    defined in the baseline copy of the importer file (or any baseline
    file under the same package), we synthesise a tiny shim:

        # auto-generated shim for the agent's missing-module hallucination
        from .<importer_module> import <SYMBOL>

    This lets the server start without rolling back the agent's new
    routes / models, so V_reservation has a chance to pass.

    Returns the list of created shim paths.
    """

    import re as _re

    if not (backend_dir / ".git").is_dir():
        return []

    # Find every agent-touched python file — both diffs AND untracked
    # new files. We don't restrict to guarded prefixes here because
    # the agent's NEW files outside those prefixes (e.g.
    # ``app/reservations/routes.py``) frequently import non-existent
    # modules from inside the guarded prefixes (e.g.
    # ``from app.wrapper_api.models import WrapperUser`` when the
    # symbol is actually in ``wrapper_api.db``).
    diff = subprocess.run(
        ["git", "diff", "--name-only", "baseline"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    untracked = subprocess.run(
        ["git", "ls-files", "--others", "--exclude-standard"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    touched_py: List[str] = []
    if diff.returncode == 0:
        touched_py.extend(
            ln.strip() for ln in diff.stdout.splitlines()
            if ln.strip().endswith(".py")
        )
    if untracked.returncode == 0:
        touched_py.extend(
            ln.strip() for ln in untracked.stdout.splitlines()
            if ln.strip().endswith(".py")
        )
    if not touched_py:
        return []

    # Match BOTH:
    #   - relative imports: ``from .module import Name1, Name2``
    #   - absolute imports under app/wrapper_api/, app/orders_api/,
    #     and similar pizza-contract roots that the agent commonly
    #     hallucinates names from.
    rel_import_re = _re.compile(
        r"^\s*from\s+\.([A-Za-z_][A-Za-z0-9_]*)\s+import\s+(.+)$",
        _re.MULTILINE,
    )
    abs_import_re = _re.compile(
        r"^\s*from\s+(app(?:\.[A-Za-z_][A-Za-z0-9_]*)+)\s+import\s+(.+)$",
        _re.MULTILINE,
    )
    shims_written: List[str] = []
    for rel in touched_py:
        abs_path = backend_dir / rel
        if not abs_path.is_file():
            continue
        try:
            text = abs_path.read_text(encoding="utf-8")
        except OSError:
            continue
        package_dir = abs_path.parent

        def _parse_symbols(symbols_raw: str) -> List[str]:
            if "#" in symbols_raw:
                symbols_raw = symbols_raw.split("#", 1)[0]
            symbols_raw = symbols_raw.strip().rstrip("\\").strip("()").strip()
            return [s.strip() for s in symbols_raw.split(",") if s.strip()]

        def _write_shim(
            shim_dir: Path, module_name: str, symbols: List[str],
            package_dotted_search: str,
        ) -> None:
            """Build + write a re-export shim if any symbol exists in baseline."""

            shim_path = shim_dir / f"{module_name}.py"
            if shim_path.is_file():
                return
            try:
                pkg_rel = shim_dir.relative_to(backend_dir)
            except ValueError:
                return
            ls = subprocess.run(
                ["git", "ls-tree", "-r", "--name-only", "baseline",
                 str(pkg_rel)],
                cwd=backend_dir, capture_output=True, text=True,
            )
            if ls.returncode != 0:
                return
            sibling_rels = [
                ln.strip() for ln in ls.stdout.splitlines()
                if ln.strip().endswith(".py")
            ]
            symbol_source: dict = {}
            for sib in sibling_rels:
                blob = subprocess.run(
                    ["git", "show", f"baseline:{sib}"],
                    cwd=backend_dir, capture_output=True, text=True,
                )
                if blob.returncode != 0:
                    continue
                content = blob.stdout
                sib_module = Path(sib).stem
                for sym in symbols:
                    if sym in symbol_source:
                        continue
                    if (
                        f"class {sym}" in content
                        or f"def {sym}" in content
                        or _re.search(
                            rf"^{_re.escape(sym)}\s*=",
                            content, _re.MULTILINE,
                        )
                    ):
                        symbol_source[sym] = sib_module
            if not symbol_source:
                return
            grouped: dict = {}
            for sym, source in symbol_source.items():
                grouped.setdefault(source, []).append(sym)
            lines = [
                f"# Auto-generated shim — the ./ai agent imported "
                f"`{package_dotted_search}` but never created the module.",
                "# Re-exports the requested symbols from their baseline "
                "locations so the rest of the agent's changes can keep "
                "running.",
                "",
            ]
            for source, syms in grouped.items():
                joined = ", ".join(syms)
                lines.append(f"from .{source} import {joined}")
            lines.append("")
            shim_path.parent.mkdir(parents=True, exist_ok=True)
            shim_path.write_text("\n".join(lines), encoding="utf-8")
            shims_written.append(str(shim_path.relative_to(backend_dir)))
            progress(
                f"  · synthesised shim "
                f"{shim_path.relative_to(backend_dir)} "
                f"(re-exports {sum(len(v) for v in grouped.values())} "
                "symbol(s) from baseline)"
            )

        # Relative imports: ``from .X import Y, Z``
        for match in rel_import_re.finditer(text):
            module = match.group(1)
            syms = _parse_symbols(match.group(2))
            if not syms:
                continue
            _write_shim(package_dir, module, syms,
                        package_dotted_search=f".{module}")

        # Absolute imports targeting an app.* subpackage that doesn't
        # exist yet, e.g.
        # ``from app.wrapper_api.models import WrapperUser`` when
        # ``app/wrapper_api/models.py`` is missing.
        for match in abs_import_re.finditer(text):
            dotted = match.group(1)  # "app.wrapper_api.models"
            syms = _parse_symbols(match.group(2))
            if not syms:
                continue
            parts = dotted.split(".")
            # parts[0] == "app"; last part is the module file name.
            shim_dir = backend_dir / Path(*parts[:-1])
            if not shim_dir.is_dir():
                continue
            module_name = parts[-1]
            _write_shim(shim_dir, module_name, syms,
                        package_dotted_search=dotted)
    return shims_written


def _recover_pizza_baseline_files(
    backend_dir: Path, progress=print,
) -> List[str]:
    """Selectively restore pizza-contract files from baseline.

    Diffs HEAD against the ``baseline`` ref, identifies every file the
    agent touched inside :data:`_PIZZA_BASELINE_PREFIXES`, and reverts
    those to baseline via ``git checkout baseline -- <path>``. Files
    the agent added/modified OUTSIDE those prefixes — e.g. a new
    ``app/reservations/`` module — stay as the agent left them so the
    feature it (hopefully) implemented can still be exercised by
    V_reservation.

    Returns the list of paths actually rewritten.
    """
    if not (backend_dir / ".git").is_dir():
        progress("  · no service git repo — skipping baseline recovery")
        return []
    # Identify every file the agent touched since baseline. The
    # per-service ./ai writes uncommitted changes to the working tree,
    # so we diff baseline against the working tree (no second ref) and
    # ALSO list untracked files (the agent may have added new files
    # the diff would miss).
    diff = subprocess.run(
        ["git", "diff", "--name-only", "baseline"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    if diff.returncode != 0:
        progress(f"  · git diff failed: {diff.stderr.strip()[-200:]}")
        return []
    untracked = subprocess.run(
        ["git", "ls-files", "--others", "--exclude-standard"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    touched: List[str] = []
    for line in diff.stdout.splitlines():
        line = line.strip()
        if line:
            touched.append(line)
    if untracked.returncode == 0:
        for line in untracked.stdout.splitlines():
            line = line.strip()
            if line:
                touched.append(line)
    candidates = [
        f for f in touched
        if any(f.startswith(p) or f == p for p in _PIZZA_BASELINE_PREFIXES)
    ]
    # Also rollback deleted-by-agent files that exist in baseline
    # (e.g. if the agent removed a wrapper_api helper).
    ls_baseline = subprocess.run(
        ["git", "ls-tree", "-r", "--name-only", "baseline"],
        cwd=backend_dir, capture_output=True, text=True,
    )
    if ls_baseline.returncode == 0:
        baseline_files = set(
            ls_baseline.stdout.splitlines()
        )
        # Files that vanished from the working tree but existed at
        # baseline under a guarded prefix must be restored too.
        for f in baseline_files:
            if any(f.startswith(p) or f == p for p in _PIZZA_BASELINE_PREFIXES):
                if not (backend_dir / f).exists() and f not in candidates:
                    candidates.append(f)
    # Compute which candidates already exist in baseline; the ones
    # that DON'T are agent-added files inside a guarded prefix and
    # must be deleted instead of "checked out" (which would fail
    # since baseline has no copy to restore).
    baseline_set = set()
    if ls_baseline.returncode == 0:
        baseline_set = set(ls_baseline.stdout.splitlines())

    rewritten: List[str] = []
    removed: List[str] = []
    for rel in candidates:
        target = backend_dir / rel
        if rel in baseline_set:
            result = subprocess.run(
                ["git", "checkout", "baseline", "--", rel],
                cwd=backend_dir, capture_output=True, text=True,
            )
            if result.returncode == 0:
                rewritten.append(rel)
        else:
            # Untracked-by-baseline file in a guarded prefix —
            # it's pollution the agent added to wrapper-shared
            # code. Delete it so the restored baseline imports work.
            if target.is_file():
                try:
                    target.unlink()
                    removed.append(rel)
                except OSError:
                    pass
    if rewritten or removed:
        msg_parts = []
        if rewritten:
            msg_parts.append(f"restored {len(rewritten)} file(s)")
        if removed:
            msg_parts.append(f"removed {len(removed)} agent-added file(s)")
        progress(
            "  · pizza-contract rollback: "
            + ", ".join(msg_parts)
            + " (reservation-related new files OUTSIDE guarded prefixes preserved)"
        )
    else:
        progress("  · no pizza-contract files needed rollback")
    return rewritten + removed


def invoke_ai_apply(
    wrapper: Path, backend_slug: str, prompt: str, *,
    timeout_s: int = 1200,
    fix_timeout_m: int = 10,
    model: Optional[str] = None,
    ollama_url: Optional[str] = None,
) -> None:
    """Run ``./ai <backend> apply "<prompt>"`` against the wrapper.

    The wrapper-level ``ai`` script dispatches to ``backend_slug/ai``
    when the first positional arg matches a service slug. Per-service
    ``./ai apply`` runs the LM, writes diffs, then loops the service's
    ``./test`` command with a fix model until tests pass.

    Two budgets bound the agent:

    * ``fix_timeout_m`` is the inner ./ai fix-loop budget (passed via
      ``--fix-timeout-m``). Caps the model's own retry cycle so a
      stuck loop returns control to us within a known window.
    * ``timeout_s`` is the outer subprocess timeout that ALSO covers
      the initial LM call + retrieval + diff write. Always larger
      than ``fix_timeout_m * 60`` so the inner budget can complete
      naturally before we hard-kill the subprocess.

    Returns normally on both success AND when the inner fix loop
    exhausts its budget — failure of ./ai apply does NOT abort the
    scenario, because the V_pizza regression step below is the
    authoritative pass/fail signal and can recover from many partial
    failures via selective baseline rollback.
    """
    cmd = [
        str(wrapper / "ai"),
        backend_slug,
        "apply",
        prompt,
        "--allow-dirty",
        # Skip ./ai's own fix-loop verification. Without --no-verify,
        # ``./ai`` does a ``git stash`` before applying and a
        # ``git stash pop`` on fix-loop failure — meaning the
        # agent's proposed files are silently REVERTED when its
        # internal ``./test`` budget is exhausted, leaving our
        # outer V_pizza regression + V_reservation runs with no
        # agent code to verify. The dev_skel ``./test`` script also
        # collects AI-generated integration tests that frequently
        # ship broken (a known limitation noted in CLAUDE.md), so
        # the inner fix-loop is doomed on this scenario anyway.
        # --no-verify keeps the agent's full proposal on disk so
        # we can run our own authoritative verifications.
        "--no-verify",
        "--fix-timeout-m", str(fix_timeout_m),
    ]
    if model:
        cmd.extend(["--ollama-model", model])
    if ollama_url:
        cmd.extend(["--ollama-url", ollama_url])
    print(
        f"  running ./ai {backend_slug} apply "
        f"(outer={timeout_s}s, inner fix-loop={fix_timeout_m}m"
        + (f", model={model}" if model else "")
        + (f", url={ollama_url}" if ollama_url else "")
        + ")..."
    )
    started = time.monotonic()
    try:
        result = subprocess.run(
            cmd,
            cwd=wrapper,
            env={**os.environ, "PYTHONUNBUFFERED": "1"},
            capture_output=False,  # stream to caller's stdout
            text=True,
            timeout=timeout_s,
        )
    except subprocess.TimeoutExpired:
        elapsed = time.monotonic() - started
        print(
            f"  · ./ai apply outer-timed-out after {elapsed:.0f}s — "
            "continuing to V_pizza regression (the agent may have left "
            "useful partial work on disk)"
        )
        return
    elapsed = time.monotonic() - started
    if result.returncode != 0:
        print(
            f"  · ./ai apply exited {result.returncode} after "
            f"{elapsed:.0f}s — continuing to V_pizza regression "
            "(partial agent output may still be usable)"
        )
        return
    print(f"  ./ai apply completed in {elapsed:.0f}s")


