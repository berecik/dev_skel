def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Iterative-./ai test scenario: generate the pizzeria, then "
            "ask the per-service ./ai agent to add a table reservation "
            "system, then verify the pizza ordering flow regression-"
            "passes and the new reservation flow accepts valid "
            "bookings / rejects malformed ones."
        ),
    )
    parser.add_argument(
        "--keep", action="store_true",
        help="leave the generated wrapper on disk after the test finishes",
    )
    parser.add_argument(
        "--port", type=int, default=DEFAULT_PORT,
        help=f"TCP port for the backend (default: {DEFAULT_PORT})",
    )
    parser.add_argument(
        "--server-startup-timeout", type=int, default=DEFAULT_STARTUP_TIMEOUT,
        help=f"seconds to wait for the backend (default: {DEFAULT_STARTUP_TIMEOUT})",
    )
    parser.add_argument(
        "--ai-timeout-m", type=int, default=20,
        help=(
            "outer minutes budget for the ./ai apply subprocess "
            "(default: 20). Hard-killed by us if exceeded."
        ),
    )
    parser.add_argument(
        "--ai-fix-timeout-m", type=int, default=10,
        help=(
            "inner ./ai fix-loop budget in minutes (default: 10). "
            "Always smaller than --ai-timeout-m so the agent exits "
            "naturally before we kill it."
        ),
    )
    parser.add_argument(
        "--no-skip", action="store_true",
        help="treat missing toolchain as hard failure instead of skip",
    )
    parser.add_argument(
        "--skip-baseline-check", action="store_true",
        help=(
            "skip Phase 2 (V_pizza baseline) — useful when iterating "
            "on the agent prompt and you trust the pizzeria runner is "
            "already green"
        ),
    )
    return parser.parse_args()


