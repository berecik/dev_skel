def main() -> int:
    args = parse_args()

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)
    wrapper = repo_root / "_test_projects" / PROJECT_NAME
    port = args.port
    backend_url = f"http://127.0.0.1:{port}"

    print()
    print("=== Pizza Reservation Iterative-./ai Test ===")
    print(f"  backend:   {BACKEND_SKEL}")
    print(f"  wrapper:   {wrapper}")
    print(f"  port:      {port}")
    print()

    # Phase 0
    if not ollama_reachable():
        msg = "Ollama is not reachable"
        if args.no_skip:
            print(f"  ✗ {msg}")
            return EXIT_FAIL
        print(f"  · skipping ({msg})")
        return EXIT_SETUP

    final_exit = EXIT_OK
    server_proc = None
    log_fp = None

    try:
        # Phase 1: generate
        print("Phase 1: generating pizzeria baseline...")
        backend_slug, _react_slug = generate_scenario_baseline(
            repo_root, wrapper, port,
        )
        backend_dir = wrapper / backend_slug

        # Phase 2: baseline V_pizza (so we know the starting point is green)
        if not args.skip_baseline_check:
            print()
            print("Phase 2: V_pizza baseline (must pass before refactor)...")
            server_proc, log_fp, _log_path = _restart_backend(
                backend_dir, wrapper, port, backend_url,
                args.server_startup_timeout,
            )
            exercise_pizzeria_api(backend_url)
            _stop_backend(server_proc, log_fp)
            server_proc, log_fp = None, None
            print("  ✓ V_pizza baseline green")
        else:
            print("Phase 2: skipped (--skip-baseline-check)")

        # Phase 3: git init so ./ai apply has a clean tree to diff
        print()
        print("Phase 3: git-init wrapper + service for ./ai diff baseline...")
        _git_init_baseline(wrapper, backend_dir)
        # Wipe the shared DB BEFORE git init so the empty DB IS the
        # baseline state. The next backend restart re-seeds default
        # accounts from env vars and Phase 5's register call hits a
        # clean schema.
        _reset_shared_db(wrapper)

        # Phase 4: invoke ./ai
        print()
        print("Phase 4: iterative ./ai apply (table reservation feature)...")
        print(f"  prompt: {RESERVATION_PROMPT[:120]}...")
        invoke_ai_apply(
            wrapper, backend_slug, RESERVATION_PROMPT,
            timeout_s=args.ai_timeout_m * 60,
            fix_timeout_m=args.ai_fix_timeout_m,
        )

        # Phase 4b: sanitise common agent anti-patterns BEFORE
        # running any verification. Cheap regex fixes for
        # ``Depends(CurrentUser)`` and friends. Also open the
        # wrapper's ``SQLModel.metadata.create_all(tables=[...])``
        # allowlist so the agent's new feature tables actually
        # exist on disk before any HTTP request hits them.
        _open_table_creation(backend_dir)
        sanitised = _sanitize_agent_outputs(backend_dir)
        if sanitised:
            print(
                f"  · sanitised {len(sanitised)} agent file(s) "
                "before verification"
            )

        # Phase 5: V_pizza regression
        # If the agent corrupted the ordering contract (deleted helpers,
        # introduced unresolved imports, changed status codes), restore
        # ``_PIZZA_BASELINE_FILES`` from the baseline commit and retry
        # ONCE. Reservation-related new files the agent created stay
        # untouched. This separates two real-world failure modes:
        #
        #   * "the agent didn't manage to keep the pizza contract
        #     intact but did produce reservation code" — recoverable,
        #     V_pizza still passes after rollback, V_reservation can
        #     still be evaluated.
        #   * "the agent broke things so thoroughly that even after
        #     rollback the server won't start" — non-recoverable, the
        #     scenario fails hard.
        print()
        print("Phase 5: V_pizza regression (existing pizza flow must still pass)...")
        # Reset the shared DB before each regression attempt: Phase 2's
        # baseline run + any ./ai fix-loop test invocations may have
        # written rows that conflict with the regression's "fresh
        # register". The default-account seeder re-runs at startup.
        _reset_shared_db(wrapper)
        try:
            server_proc, log_fp, _log_path = _restart_backend(
                backend_dir, wrapper, port, backend_url,
                args.server_startup_timeout,
            )
            exercise_pizzeria_api(backend_url)
            print("  ✓ V_pizza regression green")
        except (AssertionError, RuntimeError) as first_exc:
            print(
                f"  · V_pizza failed first try ({first_exc}); attempting "
                "lightweight recovery (synthesise missing-module shims)..."
            )
            _stop_backend(server_proc, log_fp)
            server_proc, log_fp = None, None
            recovered_via_shim = False
            # Step 5a: try the cheapest recovery first — synthesise
            # a shim that re-exports each missing-module symbol from
            # its baseline location. This preserves the agent's NEW
            # files (routes, models, etc.) so V_reservation has a
            # chance of passing.
            shims = _synth_missing_module_shims(backend_dir)
            if shims:
                _reset_shared_db(wrapper)
                print(
                    f"  · retrying V_pizza after {len(shims)} shim(s)..."
                )
                try:
                    server_proc, log_fp, _log_path = _restart_backend(
                        backend_dir, wrapper, port, backend_url,
                        args.server_startup_timeout,
                    )
                    exercise_pizzeria_api(backend_url)
                except (AssertionError, RuntimeError) as second_exc:
                    print(
                        f"  · shim recovery insufficient ({second_exc}); "
                        "falling back to full baseline rollback..."
                    )
                    _stop_backend(server_proc, log_fp)
                    server_proc, log_fp = None, None
                else:
                    print(
                        f"  ✓ V_pizza regression green (recovered via "
                        f"{len(shims)} missing-module shim(s) — agent's "
                        "new files preserved)"
                    )
                    recovered_via_shim = True
            if not recovered_via_shim:
                # Step 5b: full baseline rollback fallback. Loses
                # the agent's edits inside guarded prefixes but is
                # the cheapest path to a green V_pizza. We then:
                #   (i) re-mount any new agent-created routers
                #       under ``app/<feature>/`` by appending
                #       include_router statements to the restored
                #       ``app/routes.py``;
                #   (ii) run the shim synthesiser AGAIN — after
                #       rollback the agent's new ``app/<feature>/``
                #       files may still import from missing modules
                #       under the now-restored wrapper_api (e.g.
                #       ``from app.wrapper_api.models import WrapperUser``
                #       when WrapperUser actually lives in
                #       ``wrapper_api.db``).
                rewritten = _recover_pizza_baseline_files(backend_dir)
                if not rewritten:
                    raise  # no recovery possible — bail with original error
                remounted = _remount_new_routers(backend_dir)
                post_shims = _synth_missing_module_shims(backend_dir)
                # Re-open table creation after rollback restored
                # the closed-allowlist version of db.py.
                _open_table_creation(backend_dir)
                _reset_shared_db(wrapper)
                print("  · retrying V_pizza after full rollback...")
                server_proc, log_fp, _log_path = _restart_backend(
                    backend_dir, wrapper, port, backend_url,
                    args.server_startup_timeout,
                )
                exercise_pizzeria_api(backend_url)
                extra_parts = []
                if remounted:
                    extra_parts.append(f"re-mounted {', '.join(remounted)}")
                if post_shims:
                    extra_parts.append(f"+{len(post_shims)} post-rollback shim(s)")
                extra = f" ({', '.join(extra_parts)})" if extra_parts else ""
                print(
                    "  ✓ V_pizza regression green (recovered via "
                    f"baseline rollback of {len(rewritten)} file(s){extra})"
                )

        # Phase 6: V_reservation
        print()
        print("Phase 6: V_reservation (new feature)...")
        verify_reservation_flow(backend_url)

        print()
        print("=== ALL CHECKS PASSED (V_pizza + V_reservation) ===")

    except AssertionError as exc:
        print()
        print(f"  ✗ assertion failed: {exc}")
        final_exit = EXIT_FAIL
    except subprocess.TimeoutExpired as exc:
        print()
        print(f"  ✗ timeout: {exc}")
        final_exit = EXIT_FAIL
    except RuntimeError as exc:
        print()
        print(f"  ✗ {exc}")
        final_exit = EXIT_FAIL
    except Exception as exc:  # noqa: BLE001 — final-resort surface
        print()
        print(f"  ✗ unexpected error: {exc!r}")
        final_exit = EXIT_FAIL
    finally:
        _stop_backend(server_proc, log_fp)
        if args.keep:
            print()
            print(f"  --keep: wrapper left at {wrapper}")
        elif wrapper.exists():
            print(f"  cleaning {wrapper}")
            shutil.rmtree(wrapper, ignore_errors=True)

    return final_exit


if __name__ == "__main__":
    sys.exit(main())
