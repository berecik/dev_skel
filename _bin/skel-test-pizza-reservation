def _git_init_baseline(
    wrapper: Path, backend_dir: Path, progress=print,
) -> None:
    """Initialise a git repo at BOTH the wrapper and service level.

    ``./ai apply`` walks up looking for a ``.git`` directory; the
    per-service ``./ai`` warns "rollback unavailable" when there's no
    repo *inside the service*, so we init one in ``backend_dir`` too.
    That gives the runner a known checkpoint to selectively roll back
    individual files if the agent corrupts them — see
    :func:`_recover_pizza_baseline_files`.
    """
    for target in (wrapper, backend_dir):
        if (target / ".git").is_dir():
            continue  # already a repo (e.g. a re-run with --keep)
        progress(f"  initialising git repo at {target.relative_to(wrapper.parent)}")
        subprocess.run(
            ["git", "init", "--quiet", "--initial-branch=baseline"],
            cwd=target, check=True,
        )
        subprocess.run(
            ["git", "-c", "user.email=skel@dev.local",
             "-c", "user.name=Dev Skel",
             "add", "."],
            cwd=target, check=True,
        )
        subprocess.run(
            ["git", "-c", "user.email=skel@dev.local",
             "-c", "user.name=Dev Skel",
             "commit", "--quiet", "-m", "baseline: generated pizzeria"],
            cwd=target, check=True,
        )


# Directories that are wrapper-shared / pizza-contract-owning. If
