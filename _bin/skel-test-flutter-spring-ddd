#!/usr/bin/env python3
"""End-to-end integration test: Java Spring Boot backend + Flutter frontend.

Generates a wrapper containing both ``java-spring-skel`` and
``flutter-skel``, configures ``BACKEND_URL`` to a non-conflicting
port, re-copies the wrapper-shared ``.env`` into the Flutter project's
bundled asset, runs ``flutter pub get`` + ``flutter build web``
(verifying the URL is bundled into the asset), packages + starts
the Spring Boot JAR in the background, and exercises the canonical
``register -> login -> CRUD -> complete`` flow over real HTTP.

The HTTP exercise hits the BACKEND directly (not the Flutter app),
proving that the same items API contract works for both frontends.
The Flutter-specific value-add is the bundled-``.env`` inspection,
which confirms ``flutter_dotenv`` will read the right ``BACKEND_URL``
at runtime.

Usage::

    _bin/skel-test-flutter-spring-ddd              # full run
    _bin/skel-test-flutter-spring-ddd --keep       # leave wrapper on disk
    _bin/skel-test-flutter-spring-ddd --port 18784 # custom port
    _bin/skel-test-flutter-spring-ddd --no-skip    # fail on missing Flutter/Java

Exit codes::

    0 — every check passed
    1 — at least one check failed
    2 — toolchain (Flutter / Java / Maven) missing or setup error
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

from dev_skel_lib import DevSkelConfig, detect_root, load_config  # noqa: E402

from _frontend_backend_lib import (  # noqa: E402
    DEFAULT_STARTUP_TIMEOUT,
    EXIT_FAIL,
    EXIT_SETUP,
    FLUTTER_FRONTEND,
    BackendSpec,
    run_frontend_backend_integration,
)


PROJECT_NAME = "test-flutter-spring-ddd"
BACKEND_SKEL = "java-spring-ddd-skel"
BACKEND_SERVICE_NAME = "Items API"

FLUTTER_DEFAULT_PORT = 18784


def _resolve_mvn_runtime_java() -> str | None:
    """Return the absolute path of the JDK Maven uses, or ``None``.

    Parses the third line of ``mvn --version`` output, e.g.::

        Java version: 25.0.2, vendor: Homebrew, runtime: /.../openjdk.jdk/Contents/Home

    and returns ``<runtime>/bin/java``. Returns ``None`` when ``mvn``
    is not on ``PATH``, when the parse fails, or when the resolved
    binary does not exist (the harness then falls back to ``java``
    from ``PATH``).
    """

    if not shutil.which("mvn"):
        return None
    try:
        out = subprocess.run(
            ["mvn", "--version"],
            check=False,
            capture_output=True,
            text=True,
            timeout=30,
        )
    except (subprocess.TimeoutExpired, OSError):
        return None
    if out.returncode != 0:
        return None
    match = re.search(r"runtime:\s*(\S.+?)\s*(?:$|\n)", out.stdout, re.MULTILINE)
    if not match:
        return None
    runtime = match.group(1).strip().rstrip(",")
    candidate = os.path.join(runtime, "bin", "java")
    if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
        return candidate
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Integration test that generates a wrapper containing "
            "java-spring-skel + flutter-skel, builds the Flutter web "
            "bundle, packages + starts the Spring Boot backend, and "
            "verifies the items API end-to-end via real HTTP."
        ),
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help=(
            "Leave the generated wrapper at "
            "_test_projects/test-flutter-spring-ddd on disk after the test "
            "finishes. Useful for poking at the build or running the "
            "server manually."
        ),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=FLUTTER_DEFAULT_PORT,
        help=(
            "TCP port the Spring Boot backend should bind to. The wrapper "
            f"BACKEND_URL is rewritten to http://127.0.0.1:<port> before "
            f"the Flutter web build runs. Default: {FLUTTER_DEFAULT_PORT}."
        ),
    )
    parser.add_argument(
        "--server-startup-timeout",
        type=int,
        default=max(DEFAULT_STARTUP_TIMEOUT, 120),
        help=(
            "Seconds to wait for the Spring Boot server to become "
            f"reachable on the chosen port (default: {max(DEFAULT_STARTUP_TIMEOUT, 120)}). "
            "Higher than the FastAPI/django-bolt default because JVM "
            "boot + Spring context init takes longer than uvicorn boot."
        ),
    )
    parser.add_argument(
        "--no-skip",
        action="store_true",
        help=(
            "Treat missing Flutter SDK or Java/Maven as a hard failure "
            "(exit 1) instead of the default toolchain skip (exit 2)."
        ),
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    for tool, label in (("mvn", "Maven"), ("java", "Java")):
        if not shutil.which(tool):
            msg = f"{tool} ({label}) not on PATH (required to build the Spring Boot backend)"
            if args.no_skip:
                print(f"  \u2717 {msg}")
                return EXIT_FAIL
            print(f"  \u00b7 skipping ({msg})")
            return EXIT_SETUP

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)

    # Resolve the JDK Maven uses so the JAR runs with matching bytecode.
    java_executable = _resolve_mvn_runtime_java() or "java"

    pre_setup = [
        (
            "mvn -q -DskipTests package",
            ["mvn", "-q", "-DskipTests", "package"],
        ),
    ]

    spec = BackendSpec(
        skeleton=BACKEND_SKEL,
        service_name=BACKEND_SERVICE_NAME,
        server_argv_template=[
            "bash",
            "-c",
            f"exec '{java_executable}' -jar target/*.jar",
        ],
        pre_server_setup=pre_setup,
        extra_env={
            "SERVICE_HOST": "127.0.0.1",
            "SERVICE_PORT": str(args.port),
            "SPRING_DATASOURCE_URL": "jdbc:h2:mem:flutterspring;DB_CLOSE_DELAY=-1",
            "SPRING_DATASOURCE_USERNAME": "sa",
            "SPRING_DATASOURCE_PASSWORD": "",
        },
    )

    return run_frontend_backend_integration(
        frontend=FLUTTER_FRONTEND,
        project_name=PROJECT_NAME,
        title="Flutter + Spring Boot integration test",
        spec=spec,
        repo_root=repo_root,
        port=args.port,
        server_startup_timeout=args.server_startup_timeout,
        keep=args.keep,
        no_skip=args.no_skip,
    )


if __name__ == "__main__":
    sys.exit(main())
