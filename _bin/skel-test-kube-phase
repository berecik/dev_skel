#!/usr/bin/env python3
"""Smoke: run_kubernetes_phase() in static-only mode (skip_kind+skip_ai).

Exercises:
- Tier-1 helm-gen invocation end-to-end
- `_managed/<svc>/` scaffolding for every service in the project
- Second-run idempotency
- `overrides/` preservation across consecutive runs

Exits 2 ("skipped") when `helm` is not on PATH.
"""
from __future__ import annotations

import shutil
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT / "_bin"))

from skel_ai_lib import run_kubernetes_phase  # noqa: E402

TEST_DIR = REPO_ROOT / "_test_projects" / "test-kube-phase"


def _run(argv, **kw):
    return subprocess.run(argv, capture_output=True, text=True, **kw)


def _which(tool: str) -> bool:
    return _run(["which", tool]).returncode == 0


def main() -> int:
    if not _which("helm"):
        print("[kube-phase] SKIP — helm not installed", file=sys.stderr)
        return 2

    if TEST_DIR.exists():
        shutil.rmtree(TEST_DIR)

    gen = _run(
        ["make", "gen-stack-web", f"NAME=_test_projects/{TEST_DIR.name}"],
        cwd=REPO_ROOT,
    )
    if gen.returncode != 0:
        print("[kube-phase] FAIL: gen-stack-web", file=sys.stderr)
        print(gen.stdout + gen.stderr, file=sys.stderr)
        return 1

    result = run_kubernetes_phase(
        client=None,
        wrapper_dir=TEST_DIR,
        project_yml=None,
        skip_ai=True,
        skip_kind=True,
    )
    if not result.ok:
        print(f"[kube-phase] FAIL (static): {result.error}", file=sys.stderr)
        return 1

    templates = TEST_DIR / "deploy" / "helm" / "templates"
    required_files = [
        templates / "_generated" / "service-deployment.yaml",
        templates / "_generated" / "namespace.yaml",
    ]
    for p in required_files:
        if not p.exists():
            print(f"[kube-phase] FAIL: missing {p.relative_to(TEST_DIR)}",
                  file=sys.stderr)
            return 1
    for svc in ("items_api", "web_ui"):
        svc_dir = templates / "_managed" / svc
        if not svc_dir.is_dir():
            print(f"[kube-phase] FAIL: _managed/{svc}/ not created",
                  file=sys.stderr)
            return 1

    # Idempotency: second run is a clean no-op
    result2 = run_kubernetes_phase(
        client=None, wrapper_dir=TEST_DIR, project_yml=None,
        skip_ai=True, skip_kind=True,
    )
    if not result2.ok:
        print(f"[kube-phase] FAIL: second run: {result2.error}",
              file=sys.stderr)
        return 1

    # Overrides preservation
    marker = templates / "overrides" / "marker.yaml"
    marker.write_text("# user-authored\n", encoding="utf-8")
    for _ in range(3):
        run_kubernetes_phase(
            client=None, wrapper_dir=TEST_DIR, project_yml=None,
            skip_ai=True, skip_kind=True,
        )
    if not marker.exists() or marker.read_text() != "# user-authored\n":
        print("[kube-phase] FAIL: overrides/marker.yaml was disturbed",
              file=sys.stderr)
        return 1

    print("[kube-phase] static path OK")

    # Opportunistic AI branch — only when Ollama is reachable.
    if _ollama_up():
        print("[kube-phase] Ollama reachable — exercising AI Tier-2")
        shutil.rmtree(TEST_DIR)
        gen2 = _run(
            ["make", "gen-stack-web", f"NAME=_test_projects/{TEST_DIR.name}"],
            cwd=REPO_ROOT,
        )
        if gen2.returncode != 0:
            print(gen2.stdout + gen2.stderr, file=sys.stderr)
            return 1
        ai_result = run_kubernetes_phase(
            client=None,
            wrapper_dir=TEST_DIR,
            project_yml=None,
            skip_ai=False,
            skip_kind=True,
        )
        # ai_result.ok may be False because helm lint caught bad Tier-2
        # output; that is expected until Task 7's fix-loop ships. The
        # Task 5 bar is "AI actually wrote to _managed/<svc>/".
        mgmt = TEST_DIR / "deploy" / "helm" / "templates" / "_managed"
        required = [
            mgmt / "items_api" / "configmap.yaml",
            mgmt / "items_api" / "hpa.yaml",
            mgmt / "web_ui" / "nginx-configmap.yaml",
        ]
        for p in required:
            if not p.is_file() or p.stat().st_size < 10:
                print(
                    f"[kube-phase] FAIL (AI): {p.relative_to(TEST_DIR)} "
                    "missing or suspiciously small",
                    file=sys.stderr,
                )
                return 1
        tier2_count = len(list(mgmt.rglob("*.yaml")))
        if ai_result.ok:
            print(f"[kube-phase] AI pass OK ({tier2_count} Tier-2 files, lint green)")
        else:
            print(
                f"[kube-phase] AI pass OK ({tier2_count} Tier-2 files written; "
                f"lint failure deferred to Task 7: {ai_result.error})"
            )
    else:
        print("[kube-phase] Ollama unreachable — AI branch skipped")

    shutil.rmtree(TEST_DIR)
    print("[kube-phase] OK")
    return 0


def _ollama_up() -> bool:
    import os
    import urllib.error
    import urllib.request

    url = os.environ.get("OLLAMA_URL", "http://localhost:11434") + "/api/tags"
    try:
        with urllib.request.urlopen(url, timeout=2) as r:
            return r.status == 200
    except (urllib.error.URLError, OSError, TimeoutError):
        return False


if __name__ == "__main__":
    raise SystemExit(main())
