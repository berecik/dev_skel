#!/usr/bin/env python3
"""List available skeletons (relocatable)."""

from pathlib import Path

from dev_skel_lib import detect_root, list_skeletons, load_config


def main() -> None:
    script_dir = Path(__file__).resolve().parent
    cfg = load_config()
    root = detect_root(script_dir, cfg.skel_dir)
    skels = list_skeletons(root / "_skels")
    for name in skels:
        print(name)


if __name__ == "__main__":
    main()
