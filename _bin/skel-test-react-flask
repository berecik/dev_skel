#!/usr/bin/env python3
"""End-to-end integration test: Python Flask backend + React frontend.

Generates a wrapper containing both ``python-flask-skel`` and
``ts-react-skel``, configures ``BACKEND_URL`` to a non-conflicting
port, builds the React frontend (verifying the URL is baked into the
bundle), starts the Flask backend in the background via the venv's
own ``python run.py`` (so the wrapper-shared ``SERVICE_PORT`` env var
is honoured), and exercises the canonical
``register → login → CRUD → complete → reject anonymous → reject
invalid token`` flow over real HTTP using the same shape the React
``src/api/items.ts`` client uses.

Usage::

    _bin/skel-test-react-flask              # full run
    _bin/skel-test-react-flask --keep       # leave wrapper on disk
    _bin/skel-test-react-flask --port 19881 # custom port
    _bin/skel-test-react-flask --no-skip    # fail on missing Node/Python

Exit codes::

    0 — every check passed
    1 — at least one check failed
    2 — toolchain (Node / npm / Python) missing or setup error
"""

from __future__ import annotations

import argparse
import shutil
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

from dev_skel_lib import DevSkelConfig, detect_root, load_config  # noqa: E402

from _frontend_backend_lib import (  # noqa: E402
    DEFAULT_PORT,
    DEFAULT_STARTUP_TIMEOUT,
    EXIT_FAIL,
    EXIT_SETUP,
    BackendSpec,
    run_react_backend_integration,
)


PROJECT_NAME = "test-react-flask"
BACKEND_SKEL = "python-flask-skel"
BACKEND_SERVICE_NAME = "Items API"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Integration test that generates a wrapper containing "
            "python-flask-skel + ts-react-skel, builds the React frontend, "
            "starts the Flask backend, and verifies the items API "
            "end-to-end via real HTTP."
        ),
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help=(
            "Leave the generated wrapper at "
            "_test_projects/test-react-flask on disk after the test "
            "finishes. Useful for poking at the build or running the "
            "server manually."
        ),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help=(
            "TCP port the Flask backend should bind to. The wrapper "
            f"BACKEND_URL is rewritten to http://127.0.0.1:<port> before "
            f"the React build runs. Default: {DEFAULT_PORT}."
        ),
    )
    parser.add_argument(
        "--server-startup-timeout",
        type=int,
        default=DEFAULT_STARTUP_TIMEOUT,
        help=(
            "Seconds to wait for the Flask server to become reachable on "
            f"the chosen port (default: {DEFAULT_STARTUP_TIMEOUT})."
        ),
    )
    parser.add_argument(
        "--no-skip",
        action="store_true",
        help=(
            "Treat missing Node/npm/Python as a hard failure (exit 1) "
            "instead of the default toolchain skip (exit 2)."
        ),
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if not shutil.which("python3"):
        msg = "python3 not on PATH (required to run the Flask backend)"
        if args.no_skip:
            print(f"  ✗ {msg}")
            return EXIT_FAIL
        print(f"  · skipping ({msg})")
        return EXIT_SETUP

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)

    # The Flask skel's `gen` script creates `.venv/` and installs
    # PyJWT, bcrypt, pytest, etc., so the venv's python is the one
    # we should use here. `run.py` reads SERVICE_HOST + SERVICE_PORT
    # from the env, which we override below.
    spec = BackendSpec(
        skeleton=BACKEND_SKEL,
        service_name=BACKEND_SERVICE_NAME,
        server_argv_template=[
            ".venv/bin/python",
            "run.py",
        ],
        # `db.create_all()` runs from inside `create_app()`, so no
        # explicit pre-server setup is needed for the schema.
        pre_server_setup=[],
        # SQLite at the wrapper-shared `_shared/db.sqlite3` is the
        # default; override DATABASE_URL with a per-test sqlite file
        # so multiple test runs in the same wrapper don't pollute
        # each other's state.
        extra_env={
            "SERVICE_HOST": "127.0.0.1",
            "SERVICE_PORT": str(args.port),
            "DATABASE_URL": "sqlite:///react_flask_test.db",
            # Disable Flask's debug auto-reloader so we get a single
            # PID we can clean up. Debug mode is fine to leave on for
            # tracebacks; only the reloader is problematic.
            "FLASK_DEBUG": "0",
        },
    )

    return run_react_backend_integration(
        project_name=PROJECT_NAME,
        title="React + Flask integration test",
        spec=spec,
        repo_root=repo_root,
        port=args.port,
        server_startup_timeout=args.server_startup_timeout,
        keep=args.keep,
        no_skip=args.no_skip,
    )


if __name__ == "__main__":
    sys.exit(main())
