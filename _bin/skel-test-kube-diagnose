#!/usr/bin/env python3
"""Smoke test for _kube_diagnose_from_json() — parses kubectl JSON fixtures."""
from __future__ import annotations

import json
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(HERE))

from skel_ai_lib import _kube_diagnose_from_json  # noqa: E402

FIXTURES = HERE / "_fixtures" / "kube_diagnose"


def main() -> int:
    pods = json.loads((FIXTURES / "pods.json").read_text(encoding="utf-8"))
    events = json.loads((FIXTURES / "events.json").read_text(encoding="utf-8"))
    expected = (FIXTURES / "expected_bundle.txt").read_text(encoding="utf-8").strip()

    got = _kube_diagnose_from_json(
        pods=pods, events=events, describes={}, logs={}
    ).strip()

    if got != expected:
        print("[kube-diagnose] FAIL — diff:", file=sys.stderr)
        print("EXPECTED:", file=sys.stderr)
        print(expected, file=sys.stderr)
        print("GOT:", file=sys.stderr)
        print(got, file=sys.stderr)
        return 1
    print("[kube-diagnose] OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
