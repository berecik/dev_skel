#!/usr/bin/env python3
"""End-to-end integration test: Java Spring Boot backend + React frontend.

Generates a wrapper containing both ``java-spring-skel`` and
``ts-react-skel``, configures ``BACKEND_URL`` to a non-conflicting
port, builds the React frontend (verifying the URL is baked into the
bundle), packages + starts the Spring Boot JAR in the background, and
exercises the canonical ``register → login → CRUD → complete → reject
anonymous → reject invalid token`` flow over real HTTP using the same
shape the React ``src/api/items.ts`` client uses.

Usage::

    _bin/skel-test-react-spring-ddd              # full run
    _bin/skel-test-react-spring-ddd --keep       # leave wrapper on disk
    _bin/skel-test-react-spring-ddd --port 19880 # custom port
    _bin/skel-test-react-spring-ddd --no-skip    # fail on missing Java/Maven/Node

Exit codes::

    0 — every check passed
    1 — at least one check failed
    2 — toolchain (Node / npm / Java / Maven) missing or setup error
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

from dev_skel_lib import DevSkelConfig, detect_root, load_config  # noqa: E402

from _frontend_backend_lib import (  # noqa: E402
    DEFAULT_PORT,
    DEFAULT_STARTUP_TIMEOUT,
    EXIT_FAIL,
    EXIT_SETUP,
    BackendSpec,
    run_react_backend_integration,
)


PROJECT_NAME = "test-react-spring-ddd"
BACKEND_SKEL = "java-spring-ddd-skel"
BACKEND_SERVICE_NAME = "Items API"


def _resolve_mvn_runtime_java() -> str | None:
    """Return the absolute path of the JDK Maven uses, or ``None``.

    Parses the third line of ``mvn --version`` output, e.g.::

        Java version: 25.0.2, vendor: Homebrew, runtime: /.../openjdk.jdk/Contents/Home

    and returns ``<runtime>/bin/java``. Returns ``None`` when ``mvn``
    is not on ``PATH``, when the parse fails, or when the resolved
    binary does not exist (the harness then falls back to ``java``
    from ``PATH``).
    """

    if not shutil.which("mvn"):
        return None
    try:
        out = subprocess.run(
            ["mvn", "--version"],
            check=False,
            capture_output=True,
            text=True,
            timeout=30,
        )
    except (subprocess.TimeoutExpired, OSError):
        return None
    if out.returncode != 0:
        return None
    match = re.search(r"runtime:\s*(\S.+?)\s*(?:$|\n)", out.stdout, re.MULTILINE)
    if not match:
        return None
    runtime = match.group(1).strip().rstrip(",")
    candidate = os.path.join(runtime, "bin", "java")
    if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
        return candidate
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Integration test that generates a wrapper containing "
            "java-spring-skel + ts-react-skel, builds the React frontend, "
            "packages + starts the Spring Boot backend, and verifies the "
            "items API end-to-end via real HTTP."
        ),
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help=(
            "Leave the generated wrapper at "
            "_test_projects/test-react-spring-ddd on disk after the test "
            "finishes. Useful for poking at the build or running the "
            "server manually."
        ),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help=(
            "TCP port the Spring Boot backend should bind to. The wrapper "
            f"BACKEND_URL is rewritten to http://127.0.0.1:<port> before "
            f"the React build runs. Default: {DEFAULT_PORT}."
        ),
    )
    parser.add_argument(
        "--server-startup-timeout",
        type=int,
        default=max(DEFAULT_STARTUP_TIMEOUT, 120),
        help=(
            "Seconds to wait for the Spring Boot server to become "
            f"reachable on the chosen port (default: {max(DEFAULT_STARTUP_TIMEOUT, 120)}). "
            "Higher than the FastAPI/django-bolt default because JVM "
            "boot + Spring context init takes longer than uvicorn boot."
        ),
    )
    parser.add_argument(
        "--no-skip",
        action="store_true",
        help=(
            "Treat missing Node/npm/Java/Maven as a hard failure (exit 1) "
            "instead of the default toolchain skip (exit 2)."
        ),
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    for tool, label in (("mvn", "Maven"), ("java", "Java")):
        if not shutil.which(tool):
            msg = f"{tool} ({label}) not on PATH (required to build the Spring Boot backend)"
            if args.no_skip:
                print(f"  ✗ {msg}")
                return EXIT_FAIL
            print(f"  · skipping ({msg})")
            return EXIT_SETUP

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)

    # The skeleton targets Java 21. On dev machines with multiple
    # JDKs installed, `java` on $PATH may be older than what `mvn`
    # uses for compilation — that pairing produces a fatal
    # `UnsupportedClassVersionError` when the JAR is launched. We
    # parse `mvn -version` once up front, extract its `runtime`
    # path, and run the produced JAR with that same JVM. The result
    # is consistent class-file ↔ runtime bytecode levels regardless
    # of the user's $PATH ordering. If the parse fails we fall back
    # to `java` from $PATH.
    java_executable = _resolve_mvn_runtime_java() or "java"

    pre_setup = [
        (
            "mvn -q -DskipTests package",
            ["mvn", "-q", "-DskipTests", "package"],
        ),
    ]

    # Spring Initializr names the JAR `<artifact>-<version>.jar`. We
    # let the JVM autodetect the file via a glob shell expansion in
    # the binary name — the wrapper-shared scripts do the same in
    # `./run prod`. Using `bash -c` keeps the glob in the spawned
    # shell, not the Python harness. The `java` binary is the one
    # mvn used to compile (so class file version matches runtime
    # bytecode level).
    spec = BackendSpec(
        skeleton=BACKEND_SKEL,
        service_name=BACKEND_SERVICE_NAME,
        server_argv_template=[
            "bash",
            "-c",
            f"exec '{java_executable}' -jar target/*.jar",
        ],
        pre_server_setup=pre_setup,
        # The Spring Boot binary reads `server.port` from the
        # `SERVICE_PORT` env var (configured in `application.properties`
        # as `${SERVICE_PORT:8080}`). We override it to the test port
        # so the backend binds to whatever URL the React build baked.
        # `SPRING_DATASOURCE_URL` is overridden to an in-memory H2
        # database so the test does not depend on the wrapper-shared
        # SQLite file (which the wrapper writes as `jdbc:sqlite:_shared/...`
        # and would otherwise be resolved relative to the service dir).
        extra_env={
            "SERVICE_HOST": "127.0.0.1",
            "SERVICE_PORT": str(args.port),
            "SPRING_DATASOURCE_URL": "jdbc:h2:mem:reactspring;DB_CLOSE_DELAY=-1",
            "SPRING_DATASOURCE_USERNAME": "sa",
            "SPRING_DATASOURCE_PASSWORD": "",
        },
    )

    return run_react_backend_integration(
        project_name=PROJECT_NAME,
        title="React + Spring Boot integration test",
        spec=spec,
        repo_root=repo_root,
        port=args.port,
        server_startup_timeout=args.server_startup_timeout,
        keep=args.keep,
        no_skip=args.no_skip,
    )


if __name__ == "__main__":
    sys.exit(main())
