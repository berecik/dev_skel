#!/usr/bin/env bash
# Update ${DEV_DIR} with changes from ${SKEL_DIR}

set -euo pipefail

# Resolve SKEL_DIR and source common config from there
SKEL_DIR="${SKEL_DIR:=$HOME/dev_skel}"
# shellcheck source=/dev/null
. "${SKEL_DIR}/_bin/common.sh"

echo "Updating ${DEV_DIR} from dev_skel..."

if [[ ! -d "${DEV_DIR}" ]]; then
  echo "Error: ${DEV_DIR} does not exist."
  echo "Run install-dev-skel first to set up the dev directory."
  exit 1
fi

# Update-specific excludes: do not overwrite top-level README.md in target
UPDATE_EXCLUDES_FILE="${UPDATE_EXCLUDES_FILE:-${SKEL_DIR}/_bin/rsync-update-excludes.txt}"

rsync -av --progress \
  --exclude-from "${EXCLUDES_FILE}" \
  --exclude-from "${UPDATE_EXCLUDES_FILE}" \
  "${SKEL_DIR}/" "${DEV_DIR}/"

echo "Update complete!"
echo "${DEV_DIR} has been synchronized with dev_skel"
