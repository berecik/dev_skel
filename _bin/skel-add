#!/usr/bin/env python3
"""skel-add — add a service to an existing wrapper project.

`_bin/skel-add` mirrors `_bin/skel-gen`, but it targets an *existing*
wrapper project instead of creating a fresh one:

* **AI mode** (default) — dispatches to `_bin/skel-gen-ai --skip-base`
  so the existing wrapper stays intact while the new service goes
  through the usual generation, integration, test-fix, and docs phases.
* **Static mode** — dispatches to `_bin/skel-gen-static --existing-project`
  to add a deterministic non-AI baseline service into the wrapper.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent

remaining = list(sys.argv[1:])
if "--static" in remaining:
    remaining.remove("--static")
    target = SCRIPT_DIR / "skel-gen-static"
    remaining = ["--existing-project"] + remaining
else:
    target = SCRIPT_DIR / "skel-gen-ai"
    remaining = ["--skip-base"] + remaining

if not target.is_file():
    sys.exit(
        f"skel-add: target dispatcher not found at {target}.\n"
        "Re-run `_bin/skel-install` to refresh the local copy."
    )

os.execv(str(target), [str(target)] + remaining)
