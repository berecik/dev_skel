#!/usr/bin/env python3
"""Generate a new project from a skeleton (relocatable)."""

import argparse
from pathlib import Path

from dev_skel_lib import detect_root, generate_project, load_config, render_agents_template


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Generate a new project from a skeleton",
    )
    parser.add_argument("skel_type", help="Name of the skeleton under _skels (e.g. python-fastapi-skel)")
    parser.add_argument("proj_name", help="Leaf directory name to create in the current working directory")
    parser.add_argument(
        "service_in_proj_name",
        nargs="?",
        help="Optional inner service directory name (skeleton-specific)",
    )
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    script_dir = Path(__file__).resolve().parent
    cfg = load_config()
    root = detect_root(script_dir, cfg.skel_dir)
    target = Path.cwd() / args.proj_name

    service_subdir = generate_project(
        root=root,
        skel_name=args.skel_type,
        proj_name=args.proj_name,
        service_override=args.service_in_proj_name,
    )
    render_agents_template(
        target=target,
        service_subdir=service_subdir,
        skeleton_name=args.skel_type,
        project_name=args.proj_name,
    )
    print(f"Generating from skeleton '{args.skel_type}' into: {target} (service: {service_subdir})")
    print("Done.")


if __name__ == "__main__":
    main()
