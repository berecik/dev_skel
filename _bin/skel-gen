#!/usr/bin/env python3
"""skel-gen — canonical project generator (AI by default).

As of 2026-04 ``_bin/skel-gen`` is a thin dispatcher that routes to:

* **AI mode** (default) — Ollama-backed full-stack generation via
  ``_bin/skel-gen-ai``. The new default is the six-step interactive
  dialog that asks for a backend, an optional frontend, the canonical
  item entity, an auth style, and three custom freeform prompts (one
  each for the backend, frontend, and integration phases). Backends
  that ship the wrapper-shared ``/api/items`` contract give the React
  frontend a working items round-trip out of the box.

* **Static mode** — explicit no-AI fallback via
  ``_bin/skel-gen-static``. Use this when you don't have Ollama running
  or want a deterministic AI-free baseline. Trigger it from
  ``skel-gen`` by passing ``--static`` as the first argument, or call
  ``_bin/skel-gen-static`` directly.

Why dispatch via ``os.execv`` instead of importing? The two underlying
scripts have different positional argument layouts and CLI semantics —
the static path takes ``[proj_name] [skel_name] [service_name]``, the
AI path takes the same plus a ``full-stack mode`` argument group with
``--backend`` / ``--frontend`` / ``--backend-extra`` / etc. Replacing
the current process with the chosen target lets each script parse its
own argv cleanly without us having to bridge the two.

Usage examples
--------------

Default (AI, full-stack dialog)::

    _bin/skel-gen                                  # cwd as wrapper
    _bin/skel-gen myproj                           # fresh wrapper directory
    _bin/skel-gen myproj --backend python-django-bolt-skel \\
                         --frontend ts-react-skel \\
                         --item-name ticket --auth-type jwt --no-input

Static fallback (no Ollama needed)::

    _bin/skel-gen --static . python-fastapi-skel "Auth API"
    _bin/skel-gen-static . python-fastapi-skel "Auth API"   # equivalent

Backwards compatibility:

* The previous ``_bin/skel-gen`` was the single-skel STATIC generator.
  That binary lives at ``_bin/skel-gen-static`` now — use it directly
  or pass ``--static``.
* ``_bin/skel-gen-ai`` still exists and behaves exactly as before;
  ``skel-gen`` (the new default) just exec's it with the same argv.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent

# Detect the explicit static-mode opt-out. We accept ``--static`` in any
# position so users do not have to remember it must be the first arg.
# The flag is consumed before the dispatch, so the underlying script
# never sees it.
remaining = list(sys.argv[1:])
if "--static" in remaining:
    remaining.remove("--static")
    target = SCRIPT_DIR / "skel-gen-static"
else:
    target = SCRIPT_DIR / "skel-gen-ai"

if not target.is_file():
    sys.exit(
        f"skel-gen: target dispatcher not found at {target}.\n"
        "Re-run `_bin/skel-install` to refresh the local copy."
    )

# Replace the current process with the chosen target. argv[0] becomes
# the basename of the target so its --help / error messages render the
# right name.
os.execv(str(target), [str(target)] + remaining)
