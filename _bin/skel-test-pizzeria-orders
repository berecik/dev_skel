def generate_static_project(
    repo_root: Path,
    wrapper: Path,
    port: int,
    with_frontend: bool = True,
) -> Tuple[str, Optional[str]]:
    """Generate the project with skel-gen-static (fast, no Ollama needed).

    The skeleton's built-in catalog+orders endpoints are enough for the
    pizzeria-style test. Returns ``(backend_slug, frontend_slug)``.
    """
    if wrapper.exists():
        print(f"  cleaning previous {wrapper}")
        shutil.rmtree(wrapper)
    wrapper.parent.mkdir(parents=True, exist_ok=True)

    backend_url = f"http://127.0.0.1:{port}"

    cmd = [
        sys.executable,
        str(repo_root / "_bin" / "skel-gen-static"),
        wrapper.name,
        BACKEND_SKEL,
        BACKEND_SERVICE_NAME,
    ]
    if with_frontend:
        cmd.extend([
            "--frontend", REACT_SKEL,
            "--frontend-service-name", REACT_SERVICE_NAME,
        ])

    env = os.environ.copy()
    env["SKEL_BACKEND_URL"] = backend_url
    env["PYTHONUNBUFFERED"] = "1"

    print(f"  running skel-gen-static...")
    started = time.monotonic()
    result = subprocess.run(
        cmd,
        env=env,
        cwd=wrapper.parent,
        capture_output=True,
        text=True,
        timeout=300,
    )
    elapsed = time.monotonic() - started

    if result.returncode != 0:
        print(f"  \u2717 skel-gen-static failed (exit {result.returncode}) after {elapsed:.0f}s")
        tail = (result.stdout + "\n" + result.stderr).strip()[-3000:]
        print(tail)
        raise RuntimeError("skel-gen-static failed")

    print(f"  \u2713 skel-gen-static completed in {elapsed:.0f}s")

    backend_slug = _find_service_slug(wrapper, BACKEND_SERVICE_NAME)
    print(f"  backend slug:  {backend_slug}")

    frontend_slug: Optional[str] = None
    if with_frontend:
        frontend_slug = _find_service_slug(wrapper, REACT_SERVICE_NAME)
        print(f"  frontend slug: {frontend_slug}")
    return backend_slug, frontend_slug


