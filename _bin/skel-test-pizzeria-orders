def _ollama_base_url() -> str:
    """Resolve the Ollama base URL from environment (same logic as skel_ai_lib).

    Accepts a bare hostname in ``OLLAMA_HOST`` (port defaults to 11434),
    a ``host:port`` pair, or a full URL.
    """
    base = os.environ.get("OLLAMA_BASE_URL", "")
    if base:
        return base.rstrip("/")
    host = os.environ.get("OLLAMA_HOST", "localhost:11434")
    if not host.startswith(("http://", "https://")):
        # Bare hostname (e.g. ``OLLAMA_HOST=paul``) — append the
        # default Ollama port so the resolver doesn't fall through to
        # port 80.
        if ":" not in host:
            host = f"{host}:11434"
        host = f"http://{host}"
    return host.rstrip("/")


def ollama_reachable() -> bool:
    """Return True if Ollama responds to /api/tags."""
    url = f"{_ollama_base_url()}/api/tags"
    try:
        status, _ = http_request("GET", url, timeout=5)
        return status == 200
    except Exception:
        return False


def _find_service_slug(wrapper: Path, service_name: str) -> str:
    """Find the service directory slug inside a wrapper.

    Scans .skel_context.json files; falls back to a slugified name guess.
    """
    for child in sorted(wrapper.iterdir()):
        if not child.is_dir() or child.name.startswith((".", "_")):
            continue
        ctx = child / ".skel_context.json"
        if ctx.is_file():
            try:
                data = json.loads(ctx.read_text(encoding="utf-8"))
                if data.get("service_name") == service_name:
                    return child.name
            except (json.JSONDecodeError, OSError):
                pass
    # Fallback: slugify
    slug = service_name.lower().replace(" ", "_")
    if (wrapper / slug).is_dir():
        return slug
    raise RuntimeError(
        f"Could not find service directory for '{service_name}' in {wrapper}"
    )


