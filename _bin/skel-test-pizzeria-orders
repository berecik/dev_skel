#  Main orchestrator
# ---------------------------------------------------------------------------


def _run_frontend_tests(
    frontend_dir: Path, slug: str, kind: str,
) -> bool:
    """Run tests for a frontend service. Returns True if passed."""
    if kind == "flutter":
        test_dir = frontend_dir / "test"
        if not test_dir.is_dir():
            print(f"  \u00b7 no test/ directory in {slug}/, skipping")
            return True
        # Drop Item-specific widget tests shipped with the skel — they
        # import ItemForm / ItemsController from
        # lib/screens/item_form.dart / lib/controllers/items_controller.dart,
        # but the AI rewrites those modules around the user's
        # {item_class} (e.g. Order, Pizza, Ticket). The stale imports
        # would break `flutter test` even though the rewritten widget
        # code itself is fine. The cross-stack + widget_test smoke
        # tests still cover the rewritten layer.
        for stale in ("item_form_test.dart", "items_controller_test.dart"):
            stale_path = test_dir / stale
            if stale_path.is_file():
                stale_path.unlink()
                print(f"  \u00b7 removed stale skel test: test/{stale}")
        print(f"  running flutter test in {slug}/...")
        result = subprocess.run(
            ["flutter", "test"],
            cwd=frontend_dir,
            capture_output=True,
            text=True,
            timeout=600,
        )
    elif kind == "react":
        print(f"  running npm test in {slug}/...")
        result = subprocess.run(
            ["npm", "test"],
            cwd=frontend_dir,
            capture_output=True,
            text=True,
            timeout=600,
            env={**os.environ, "CI": "true"},
        )
    else:
        print(f"  \u00b7 unknown frontend kind '{kind}', skipping")
        return True

    if result.returncode != 0:
        print(f"  \u2717 {kind} tests failed (exit {result.returncode})")
        tail = (result.stdout + "\n" + result.stderr).strip()[-2000:]
        print(tail)
        print("  (continuing)")
        return False
    print(f"  \u2713 {kind} tests passed")
    return True


def _start_backend(
    backend_dir: Path, wrapper: Path, port: int, backend_url: str,
) -> Tuple[subprocess.Popen, "IO", Path]:
    """Start the backend server. Returns (proc, log_fp, log_path)."""
    server_log = backend_dir / "test-server.log"
    log_fp = open(server_log, "wb")  # noqa: SIM115

    server_env = os.environ.copy()
    server_env["BACKEND_URL"] = backend_url
    wrapper_env_file = wrapper / ".env"
    if wrapper_env_file.is_file():
        for line in wrapper_env_file.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if "=" in line:
                key, _, val = line.partition("=")
                server_env.setdefault(key.strip(), val.strip())

    proc = subprocess.Popen(
        [
            ".venv/bin/python",
            "-m",
            "uvicorn",
            "app:get_app",
            "--factory",
            "--host",
            "127.0.0.1",
            "--port",
            str(port),
            "--log-level",
            "warning",
        ],
        cwd=backend_dir,
        stdout=log_fp,
        stderr=subprocess.STDOUT,
        env=server_env,
    )
    return proc, log_fp, server_log


def main() -> int:
    args = parse_args()

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)
    wrapper = repo_root / "_test_projects" / PROJECT_NAME
    port = args.port
    backend_url = f"http://127.0.0.1:{port}"

    print()
    print("=== Pizzeria AI Generation + Integration Test ===")
    print(f"  backend:  {BACKEND_SKEL}")
    print(f"  react:    {REACT_SKEL}")
    print(f"  flutter:  {FLUTTER_SKEL}")
    print(f"  wrapper:  {wrapper}")
    print(f"  port:     {port}")
    print()

    # Phase 0: Toolchain probes
    if not ollama_reachable():
        msg = f"Ollama is not reachable at {_ollama_base_url()}"
        if args.no_skip:
            print(f"  \u2717 {msg}")
            return EXIT_FAIL
        print(f"  \u00b7 skipping ({msg})")
        return EXIT_SETUP

    has_node_sdk = have_node()
    has_flutter_sdk = have_flutter()

    if not has_node_sdk:
        if args.no_skip:
            print("  \u2717 Node.js/npm not installed (required for React)")
            return EXIT_FAIL
        print("  \u00b7 Node.js not found -- React frontend will be skipped")

    if not has_flutter_sdk and not args.skip_flutter_build:
        print("  \u00b7 Flutter not found -- Flutter frontend will be skipped")

    final_exit = EXIT_OK
    server_proc: Optional[subprocess.Popen] = None
    log_fp = None
    server_log: Optional[Path] = None

    try:
        # ---------------------------------------------------------------
        # Phase 1: Generate backend + React frontend
        # ---------------------------------------------------------------
        include_react = has_node_sdk
        print()
        print(f"Phase 1: AI generation (react={'yes' if include_react else 'no'})...")
        backend_slug, react_slug = generate_pizzeria_project(
            repo_root, wrapper, port,
            with_react=include_react,
        )

        backend_dir = wrapper / backend_slug
        react_dir = (wrapper / react_slug) if react_slug else None

        # ---------------------------------------------------------------
        # Phase 2: Run backend + React tests
        # ---------------------------------------------------------------
        print()
        print("Phase 2: Running generated service tests...")

        # 2a: Backend tests
        venv_pytest = backend_dir / ".venv" / "bin" / "pytest"
        if venv_pytest.is_file():
            print(f"  running pytest in {backend_slug}/...")
            result = subprocess.run(
                [str(venv_pytest), "tests/", "-x", "-q"],
                cwd=backend_dir,
                capture_output=True,
                text=True,
                timeout=600,
            )
            if result.returncode != 0:
                print(f"  \u2717 backend tests failed (exit {result.returncode})")
                tail = (result.stdout + "\n" + result.stderr).strip()[-2000:]
                print(tail)
                print("  (continuing to HTTP exercise)")
            else:
                print("  \u2713 backend tests passed")
        else:
            print(f"  \u00b7 no pytest found in {backend_slug}/, skipping")

        # 2b: React tests
        if react_dir is not None and has_node_sdk:
            _run_frontend_tests(react_dir, react_slug, "react")

        # ---------------------------------------------------------------
        # Phase 3: Start backend, run 14-step HTTP exercise
        # ---------------------------------------------------------------
        print()
        print("Phase 3: HTTP integration exercise (backend + React)...")
        print(f"  starting {BACKEND_SKEL} on 127.0.0.1:{port}...")

        server_proc, log_fp, server_log = _start_backend(
            backend_dir, wrapper, port, backend_url,
        )

        if not wait_for_server(
            f"{backend_url}/docs",
            timeout_s=args.server_startup_timeout,
        ):
            print("  \u2717 server did not become ready in time")
            print()
            print("  ----- server log (last 4000 chars) -----")
            try:
                print(server_log.read_text(encoding="utf-8")[-4000:])
            except OSError:
                pass
            return EXIT_FAIL
        print("  \u2713 server is up")

        exercise_pizzeria_api(backend_url)

        # ---------------------------------------------------------------
        # Phase 4: Add Flutter frontend to the same wrapper
        # ---------------------------------------------------------------
        if has_flutter_sdk and not args.skip_flutter_build:
            # Stop the server before adding Flutter — common-wrapper.sh
            # may regenerate the shared DB during skel-gen-ai.
            if server_proc is not None and server_proc.poll() is None:
                server_proc.terminate()
                try:
                    server_proc.wait(timeout=10)
                except subprocess.TimeoutExpired:
                    server_proc.kill()
                    server_proc.wait(timeout=5)
            if log_fp is not None:
                log_fp.close()
                log_fp = None

            print()
            print("Phase 4: Adding Flutter frontend to wrapper...")
            flutter_slug = add_flutter_frontend(repo_root, wrapper)
            flutter_dir = wrapper / flutter_slug

            # Phase 5: Run Flutter tests
            print()
            print("Phase 5: Running Flutter tests...")
            _run_frontend_tests(flutter_dir, flutter_slug, "flutter")

            # Phase 6: Restart server and re-run 14-step HTTP exercise
            print()
            print("Phase 6: HTTP integration exercise (final, both frontends)...")
            print(f"  restarting backend on 127.0.0.1:{port}...")

            server_proc, log_fp, server_log = _start_backend(
                backend_dir, wrapper, port, backend_url,
            )
            if not wait_for_server(
                f"{backend_url}/docs",
                timeout_s=args.server_startup_timeout,
            ):
                print("  \u2717 server did not restart in time")
                return EXIT_FAIL
            print("  \u2713 server is up")

            exercise_pizzeria_api(backend_url)
        else:
            print()
            print("  \u00b7 Skipping Flutter phases (SDK not available)")

        print()
        print("=== ALL CHECKS PASSED ===")

    except AssertionError as exc:
        print()
        print(f"  \u2717 assertion failed: {exc}")
        if server_log and server_log.is_file():
            print()
            print("  ----- server log (last 4000 chars) -----")
            try:
                print(server_log.read_text(encoding="utf-8")[-4000:])
            except OSError:
                pass
        final_exit = EXIT_FAIL
    except subprocess.TimeoutExpired as exc:
        print()
        print(f"  \u2717 timeout: {exc}")
        final_exit = EXIT_FAIL
    except RuntimeError as exc:
        print()
        print(f"  \u2717 {exc}")
        final_exit = EXIT_FAIL
    except Exception as exc:  # noqa: BLE001
        print()
        print(f"  \u2717 unexpected error: {exc!r}")
        final_exit = EXIT_FAIL
    finally:
        # Stop the server
        if server_proc is not None and server_proc.poll() is None:
            print()
            print(f"Stopping server (pid {server_proc.pid})...")
            try:
                server_proc.terminate()
                try:
                    server_proc.wait(timeout=10)
                except subprocess.TimeoutExpired:
                    print("  (SIGTERM timed out, sending SIGKILL)")
                    server_proc.kill()
                    try:
                        server_proc.wait(timeout=5)
                    except subprocess.TimeoutExpired:
                        pass
            except OSError:
                pass

        if log_fp is not None:
            try:
                log_fp.close()
            except OSError:
                pass

        if args.keep:
            print()
            print(f"  --keep: wrapper left at {wrapper}")
        elif wrapper.exists():
            print(f"  cleaning {wrapper}")
            shutil.rmtree(wrapper, ignore_errors=True)

    return final_exit


if __name__ == "__main__":
    sys.exit(main())
