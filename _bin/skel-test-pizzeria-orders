def generate_pizzeria_project(
    repo_root: Path,
    wrapper: Path,
    port: int,
    with_react: bool = True,
) -> Tuple[str, Optional[str]]:
    """Call skel-gen-ai to generate the pizzeria wrapper with React frontend.

    Returns ``(backend_slug, react_slug)``.  ``react_slug`` is
    ``None`` when *with_react* is ``False``.
    """
    if wrapper.exists():
        print(f"  cleaning previous {wrapper}")
        shutil.rmtree(wrapper)
    wrapper.parent.mkdir(parents=True, exist_ok=True)

    backend_url = f"http://127.0.0.1:{port}"

    cmd = [
        sys.executable,
        str(repo_root / "_bin" / "skel-gen-ai"),
        wrapper.name,
        "--backend", BACKEND_SKEL,
        "--backend-service-name", BACKEND_SERVICE_NAME,
        "--item-name", ITEM_CLASS,
        "--auth-type", AUTH_TYPE,
        "--backend-extra", BACKEND_EXTRA,
        "--frontend-extra", FRONTEND_EXTRA,
        "--integration-extra", INTEGRATION_EXTRA,
        "--testing-scenario", TESTING_SCENARIO,
        "--no-input",
    ]
    if with_react:
        cmd.extend(["--frontend", REACT_SKEL])
        cmd.extend(["--frontend-service-name", REACT_SERVICE_NAME])
    else:
        cmd.append("--no-frontend")

    env = os.environ.copy()
    env["SKEL_BACKEND_URL"] = backend_url
    env["PYTHONUNBUFFERED"] = "1"

    print(f"  running skel-gen-ai (this may take 10-30 minutes)...")
    print(f"  SKEL_BACKEND_URL={backend_url}")
    started = time.monotonic()
    result = subprocess.run(
        cmd,
        env=env,
        cwd=wrapper.parent,
        stdout=None if env.get("SKEL_AI_VERBOSE") else subprocess.PIPE,
        stderr=subprocess.STDOUT if not env.get("SKEL_AI_VERBOSE") else None,
        text=True,
    )
    elapsed = time.monotonic() - started

    if result.returncode != 0:
        print(
            f"  \u2717 skel-gen-ai failed "
            f"(exit {result.returncode}) after {elapsed:.0f}s"
        )
        tail = (result.stdout or "") + "\n" + (result.stderr or "")
        print(tail.strip()[-3000:])
        raise RuntimeError("skel-gen-ai failed")

    print(f"  \u2713 skel-gen-ai completed in {elapsed:.0f}s")

    backend_slug = _find_service_slug(wrapper, BACKEND_SERVICE_NAME)
    print(f"  backend slug:  {backend_slug}")

    react_slug: Optional[str] = None
    if with_react:
        react_slug = _find_service_slug(wrapper, REACT_SERVICE_NAME)
        print(f"  react slug:    {react_slug}")
    return backend_slug, react_slug


def add_flutter_frontend(
    repo_root: Path,
    wrapper: Path,
) -> str:
    """Add Flutter frontend to an existing wrapper via skel-gen-ai.

    Always uses the AI overlay so the playbook validates the FULL
    AI-generation pipeline end-to-end. When ``item_class`` collides
    with the bundled flutter-skel's pre-shipped rich classes (Order /
    OrderDetail / OrderLine / OrderAddress), the manifest's dynamic
    template paths point the AI at the EXISTING rich bundled file as
    the reference and instruct it to preserve the rich shape while
    applying the user's frontend instructions.

    Returns the Flutter service slug.
    """
    cmd = [
        sys.executable,
        str(repo_root / "_bin" / "skel-gen-ai"),
        wrapper.name,
        FLUTTER_SKEL,
        FLUTTER_SERVICE_NAME,
        "--item-name", ITEM_CLASS,
        "--auth-type", AUTH_TYPE,
        "--frontend-extra", FRONTEND_EXTRA,
        "--no-input",
        "--no-integrate",
        "--no-docs",
        "--no-kube",
    ]
    env = os.environ.copy()
    env["PYTHONUNBUFFERED"] = "1"

    print(f"  running skel-gen-ai {FLUTTER_SKEL} (add to existing wrapper)...")
    started = time.monotonic()
    result = subprocess.run(
        cmd,
        env=env,
        cwd=wrapper.parent,
        stdout=None if env.get("SKEL_AI_VERBOSE") else subprocess.PIPE,
        stderr=subprocess.STDOUT if not env.get("SKEL_AI_VERBOSE") else None,
        text=True,
    )
    elapsed = time.monotonic() - started

    if result.returncode != 0:
        print(
            f"  \u2717 skel-gen-ai flutter failed "
            f"(exit {result.returncode}) after {elapsed:.0f}s"
        )
        tail = (result.stdout or "") + "\n" + (result.stderr or "")
        print(tail.strip()[-3000:])
        raise RuntimeError("skel-gen-ai flutter failed")

    print(f"  \u2713 flutter frontend added in {elapsed:.0f}s")

    flutter_slug = _find_service_slug(wrapper, FLUTTER_SERVICE_NAME)
    print(f"  flutter slug:  {flutter_slug}")
    return flutter_slug


