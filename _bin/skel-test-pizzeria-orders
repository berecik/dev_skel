def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "AI-generation integration test: generates a FastAPI + React "
            "pizzeria ordering app via skel-gen-ai, then adds a Flutter "
            "frontend via skel-add. Both frontends are exercised against "
            "the live backend via the 14-step HTTP order lifecycle."
        ),
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help="Leave the generated wrapper on disk after the test finishes.",
    )
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help=f"TCP port for the FastAPI backend (default: {DEFAULT_PORT}).",
    )
    parser.add_argument(
        "--server-startup-timeout",
        type=int,
        default=DEFAULT_STARTUP_TIMEOUT,
        help=(
            "Seconds to wait for the backend to become reachable "
            f"(default: {DEFAULT_STARTUP_TIMEOUT})."
        ),
    )
    parser.add_argument(
        "--no-skip",
        action="store_true",
        help="Treat missing toolchain as hard failure instead of skip.",
    )
    parser.add_argument(
        "--skip-flutter-build",
        action="store_true",
        help=(
            "Skip adding and testing the Flutter frontend (useful when "
            "iterating on backend + React only)."
        ),
    )
    parser.add_argument(
        "--static",
        action="store_true",
        help=(
            "Use skel-gen-static instead of skel-gen-ai. The skeleton "
            "now ships catalog+orders endpoints natively, so the static "
            "generator produces a working project without AI."
        ),
    )
    return parser.parse_args()


