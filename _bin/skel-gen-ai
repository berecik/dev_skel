def _run_kube_phase_with_fallback(*, client, wrapper_dir, args) -> None:
    """Run Phase 5 (Kubernetes lifecycle) and report outcome.

    Never raises — any exception is logged so the user still sees the
    happy-path summary for the services themselves. On failure the
    service code is left on disk; the user can resume with
    ``./project kube bootstrap`` or ``./project kube sync --e2e``.
    """
    print()
    print("  ===== Kubernetes lifecycle (Phase 5) =====")
    try:
        result = run_kubernetes_phase(
            client=client,
            wrapper_dir=wrapper_dir,
            project_yml=None,
            fix_timeout_m=getattr(args, "kube_fix_timeout", 30),
            keep_kind=getattr(args, "keep_kube", False),
            skip_kind=False,
            skip_ai=False,
        )
    except Exception as exc:  # noqa: BLE001 — keep the summary reachable
        print(f"  Kubernetes phase raised: {exc!r}")
        print(
            "  (service code unaffected; re-run with "
            "`./project kube bootstrap` once the issue is resolved)"
        )
        return

    if result.ok:
        print(
            f"  Kubernetes phase OK "
            f"({len(result.generated_files)} Tier-2 files, "
            f"fix_iterations={result.fix_iterations})"
        )
    else:
        print(f"  Kubernetes phase FAILED: {result.error}")
        if result.generated_files:
            print(
                f"  ({len(result.generated_files)} Tier-2 files were written; "
                "re-run with `./project kube sync --e2e` after fixing the "
                "issue above)"
            )


