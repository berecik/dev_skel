def _is_cwd_proj(name: str | None) -> bool:
    """Whether the user-supplied ``proj_name`` means "use the cwd"."""

    return name is None or name in ("", ".")


def _guard_swapped_args(proj_name: str | None, skels_dir: Path) -> None:
    """Catch the common mistake of passing the skel name in the proj slot.

    Mirrors the same guard in ``_bin/skel-gen``: when ``proj_name`` looks
    like an existing ``*-skel`` directory we bail with an actionable
    error rather than silently creating a wrapper named after the
    skeleton.
    """

    if not proj_name or proj_name == ".":
        return
    if not proj_name.endswith("-skel"):
        return
    if not (skels_dir / proj_name).is_dir():
        return
    raise SystemExit(
        f"Looks like '{proj_name}' is a skeleton name, not a project name.\n"
        "The positional order is now:\n"
        "  _bin/skel-gen-ai [proj_name] [skel_name] [service_name]\n\n"
        "Try one of:\n"
        f"  _bin/skel-gen-ai . {proj_name}              # install into the current directory\n"
        f"  _bin/skel-gen-ai myproj {proj_name}         # create ./myproj/ from the skeleton\n"
        f"  _bin/skel-gen-ai myproj {proj_name} 'My API' # also pick a service display name"
    )


def main() -> None:
    args = parse_args()

    # Propagate verbosity to every child AI invocation (./ai from
    # generated services, Kubernetes phase, fix loop) via the same
    # env var the per-service runtime honors. Never shrink an outer
    # setting: if the operator already set SKEL_AI_VERBOSE=2 and then
    # runs with -v (1), keep the 2.
    if args.verbose:
        prior = os.environ.get("SKEL_AI_VERBOSE", "").strip()
        try:
            prior_n = int(prior) if prior.isdigit() else 0
        except ValueError:
            prior_n = 0
        os.environ["SKEL_AI_VERBOSE"] = str(max(prior_n, args.verbose))

    cfg: DevSkelConfig = load_config()
    script_dir = Path(__file__).resolve().parent
    repo_root = detect_root(script_dir, cfg.skel_dir)

    skels_dir = repo_root / "_skels"
    require_dir(skels_dir, f"No _skels directory found at: {skels_dir}")

    _guard_swapped_args(args.proj_name, skels_dir)

    # Project name: default to '.' (cwd). On a TTY, ask once with the
    # cwd as the default so the user can override it; with --no-input or
    # without a TTY we silently fall through to '.'.
    if _is_cwd_proj(args.proj_name):
        cwd_default = Path.cwd().name
        if args.no_input:
            args.proj_name = "."
        else:
            answer = prompt_text(
                f"Project name (wrapper directory) [.={cwd_default}]",
                default=".",
                no_input=args.no_input,
            )
            args.proj_name = answer or "."

    if _is_cwd_proj(args.proj_name):
        target = Path.cwd().resolve()
        display_proj_name = target.name
        gen_proj_arg = "."
    else:
        target = (Path.cwd() / args.proj_name).resolve()
        display_proj_name = args.proj_name
        gen_proj_arg = args.proj_name

    # ----- Mode dispatch ----------------------------------------------- #
    #
    # When the user provides an explicit positional `skel_name` (or a
    # custom --manifest path), run the legacy single-skeleton flow that
    # rewrites just that one skel. Without it, run the new full-stack
    # dialog that asks for backend + frontend separately and integrates
    # them together. Both modes share the rest of the helper machinery
    # (Ollama config, sibling discovery, integration phase, test-fix
    # loop) — only the entry-point differs.

    if args.skel_name or args.manifest:
        return _run_single_skel_flow(
            args=args,
            repo_root=repo_root,
            skels_dir=skels_dir,
            target=target,
            display_proj_name=display_proj_name,
            gen_proj_arg=gen_proj_arg,
        )

    return _run_fullstack_flow(
        args=args,
        repo_root=repo_root,
        skels_dir=skels_dir,
        target=target,
        display_proj_name=display_proj_name,
        gen_proj_arg=gen_proj_arg,
    )


def _run_single_skel_flow(
    *,
    args: argparse.Namespace,
    repo_root: Path,
    skels_dir: Path,
    target: Path,
    display_proj_name: str,
    gen_proj_arg: str,
) -> None:
    """Legacy single-skeleton flow.

    Triggered when the user passes an explicit positional ``skel_name``
    (or a ``--manifest`` path). Runs the per-target manifest, then the
    optional integration phase + test-and-fix loop. Same behavior as
    pre-2026-04 ``skel-gen-ai`` invocations — kept for scripted users.
    """

    skel_path = skels_dir / args.skel_name
    require_dir(
        skel_path,
        f"Error: skeleton not found: {args.skel_name} (expected at {skel_path})",
    )

    # ----- 1. Collect user input FIRST so the slug drives the dirname -- #

    cli_service_name = args.service_name or args.service_name_pos

    answers = prompt_user_dialog(
        skeleton_name=args.skel_name,
        default_project_name=display_proj_name,
        default_service_subdir=slugify_service_name(cli_service_name)
        if cli_service_name
        else default_service_base(args.skel_name),
        service_label=cli_service_name,
        item_name=args.item_name,
        auth_type=args.auth_type,
        auth_details=args.auth_details,
        no_input=args.no_input,
    )

    chosen_service_label: str = answers["service_label"]

    # ----- 2. Generate (or locate) the project ------------------------- #

    if args.skip_base:
        if not target.is_dir():
            raise SystemExit(
                f"--skip-base requires the project directory to exist already: {target}"
            )
        service_subdir = _resolve_service_subdir(
            target=target,
            skel_name=args.skel_name,
            service_name=chosen_service_label,
            skip_base=True,
        )
    else:
        service_subdir = generate_project(
            root=repo_root,
            skel_name=args.skel_name,
            proj_name=gen_proj_arg,
            service_name=chosen_service_label,
        )
        render_agents_template(
            target=target,
            service_subdir=service_subdir,
            skeleton_name=args.skel_name,
            project_name=display_proj_name,
        )

    inner_dir = target / service_subdir
    if not inner_dir.is_dir():
        raise SystemExit(
            f"Expected service directory '{inner_dir}' was not created. "
            "Aborting before AI overlay."
        )

    # ----- 3. Build the generation context ----------------------------- #

    ctx = GenerationContext(
        skeleton_name=args.skel_name,
        skeleton_path=skel_path,
        project_root=target,
        project_name=display_proj_name,
        service_subdir=service_subdir,
        service_label=chosen_service_label,
        item_name=answers["item_name"],
        auth_type=answers["auth_type"],
        auth_details=answers.get("auth_details", ""),
    )

    # ----- 4. Load manifest -------------------------------------------- #

    if args.manifest:
        manifest_path = Path(args.manifest).expanduser().resolve()
        if not manifest_path.is_file():
            raise SystemExit(f"--manifest path not found: {manifest_path}")
        # Load via the same loader by temporarily importing the module.
        from importlib.util import module_from_spec, spec_from_file_location
        spec = spec_from_file_location("_skel_ai_custom_manifest", manifest_path)
        if spec is None or spec.loader is None:
            raise SystemExit(f"Could not load manifest at {manifest_path}")
        module = module_from_spec(spec)
        spec.loader.exec_module(module)
        raw = getattr(module, "MANIFEST", None)
        if not isinstance(raw, dict):
            raise SystemExit(
                f"Custom manifest at {manifest_path} must define MANIFEST = {{...}}"
            )
        # Reuse the validation in load_manifest by writing a tiny adapter:
        from skel_ai_lib import AiManifest, AiTarget

        manifest = AiManifest(
            skeleton_name=args.skel_name,
            targets=[
                AiTarget(
                    path=str(t["path"]),
                    template=t.get("template"),
                    prompt=str(t["prompt"]),
                    language=str(t.get("language", "python")),
                    description=str(t.get("description", "")),
                )
                for t in raw.get("targets", [])
            ],
            system_prompt=str(raw.get("system_prompt", "")),
            notes=str(raw.get("notes", "")),
        )
    else:
        try:
            manifest = load_manifest(repo_root, args.skel_name)
            manifest_path = (
                repo_root / "_skels" / "_common" / "manifests" / f"{args.skel_name}.py"
            )
        except FileNotFoundError as exc:
            raise SystemExit(str(exc))

    # Optional INTEGRATION_MANIFEST in the same per-skel manifest file.
    # Returns None when the skel does not declare one — that's the silent
    # opt-out path used by the simpler skels.
    integration_manifest = None
    if not args.no_integrate and not args.manifest:
        try:
            integration_manifest = load_integration_manifest(
                repo_root, args.skel_name
            )
        except (FileNotFoundError, ValueError) as exc:
            print(f"  (could not load integration manifest: {exc})")

    _print_summary(ctx, manifest_path)

    if args.dry_run:
        print("  (dry-run) targets that would be generated:")
        for t in manifest.targets:
            expanded = expand_target_paths(t, ctx)
            template = expanded.template or "—"
            print(f"    - {expanded.path}  (template: {template})")
        if integration_manifest and integration_manifest.targets:
            # Sibling discovery happens before the dry-run list so the
            # `{wrapper_snapshot}` placeholder render path matches what
            # the real run would do (and so an empty wrapper produces
            # the friendlier "no siblings" message in the snapshot).
            ctx.siblings = discover_siblings(target, exclude_slug=service_subdir)
            print()
            print(
                f"  (dry-run) integration targets "
                f"({len(integration_manifest.targets)}, siblings discovered: "
                f"{len(ctx.siblings)}):"
            )
            for t in integration_manifest.targets:
                expanded = expand_target_paths(t, ctx)
                template = expanded.template or "—"
                print(
                    f"    + {expanded.path}  (template: {template})"
                )
            print(
                f"  (dry-run) integration test command: "
                f"{integration_manifest.test_command} "
                f"(fix timeout: {integration_manifest.fix_timeout_m}m)"
            )
        elif not args.no_integrate:
            print()
            print("  (dry-run) no INTEGRATION_MANIFEST declared — integration phase will be skipped.")
        print()
        return

    # ----- 5. Verify Ollama and run per-target generation -------------- #

    ollama_cfg = _build_ollama_config(args)
    client = OllamaClient(ollama_cfg)
    try:
        client.verify()
    except OllamaError as exc:
        raise SystemExit(f"Ollama check failed:\n{exc}")

    print(f"  Ollama: {ollama_cfg.model} @ {ollama_cfg.base_url}")
    print(f"  Generating {len(manifest.targets)} files...")
    print()

    try:
        results = generate_targets(
            client=client,
            manifest=manifest,
            ctx=ctx,
            dry_run=False,
            progress=_PROGRESS,
        )
    except OllamaError as exc:
        raise SystemExit(f"\nOllama generation failed:\n{exc}")

    print()
    print("  Files written:")
    for r in results:
        rel = r.written_to.relative_to(target)
        print(f"    + {rel}  ({r.bytes_written} bytes)")

    # ----- 6. Integration phase ---------------------------------------- #
    #
    # Discover sibling services in the wrapper, populate the context,
    # then run the integration manifest. This is a NEW Ollama session
    # whose targets are *additive* (sibling clients, integration tests)
    # rather than replacements for the per-target manifest's outputs.

    integration_results: list = []
    if integration_manifest and integration_manifest.targets:
        ctx.siblings = discover_siblings(target, exclude_slug=service_subdir)
        print()
        print(
            f"  Integration phase: {len(integration_manifest.targets)} target(s), "
            f"{len(ctx.siblings)} sibling service(s) discovered."
        )
        if ctx.siblings:
            for s in ctx.siblings:
                print(f"    · {s.slug} ({s.kind}, {s.tech})")
        print()
        # Broad try/except — see the matching block in
        # `_run_fullstack_flow` for the rationale: integration / test
        # errors are bypassed to Ollama via the test-fix loop, so a
        # crash here would lose the test output the next iteration
        # could feed back to the model.
        try:
            integration_results = run_integration_phase(
                client=client,
                manifest=integration_manifest,
                ctx=ctx,
                dry_run=False,
                progress=_PROGRESS,
            )
        except OllamaError as exc:
            print(f"  Integration phase Ollama error: {exc}")
            print("  (continuing to the test-fix loop with whatever files exist)")
        except Exception as exc:  # noqa: BLE001 — bypass to next phase
            print(f"  Integration phase raised unexpectedly: {exc!r}")
            print("  (continuing to the test-fix loop with whatever files exist)")
        if integration_results:
            print()
            print("  Integration files written:")
            for r in integration_results:
                try:
                    rel = r.written_to.relative_to(target)
                except ValueError:
                    rel = r.written_to
                print(f"    + {rel}  ({r.bytes_written} bytes)")
    elif not args.no_integrate:
        print()
        print(
            f"  (no INTEGRATION_MANIFEST in {args.skel_name}.py — skipping "
            "integration phase)"
        )

    # ----- 7. Test-and-fix loop ---------------------------------------- #

    if (
        integration_manifest
        and integration_results
        and not args.no_test_fix
    ):
        print()
        print("  Running the test-and-fix loop...")
        try:
            final = run_test_and_fix_loop(
                client=client,
                ctx=ctx,
                manifest=integration_manifest,
                integration_results=integration_results,
                progress=_PROGRESS,
            )
        except OllamaError as exc:
            print(f"  Test-and-fix loop Ollama error: {exc}")
            print("  (the inner repair was aborted; the test command output above is what we have)")
            final = None  # type: ignore[assignment]
        except Exception as exc:  # noqa: BLE001 — last-resort safety net
            print(f"  Test-and-fix loop raised unexpectedly: {exc!r}")
            print("  (inspect the generated files and re-run manually)")
            final = None  # type: ignore[assignment]
        else:
            print()
            if final.passed:
                print(
                    f"  Test-and-fix loop: PASS "
                    f"(exit 0 in {final.duration_s:.1f}s)"
                )
            else:
                print(
                    f"  Test-and-fix loop: FAIL "
                    f"(exit {final.returncode} after "
                    f"{integration_manifest.fix_timeout_m}m timeout). "
                    f"Inspect the generated files and re-run manually."
                )

    # ----- 8. Documentation generation ------------------------------------- #
    if client is not None and not args.no_docs:
        print()
        print("  ===== Documentation & LLM instructions =====")
        try:
            docs_written = run_docs_generation(
                client=client,
                project_root=target,
                project_name=display_proj_name,
                service_contexts=[ctx],
                dry_run=False,
                progress=_PROGRESS,
            )
        except Exception as exc:  # noqa: BLE001
            print(f"  Documentation generation error: {exc!r}")
            docs_written = []
        if docs_written:
            print(f"  Generated {len(docs_written)} documentation files.")

    # ----- 9. Kubernetes lifecycle (Phase 4) ------------------------------ #
    if not args.no_kube:
        _run_kube_phase_with_fallback(
            client=client,
            wrapper_dir=target,
            args=args,
        )

    print()
    print("  Done. Review the generated files and run the project's tests.")


