def _resolve_service_subdir(
    *, target: Path, skel_name: str, service_name: str | None, skip_base: bool
) -> str:
    """Pick a service subdir consistent with both modes (full gen / skip-base).

    With ``skip_base=True`` we expect the project to already exist and use
    the slug exactly (no auto-suffix), so re-runs of ``--skip-base`` against
    the same project pick up the directory the user already has on disk.
    """

    if service_name:
        base = slugify_service_name(service_name)
    else:
        base = default_service_base(skel_name)
    if skip_base:
        return base
    return base if not (target / base).exists() else choose_service_subdir(target, base)


def _build_ollama_config(args: argparse.Namespace) -> OllamaConfig:
    cfg = OllamaConfig.from_env()
    if args.ollama_model:
        cfg.model = args.ollama_model
    if args.ollama_url:
        url = args.ollama_url.rstrip("/")
        cfg.base_url = url[:-3] if url.endswith("/v1") else url
    if args.ollama_temperature is not None:
        cfg.temperature = args.ollama_temperature
    return cfg


