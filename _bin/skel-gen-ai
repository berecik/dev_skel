def _generate_per_target_overlay(
    *,
    args: argparse.Namespace,
    repo_root: Path,
    skel_name: str,
    service_label: str,
    target: Path,
    display_proj_name: str,
    gen_proj_arg: str,
    item_name: str,
    auth_type: str,
    backend_extra: str,
    frontend_extra: str,
    integration_extra: str,
    testing_scenario: str,
    client: Optional[OllamaClient],
    skip_base: bool,
    dry_run: bool,
) -> tuple[str, GenerationContext, Optional[Any], Optional[Any]]:
    """Run skel-gen + the per-target manifest overlay for ONE skeleton.

    Returns ``(service_subdir, ctx, integration_manifest, manifest)``.
    The integration phase + test-and-fix loop are NOT run here — the
    full-stack driver runs them once at the end so the integration
    phase sees both services on disk.
    """

    skel_path = repo_root / "_skels" / skel_name
    require_dir(
        skel_path,
        f"Error: skeleton not found: {skel_name} (expected at {skel_path})",
    )

    # Generate (or locate) the project on disk.
    if skip_base:
        if not target.is_dir():
            raise SystemExit(
                f"--skip-base requires the project directory to exist already: {target}"
            )
        service_subdir = _resolve_service_subdir(
            target=target,
            skel_name=skel_name,
            service_name=service_label,
            skip_base=True,
        )
    else:
        service_subdir = generate_project(
            root=repo_root,
            skel_name=skel_name,
            proj_name=gen_proj_arg,
            service_name=service_label,
        )
        render_agents_template(
            target=target,
            service_subdir=service_subdir,
            skeleton_name=skel_name,
            project_name=display_proj_name,
        )

    inner_dir = target / service_subdir
    if not inner_dir.is_dir():
        raise SystemExit(
            f"Expected service directory '{inner_dir}' was not created. "
            "Aborting before AI overlay."
        )

    # Build the generation context with the three custom prompts.
    ctx = GenerationContext(
        skeleton_name=skel_name,
        skeleton_path=skel_path,
        project_root=target,
        project_name=display_proj_name,
        service_subdir=service_subdir,
        service_label=service_label,
        item_name=item_name,
        auth_type=auth_type,
        backend_extra=backend_extra,
        frontend_extra=frontend_extra,
        integration_extra=integration_extra,
        testing_scenario=testing_scenario,
    )

    # Load the per-target manifest.
    try:
        manifest = load_manifest(repo_root, skel_name)
    except FileNotFoundError as exc:
        raise SystemExit(str(exc))

    # Optional integration manifest (loaded but NOT executed here).
    integration_manifest = None
    if not args.no_integrate:
        try:
            integration_manifest = load_integration_manifest(repo_root, skel_name)
        except (FileNotFoundError, ValueError) as exc:
            print(f"  (could not load integration manifest for {skel_name}: {exc})")

    # Print a small per-skel summary.
    print()
    print(f"  ===== {skel_name} =====")
    print(f"  Service dir : {service_subdir}  ({inner_dir})")
    print(f"  Service name: {service_label}")
    print(f"  Item entity : {item_name}  (class: {ctx.item_class})")
    print(f"  Auth style  : {auth_type}")

    if dry_run:
        print(f"  (dry-run) per-target targets ({len(manifest.targets)}):")
        for t in manifest.targets:
            expanded = expand_target_paths(t, ctx)
            tmpl = expanded.template or "—"
            print(f"    - {expanded.path}  (template: {tmpl})")
        return service_subdir, ctx, integration_manifest, manifest

    if client is None:
        return service_subdir, ctx, integration_manifest, manifest

    print(f"  Generating {len(manifest.targets)} files via Ollama...")
    try:
        results = generate_targets(
            client=client,
            manifest=manifest,
            ctx=ctx,
            dry_run=False,
            progress=_PROGRESS,
        )
    except OllamaError as exc:
        raise SystemExit(f"\nOllama generation failed for {skel_name}:\n{exc}")

    print(f"  Files written ({len(results)}):")
    for r in results:
        rel = r.written_to.relative_to(target)
        print(f"    + {rel}  ({r.bytes_written} bytes)")

    return service_subdir, ctx, integration_manifest, manifest


def _print_fullstack_summary(
    choices: FullstackChoices, target: Path
) -> None:
    print()
    print("  ===== full-stack run summary =====")
    print(f"  Project (wrapper) : {choices.project_name}  ({target})")
    if choices.has_backend:
        print(
            f"  Backend           : {choices.backend_skeleton} → "
            f"{choices.backend_service_label}"
        )
    else:
        print("  Backend           : (none — frontend-only)")
    if choices.has_frontend:
        print(
            f"  Frontend          : {choices.frontend_skeleton} → "
            f"{choices.frontend_service_label}"
        )
    else:
        print("  Frontend          : (none — backend-only)")
    print(f"  Item entity       : {choices.item_name}")
    print(f"  Auth style        : {choices.auth_type}")
    if choices.backend_extra:
        print(f"  Backend extra     : {choices.backend_extra}")
    if choices.frontend_extra:
        print(f"  Frontend extra    : {choices.frontend_extra}")
    if choices.integration_extra:
        print(f"  Integration extra : {choices.integration_extra}")
    if choices.testing_scenario:
        print(f"  Testing scenario  : {choices.testing_scenario}")
    if choices.has_frontend:
        if choices.backend_serves_items:
            print(
                "  Items contract    : "
                f"{choices.backend_skeleton} ships /api/items + "
                "/api/auth/login; React src/api/items.ts will hit it directly."
            )
        else:
            print(
                "  Items contract    : "
                f"⚠ {choices.backend_skeleton} does NOT yet ship the "
                "wrapper-shared /api/items layer. The React frontend will "
                "receive 404 until you add a matching backend route."
            )
    print()


def _run_fullstack_flow(
    *,
    args: argparse.Namespace,
    repo_root: Path,
    skels_dir: Path,
    target: Path,
    display_proj_name: str,
    gen_proj_arg: str,
) -> None:
    """New full-stack dialog flow.

    Asks the user (or reads CLI flags) for backend + frontend, then
    generates both into the same wrapper, then runs the backend's
    integration phase + test-and-fix loop with both services visible
    as siblings of each other.
    """

    ai_supported = discover_manifests(repo_root)
    if not ai_supported:
        raise SystemExit(
            f"No AI manifests found under "
            f"{repo_root / '_skels' / '_common' / 'manifests'}.\n"
            "Drop a `<skeleton>.py` file there or use `_bin/skel-gen` "
            "for static-only generation."
        )

    backends, frontends = split_skels_by_kind(ai_supported)

    # `--auth-details` is the legacy alias for `--backend-extra`. If the
    # user passed both, the explicit `--backend-extra` wins; otherwise
    # we mirror the deprecated value through.
    legacy_backend_extra = args.backend_extra or args.auth_details

    choices = prompt_fullstack_dialog(
        available_backends=backends,
        available_frontends=frontends,
        default_project_name=display_proj_name,
        backend_skeleton=args.backend,
        frontend_skeleton=args.frontend,
        backend_service_label=args.backend_service_name or args.service_name,
        frontend_service_label=args.frontend_service_name,
        item_name=args.item_name,
        auth_type=args.auth_type,
        backend_extra=legacy_backend_extra,
        frontend_extra=args.frontend_extra,
        integration_extra=args.integration_extra,
        testing_scenario=args.testing_scenario,
        no_input=args.no_input,
        allow_no_frontend=True,
        skip_frontend=args.no_frontend,
        allow_no_backend=True,
        skip_backend=args.no_backend,
    )

    _print_fullstack_summary(choices, target)

    # ----- Optional Ollama client (skipped on dry-run) ------------------ #
    client: Optional[OllamaClient]
    if args.dry_run:
        client = None
        print("  (dry-run) Ollama not contacted; only structural checks run.")
    else:
        ollama_cfg = _build_ollama_config(args)
        client = OllamaClient(ollama_cfg)
        try:
            client.verify()
        except OllamaError as exc:
            raise SystemExit(f"Ollama check failed:\n{exc}")
        print(f"  Ollama: {ollama_cfg.model} @ {ollama_cfg.base_url}")

    # ----- Phase 1: backend per-target overlay (optional) --------------- #
    backend_subdir: Optional[str] = None
    backend_ctx: Optional[GenerationContext] = None
    backend_integration = None
    if choices.has_backend:
        print()
        print("  ===== Phase 1: Backend generation =====")
        backend_subdir, backend_ctx, backend_integration, _backend_manifest = (
            _generate_per_target_overlay(
                args=args,
                repo_root=repo_root,
                skel_name=choices.backend_skeleton,
                service_label=choices.backend_service_label,
                target=target,
                display_proj_name=display_proj_name,
                gen_proj_arg=gen_proj_arg,
                item_name=choices.item_name,
                auth_type=choices.auth_type,
                backend_extra=choices.backend_extra,
                frontend_extra=choices.frontend_extra,
                integration_extra=choices.integration_extra,
                testing_scenario=choices.testing_scenario,
                client=client,
                skip_base=args.skip_base,
                dry_run=args.dry_run,
            )
        )
    else:
        print()
        print("  ===== Phase 1: Backend skipped (frontend-only project) =====")

    # ----- Phase 2: frontend per-target overlay (optional) -------------- #
    frontend_subdir: Optional[str] = None
    frontend_ctx: Optional[GenerationContext] = None
    if choices.has_frontend:
        print()
        print("  ===== Phase 2: Frontend generation =====")
        frontend_subdir, frontend_ctx, _frontend_int, _frontend_manifest = (
            _generate_per_target_overlay(
                args=args,
                repo_root=repo_root,
                skel_name=choices.frontend_skeleton,
                service_label=choices.frontend_service_label,
                target=target,
                display_proj_name=display_proj_name,
                gen_proj_arg=gen_proj_arg,
                item_name=choices.item_name,
                auth_type=choices.auth_type,
                backend_extra=choices.backend_extra,
                frontend_extra=choices.frontend_extra,
                integration_extra=choices.integration_extra,
                testing_scenario=choices.testing_scenario,
                client=client,
                skip_base=args.skip_base,
                dry_run=args.dry_run,
            )
        )

    # ----- Refresh wrapper dispatch scripts (all services now on disk) -- #
    #
    # Each skel's ``gen`` script already calls ``common-wrapper.sh``, but
    # only with the services it knew about at that point. Now that every
    # service (backend + frontend) is generated, re-run the wrapper
    # scaffolder so the dispatch scripts (``run``, ``test``, ``build``,
    # ``install-deps``, …) are fully aware of all siblings. When the
    # project skipped the backend, we anchor the refresh on the frontend
    # subdir instead (common-wrapper.sh expects *some* service slug to
    # treat as the "just-generated" one for sidecar-overwrite purposes).
    if not args.dry_run:
        common_wrapper = repo_root / "_skels" / "_common" / "common-wrapper.sh"
        if common_wrapper.is_file():
            anchor_subdir = backend_subdir or frontend_subdir
            if anchor_subdir:
                print()
                print(
                    "  Refreshing wrapper dispatch scripts "
                    "(all services visible)..."
                )
                subprocess.run(
                    ["bash", str(common_wrapper), str(target), anchor_subdir],
                    check=False,
                )

    # ----- Phase 3: backend integration (now sees frontend as sibling) - #
    #
    # Integration is a backend-side concern (the manifest lives on the
    # backend skeleton and writes integration files into the backend
    # service). A frontend-only project has nothing to integrate.
    integration_results: list = []
    if (
        choices.has_backend
        and backend_integration
        and backend_integration.targets
        and not args.no_integrate
    ):
        if args.dry_run:
            backend_ctx.siblings = discover_siblings(target, exclude_slug=backend_subdir)
            print()
            print(
                f"  ===== Phase 3: Integration (dry-run) =====\n"
                f"  {len(backend_integration.targets)} target(s), "
                f"{len(backend_ctx.siblings)} sibling(s) discovered:"
            )
            for t in backend_integration.targets:
                expanded = expand_target_paths(t, backend_ctx)
                tmpl = expanded.template or "—"
                print(f"    + {expanded.path}  (template: {tmpl})")
            print(
                f"  test_command: {backend_integration.test_command}  "
                f"(fix_timeout: {backend_integration.fix_timeout_m}m)"
            )
        else:
            backend_ctx.siblings = discover_siblings(target, exclude_slug=backend_subdir)
            print()
            print(
                f"  ===== Phase 3: Integration =====\n"
                f"  {len(backend_integration.targets)} target(s), "
                f"{len(backend_ctx.siblings)} sibling service(s) discovered."
            )
            for s in backend_ctx.siblings:
                print(f"    · {s.slug} ({s.kind}, {s.tech})")
            # The integration phase + test-fix loop are wrapped in
            # *broad* try/excepts (not just OllamaError) because the
            # project-wide rule is "bypass integration/test errors to
            # Ollama" — a Python crash here would lose the test
            # output that the next iteration could feed back to the
            # model. Anything we cannot route to Ollama gets printed
            # so the user sees what happened and the pipeline
            # continues to the test-fix loop with whatever files
            # were already written.
            try:
                integration_results = run_integration_phase(
                    client=client,
                    manifest=backend_integration,
                    ctx=backend_ctx,
                    dry_run=False,
                    progress=_PROGRESS,
                )
            except OllamaError as exc:
                print(f"  Integration phase Ollama error: {exc}")
                print("  (continuing to the test-fix loop with whatever files exist)")
            except Exception as exc:  # noqa: BLE001 — bypass to next phase
                print(f"  Integration phase raised unexpectedly: {exc!r}")
                print("  (continuing to the test-fix loop with whatever files exist)")
            print(f"  Integration files written ({len(integration_results)}):")
            for r in integration_results:
                try:
                    rel = r.written_to.relative_to(target)
                except ValueError:
                    rel = r.written_to
                print(f"    + {rel}  ({r.bytes_written} bytes)")
    elif (
        choices.has_backend
        and not args.no_integrate
        and not args.dry_run
    ):
        print()
        print(
            f"  (no INTEGRATION_MANIFEST in {choices.backend_skeleton}.py — "
            "skipping integration phase)"
        )

    # ----- Phase 4: documentation generation ----------------------------- #
    if not args.dry_run and client is not None and not args.no_docs:
        print()
        print("  ===== Phase 4: Documentation & LLM instructions =====")
        service_contexts = []
        if backend_ctx is not None:
            service_contexts.append(backend_ctx)
        if frontend_ctx is not None:
            service_contexts.append(frontend_ctx)
        try:
            docs_written = run_docs_generation(
                client=client,
                project_root=target,
                project_name=display_proj_name,
                service_contexts=service_contexts,
                dry_run=False,
                progress=_PROGRESS,
            )
        except Exception as exc:  # noqa: BLE001
            print(f"  Documentation generation error: {exc!r}")
            print("  (project is fully functional — docs can be regenerated later)")
            docs_written = []
        if docs_written:
            print(f"  Generated {len(docs_written)} documentation files.")
    elif args.dry_run:
        print()
        print(
            "  (dry-run) Phase 4: would generate README.md, AGENTS.md, "
            "CLAUDE.md, JUNIE-RULES.md + per-service docs"
        )

    # ----- Phase 5: Kubernetes lifecycle -------------------------------- #
    if not args.dry_run and not args.no_kube:
        _run_kube_phase_with_fallback(
            client=client,
            wrapper_dir=target,
            args=args,
        )

    # ----- Phase 6: Test generation + fix loop ----------------------- #
    if not args.no_test_fix and not args.dry_run:
        if getattr(args, 'legacy_test_fix', False):
            # Legacy behavior: old patch-all-files loop
            print()
            print("  ===== Phase 6: Test & fix (legacy mode) =====")
            final = run_test_and_fix_loop(
                client=client,
                ctx=backend_ctx,
                manifest=backend_integration,
                integration_results=integration_results,
                progress=_PROGRESS,
            )
        else:
            # New behavior: staged test generation + targeted fix
            print()
            final = run_test_generation_phase(
                client=client,
                ctx=backend_ctx,
                manifest=backend_integration,
                progress=_PROGRESS,
            )

    print()
    print("  Done. Review the generated files and run the project's tests.")


if __name__ == "__main__":
    main()
