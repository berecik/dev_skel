def _critique_file(
    client: OllamaClient,
    skeleton: str,
    filename: str,
    content: str,
    system_prompt: str,
) -> Optional[str]:
    """Ask the model to critique a generated file against constraints.

    Returns a one-line reason string if the critique says FAIL, or
    None if PASS. Capped at a short prompt to keep latency low.
    """

    # Extract the CRITICAL RULES section from the system prompt
    # (everything between "CRITICAL" and the next section or end).
    import re
    rules_match = re.search(
        r"(?:CRITICAL|Coding rules|Required).*?(?=\n\n[A-Z]|\Z)",
        system_prompt,
        re.DOTALL | re.IGNORECASE,
    )
    rules = rules_match.group(0)[:1500] if rules_match else ""
    if not rules:
        return None  # No rules to check against

    critique_prompt = f"""\
Review this generated file against the coding rules below.
Reply with EXACTLY one line: either "PASS" or "FAIL: <reason>".

FILE: {filename}
---
{content[:3000]}
---

RULES:
{rules}
"""

    try:
        response = client.chat(
            system="You are a code reviewer. Reply EXACTLY 'PASS' or 'FAIL: reason'.",
            user=critique_prompt,
        )
        line = response.strip().splitlines()[0].strip()
        if line.upper().startswith("FAIL"):
            return line[5:].strip().lstrip(":").strip()
        return None
    except Exception:
        return None  # critique failure is not blocking


def _regenerate_with_critique(
    client: OllamaClient,
    manifest,
    target,
    ctx,
    critique_reason: str,
    output_path: Path,
) -> bool:
    """Re-generate a single target file with the critique reason appended.

    Returns True if the re-generation succeeded and overwrote the file.
    """

    try:
        extra_context = (
            f"\n\nA code reviewer found an issue with a previous version:\n"
            f"  {critique_reason}\n"
            f"Fix this issue in the new version. Output ONLY the corrected "
            f"file contents."
        )
        # We use the same generate_targets but with modified prompt
        original_prompt = target.prompt
        target.prompt = original_prompt + extra_context

        results = generate_targets(
            client=client,
            manifest=manifest,
            ctx=ctx,
            dry_run=False,
            progress=None,
        )

        target.prompt = original_prompt  # restore

        # Find the result matching our target
        for r in results:
            if r.written_to == output_path or str(r.written_to).endswith(
                str(output_path.name)
            ):
                return True
        return False
    except Exception:
        return False


# --------------------------------------------------------------------------- #
#  Per-skeleton validators
# --------------------------------------------------------------------------- #


def _venv_python(project_dir: Path) -> Path:
    """Path to the python executable inside the project's virtualenv."""

    return project_dir / ".venv" / "bin" / "python"


def _run(
    cmd: Sequence[str],
    *,
    cwd: Path,
    env: Optional[Dict[str, str]] = None,
    capture: bool = True,
) -> subprocess.CompletedProcess:
    return subprocess.run(
        list(cmd),
        cwd=str(cwd),
        check=False,
        capture_output=capture,
        text=True,
        env=env,
    )


def _syntax_check(files: Sequence[Path]) -> Optional[str]:
    """Compile every generated file via ``py_compile``; return error or None."""

    import py_compile

    for f in files:
        if not f.is_file() or f.suffix != ".py":
            continue
        try:
            py_compile.compile(str(f), doraise=True)
        except py_compile.PyCompileError as exc:
            return f"{f}: {exc.msg}"
    return None


def _validate_django(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    err = _syntax_check(files)
    if err:
        return f"syntax error: {err}"

    py = _venv_python(project_dir)
    if not py.is_file():
        return f"missing virtualenv at {py}"

    proc = _run([str(py), "manage.py", "check"], cwd=project_dir)
    if proc.returncode != 0:
        return f"`manage.py check` failed:\n{proc.stdout}\n{proc.stderr}"
    return None


def _validate_django_bolt(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    err = _validate_django(project_dir, files)
    if err:
        return err

    py = _venv_python(project_dir)
    pip = py.parent / "pip"

    # The django-bolt `gen` script only installs production deps from
    # requirements.txt, so the .venv usually lacks pytest. Install it on
    # demand so the collection check below has something to work with.
    probe = _run(
        [str(py), "-c", "import pytest"], cwd=project_dir
    )
    if probe.returncode != 0:
        install = _run(
            [str(pip), "install", "-q", "pytest", "pytest-django"],
            cwd=project_dir,
        )
        if install.returncode != 0:
            return f"pip install pytest failed:\n{install.stdout}\n{install.stderr}"

    # Best-effort pytest collection; we only care that imports resolve.
    proc = _run(
        [str(py), "-m", "pytest", "--collect-only", "-q", "app/tests"],
        cwd=project_dir,
    )
    if proc.returncode not in (0, 5):  # 5 = "no tests collected", still acceptable
        return f"pytest collection failed:\n{proc.stdout}\n{proc.stderr}"
    return None


def _validate_fastapi(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    err = _syntax_check(files)
    if err:
        return f"syntax error: {err}"

    py = _venv_python(project_dir)
    if not py.is_file():
        return f"missing virtualenv at {py}"

    # Discover the AI-generated module by walking app/* for the directory the
    # generator just created. We grab the first app/<dir> that contains
    # routes.py — manifests always emit one. Falls back to a basic syntax
    # check if discovery fails.
    candidates = sorted(p for p in (project_dir / "app").glob("*/routes.py"))
    if not candidates:
        return "no app/<service>/routes.py was generated"

    module_root = candidates[0].parent.name
    snippet = (
        f"from app.{module_root} import models, depts, routes\n"
        f"print('imports OK:', '{module_root}')\n"
    )
    proc = _run([str(py), "-c", snippet], cwd=project_dir)
    if proc.returncode != 0:
        return (
            f"import of app.{module_root} failed:\n{proc.stdout}\n{proc.stderr}"
        )
    return None


def _validate_flask(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    err = _syntax_check(files)
    if err:
        return f"syntax error: {err}"

    py = _venv_python(project_dir)
    if not py.is_file():
        return f"missing virtualenv at {py}"

    # Just verify that the AI-rewritten app/ package still imports cleanly
    # under the production runtime (which exercises the env-driven config
    # loading and the new model/routes files).
    snippet = (
        "from app import create_app, db\n"
        "from app.config import Config\n"
        "import app.models  # exercises the rewritten model module\n"
        "import app.routes  # exercises the rewritten routes module\n"
        "print('imports OK')\n"
    )
    proc = _run([str(py), "-c", snippet], cwd=project_dir)
    if proc.returncode != 0:
        return f"flask import failed:\n{proc.stdout}\n{proc.stderr}"
    return None


def _java_syntax_check(files: Sequence[Path]) -> Optional[str]:
    """Best-effort syntax check for .java files (balanced braces only)."""

    for f in files:
        if not f.is_file() or f.suffix != ".java":
            continue
        text = f.read_text(encoding="utf-8", errors="replace")
        if text.count("{") != text.count("}"):
            return f"{f}: unbalanced braces"
        if text.count("(") != text.count(")"):
            return f"{f}: unbalanced parentheses"
    return None


def _validate_spring(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    err = _java_syntax_check(files)
    if err:
        return err

    if not shutil.which("mvn"):
        return None  # treat as smoke-only when Maven is not installed

    # `mvn -q -DskipTests package` is the canonical "does this compile?"
    # check for a Spring Boot project. Skip the test suite to keep the
    # AI test runner under a few minutes per skeleton.
    proc = _run(
        ["mvn", "-q", "-DskipTests", "package"],
        cwd=project_dir,
    )
    if proc.returncode != 0:
        # Maven prints diagnostics to stdout — surface the tail.
        tail = "\n".join(proc.stdout.splitlines()[-30:])
        return f"`mvn package` failed:\n{tail}"
    return None


def _validate_rust(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    """Run `cargo check` against the regenerated crate."""

    if not shutil.which("cargo"):
        return None  # treat as smoke-only when Rust is not installed

    # cargo check is much faster than build and still type-checks every
    # source file the AI touched. The skel's `target/` is cached so
    # repeat invocations are fast after the first run.
    proc = _run(["cargo", "check", "--quiet"], cwd=project_dir)
    if proc.returncode != 0:
        tail = "\n".join((proc.stdout + proc.stderr).splitlines()[-30:])
        return f"`cargo check` failed:\n{tail}"
    return None


def _validate_js(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    """Sanity-check the regenerated Node service via `node --check`."""

    node = shutil.which("node")
    if not node:
        return None  # treat as smoke-only when Node is not installed

    # Run `node --check` on every generated .js file: parses the file
    # and bails on syntax errors without executing it.
    for f in files:
        if not f.is_file() or f.suffix != ".js":
            continue
        proc = _run([node, "--check", str(f)], cwd=project_dir)
        if proc.returncode != 0:
            return f"`node --check {f.name}` failed:\n{proc.stderr.strip()}"

    # Best-effort import smoke: try to import the new helper module.
    # We discover it by finding the only non-test file in src/ that
    # is NOT index.js / config.js. Skip when no candidate is found.
    src = project_dir / "src"
    candidates = [
        p
        for p in src.glob("*.js")
        if p.name not in {"index.js", "config.js"} and not p.name.endswith(".test.js")
    ]
    if candidates:
        target = candidates[0]
        snippet = f"import('./{target.name}').then(() => console.log('imports OK'));"
        proc = _run(
            [node, "--input-type=module", "-e", snippet],
            cwd=src,
        )
        if proc.returncode != 0:
            return (
                f"node import of {target.name} failed:\n"
                f"{proc.stdout}\n{proc.stderr}"
            )
    return None


def _validate_react(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    """Run a TypeScript-only typecheck on the regenerated React project."""

    if not shutil.which("npx"):
        return None  # treat as smoke-only when Node is not installed

    # `tsc --noEmit` exercises the new tsconfig + tsx files without
    # paying the full Vite build cost. We re-run via npx so the local
    # node_modules tsc binary is preferred.
    proc = _run(
        ["npx", "--no-install", "tsc", "--noEmit"],
        cwd=project_dir,
    )
    if proc.returncode != 0:
        tail = "\n".join((proc.stdout + proc.stderr).splitlines()[-30:])
        return f"`tsc --noEmit` failed:\n{tail}"
    return None


def _validate_flutter(project_dir: Path, files: Sequence[Path]) -> Optional[str]:
    """Run `flutter pub get` + `flutter analyze` on the regen project.

    We deliberately stop short of `flutter test` here — that runs
    inside `_skels/flutter-skel/test_skel` and is much slower because
    it spins up the test runner per package. Static analysis catches
    the most common AI regressions (typos, missing imports, broken
    type signatures) without paying that cost on every run.

    Treats Flutter-not-installed as a soft skip so the AI runner stays
    green on CI hosts without the SDK, mirroring `_validate_react`.
    """

    if not shutil.which("flutter"):
        return None  # treat as smoke-only when Flutter is not installed

    proc = _run(["flutter", "pub", "get"], cwd=project_dir)
    if proc.returncode != 0:
        tail = "\n".join((proc.stdout + proc.stderr).splitlines()[-30:])
        return f"`flutter pub get` failed:\n{tail}"

    proc = _run(["flutter", "analyze"], cwd=project_dir)
    if proc.returncode != 0:
        combined = proc.stdout + proc.stderr
        lines = combined.splitlines()
        # Only fail on error/warning lines — info-level lint
        # diagnostics (dangling_library_doc_comments, deprecated hints)
        # are noise from AI-generated code and not worth blocking on.
        # Flutter analyze lines look like: "  error • msg • file:line • rule"
        error_lines = [
            line for line in lines
            if " • " in line and (
                line.strip().startswith("error") or
                line.strip().startswith("warning")
            )
        ]
        if error_lines:
            tail = "\n".join(error_lines[:15])
            return f"`flutter analyze` failed:\n{tail}"
        # Info-only — treat as pass
    return None


VALIDATORS: Dict[str, Callable[[Path, Sequence[Path]], Optional[str]]] = {
    "python-django-skel": _validate_django,
    "python-django-bolt-skel": _validate_django_bolt,
    "python-fastapi-skel": _validate_fastapi,
    "python-flask-skel": _validate_flask,
    "java-spring-skel": _validate_spring,
    "rust-actix-skel": _validate_rust,
    "rust-axum-skel": _validate_rust,
    "js-skel": _validate_js,
    "ts-react-skel": _validate_react,
    "flutter-skel": _validate_flutter,
}


# --------------------------------------------------------------------------- #
#  Per-skeleton run
# --------------------------------------------------------------------------- #


@contextlib.contextmanager
def chdir(path: Path):
    prev = Path.cwd()
    os.chdir(path)
    try:
        yield
    finally:
        os.chdir(prev)


def run_one_skeleton(
    *,
    skeleton: str,
    repo_root: Path,
    client: Optional[OllamaClient],
    args: argparse.Namespace,
) -> RunResult:
    """Generate + AI-overlay + validate a single skeleton.

    Returns a :class:`RunResult` describing the outcome. ``client`` is
    ``None`` only in dry-run mode.
    """

    started = time.monotonic()
    skel_short = short_name(skeleton)
    proj_rel = PROJECT_DIR_TEMPLATE.format(skel_short=skel_short)
    proj_path = (repo_root / proj_rel).resolve()
    service_label = args.service_name or DEFAULTS["service_name"]
    service_slug = slugify_service_name(service_label)

    print()
    print(f"=== {skeleton} → {proj_rel}/{service_slug} ===")

    # ----- 1. Wipe + scaffold base project -------------------------- #

    if not args.skip_base:
        if proj_path.exists():
            print(f"  cleaning previous {proj_rel}")
            shutil.rmtree(proj_path)
        proj_path.parent.mkdir(parents=True, exist_ok=True)
        with chdir(proj_path.parent):
            try:
                service_subdir = generate_project(
                    root=repo_root,
                    skel_name=skeleton,
                    proj_name=proj_path.name,
                    service_name=service_label,
                )
            except (subprocess.CalledProcessError, SystemExit) as exc:
                return RunResult(
                    skeleton=skeleton,
                    status="fail",
                    duration_s=time.monotonic() - started,
                    detail=f"base skel-gen failed: {exc}",
                )
        render_agents_template(
            target=proj_path,
            service_subdir=service_subdir,
            skeleton_name=skeleton,
            project_name=proj_path.name,
        )
    else:
        if not proj_path.is_dir():
            return RunResult(
                skeleton=skeleton,
                status="fail",
                duration_s=time.monotonic() - started,
                detail=f"--skip-base requires {proj_path} to exist",
            )
        # On --skip-base, expect the project on disk to use the slug from
        # the chosen service name.
        service_subdir = service_slug

    inner_dir = proj_path / service_subdir
    if not inner_dir.is_dir():
        return RunResult(
            skeleton=skeleton,
            status="fail",
            duration_s=time.monotonic() - started,
            detail=f"expected service dir {inner_dir} not created",
        )

    # ----- 2. Build the generation context ------------------------- #

    ctx = GenerationContext(
        skeleton_name=skeleton,
        skeleton_path=repo_root / "_skels" / skeleton,
        project_root=proj_path,
        project_name=proj_path.name,
        service_subdir=service_subdir,
        service_label=service_label,
        item_name=args.item_name or DEFAULTS["item_name"],
        auth_type=args.auth_type or DEFAULTS["auth_type"],
        auth_details=(
            args.auth_details if args.auth_details is not None else DEFAULTS["auth_details"]
        ),
    )

    # ----- 3. Load manifest, plan targets -------------------------- #

    manifest = load_manifest(repo_root, skeleton)
    expanded_targets = [expand_target_paths(t, ctx) for t in manifest.targets]
    print(f"  manifest: {len(manifest.targets)} target(s)")
    for t in expanded_targets:
        print(f"    - {t.path}")

    # ----- 4. Run Ollama (or skip in dry-run) ---------------------- #

    if args.dry_run or client is None:
        print("  (dry-run) skipping Ollama")
        return RunResult(
            skeleton=skeleton,
            status="ok",
            duration_s=time.monotonic() - started,
            detail="dry-run",
        )

    max_retries = getattr(args, "max_retries", 1)
    use_critique = getattr(args, "critique", True)
    last_err: Optional[str] = None

    for attempt in range(1 + max_retries):
        if attempt > 0:
            print(f"  retry {attempt}/{max_retries} (previous: {last_err[:80]}...)")

        try:
            results = generate_targets(
                client=client,
                manifest=manifest,
                ctx=ctx,
                dry_run=False,
                progress=sys.stdout,
            )
        except OllamaError as exc:
            last_err = f"Ollama generation failed: {exc}"
            if attempt < max_retries:
                continue
            return RunResult(
                skeleton=skeleton,
                status="fail",
                duration_s=time.monotonic() - started,
                detail=last_err,
            )

        written = [r.written_to for r in results]
        print(f"  wrote {len(written)} file(s)")

        # ----- 4a. Critique loop (optional) ------------------------- #
        #
        # Ask the same model to review each generated file against the
        # manifest's system prompt constraints. If the critique says
        # FAIL, re-generate that single file with the critique reason
        # appended as extra context. Capped at 1 critique per file to
        # bound runtime.

        if use_critique and client is not None:
            for result in results:
                if not result.written_to.is_file():
                    continue
                content = result.written_to.read_text(encoding="utf-8")
                critique = _critique_file(
                    client, skeleton, result.written_to.name, content,
                    manifest.system_prompt,
                )
                if critique:
                    print(f"  critique: {result.written_to.name} → {critique[:60]}...")
                    # Re-generate with the critique as extra context.
                    # We modify the target's prompt temporarily.
                    for target in manifest.targets:
                        expanded = expand_target_paths(target, ctx)
                        if str(result.written_to).endswith(expanded.path):
                            fixed = _regenerate_with_critique(
                                client, manifest, target, ctx,
                                critique, result.written_to,
                            )
                            if fixed:
                                print(f"  critique-fix: {result.written_to.name} re-generated")
                            break

        # ----- 5. Validate ---------------------------------------------- #

        validator = VALIDATORS.get(skeleton)
        if validator is None:
            err = _syntax_check(written)
        else:
            err = validator(inner_dir, written)

        if err:
            last_err = err
            if attempt < max_retries:
                # Clean up generated files before retry so the next
                # attempt starts fresh.
                for f in written:
                    with contextlib.suppress(OSError):
                        f.unlink()
                continue
            return RunResult(
                skeleton=skeleton,
                status="fail",
                duration_s=time.monotonic() - started,
                detail=err,
            )
        else:
            if attempt > 0:
                print(f"  passed on retry {attempt}")
            break  # validation passed

    # Optional cleanup
    if not args.keep:
        shutil.rmtree(proj_path, ignore_errors=True)

    return RunResult(
        skeleton=skeleton,
        status="ok",
        duration_s=time.monotonic() - started,
        detail=f"{len(written)} files generated and validated",
    )


