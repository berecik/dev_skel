#!/usr/bin/env python3
"""End-to-end integration test: django-bolt backend + React frontend.

Generates a wrapper containing both ``python-django-bolt-skel`` and
``ts-react-skel``, configures ``BACKEND_URL`` to a non-conflicting
port, builds the React frontend (verifying the URL is baked into the
bundle), starts the django-bolt server in the background, and exercises
the ``register → login → create item → list items`` flow over real
HTTP using the same shape the React ``src/api/items.ts`` client uses.

This is the cross-stack proof that:

1. ``_bin/skel-gen`` can generate a wrapper containing the canonical
   React + django-bolt full-stack pair.
2. The wrapper-shared ``BACKEND_URL`` env var is consistently consumed
   by both services (the React Vite plugin bakes it into the bundle;
   django-bolt binds the matching port).
3. The React skel's ``src/api/items.ts`` client + the django-bolt
   skel's ``ItemViewSet`` agree on URL paths, request shapes, JWT
   bearer header, and response shapes.
4. The end-to-end ``register → login → create item → list items``
   flow works against a live django-bolt server bound to the same
   port the React bundle expects.

Usage::

    _bin/test-react-django-bolt-integration              # full run
    _bin/test-react-django-bolt-integration --keep       # leave wrapper on disk
    _bin/test-react-django-bolt-integration --port 19876 # custom port
    _bin/test-react-django-bolt-integration --no-skip    # fail on missing Node

Exit codes::

    0 — every check passed
    1 — at least one check failed
    2 — toolchain (Node / npm / Python) missing or setup error
"""

from __future__ import annotations

import argparse
import contextlib
import json
import os
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

from dev_skel_lib import (  # noqa: E402
    DevSkelConfig,
    detect_root,
    generate_project,
    load_config,
    render_agents_template,
)


# --------------------------------------------------------------------------- #
#  Configuration
# --------------------------------------------------------------------------- #


PROJECT_NAME = "test-react-django-bolt"
BACKEND_SKEL = "python-django-bolt-skel"
FRONTEND_SKEL = "ts-react-skel"
BACKEND_SERVICE_NAME = "Items API"
FRONTEND_SERVICE_NAME = "Web UI"

DEFAULT_PORT = 18765
DEFAULT_STARTUP_TIMEOUT = 60

EXIT_OK = 0
EXIT_FAIL = 1
EXIT_SETUP = 2

TEST_USERNAME = "react-integration-user"
TEST_PASSWORD = "react-integration-pw-12345"
TEST_ITEM_NAME = "react-integration-test-item"
TEST_ITEM_DESCRIPTION = "Created by _bin/test-react-django-bolt-integration"


# --------------------------------------------------------------------------- #
#  CLI
# --------------------------------------------------------------------------- #


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Integration test that generates a wrapper containing "
            "python-django-bolt-skel + ts-react-skel, builds the React "
            "frontend, starts the django-bolt backend, and verifies the "
            "items API end-to-end via real HTTP."
        ),
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help=(
            "Leave the generated wrapper at _test_projects/test-react-django-bolt "
            "on disk after the test finishes. Useful for poking at the build "
            "or running the server manually."
        ),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help=(
            "TCP port the django-bolt backend should bind to. The wrapper "
            f"BACKEND_URL is rewritten to http://127.0.0.1:<port> before "
            f"the React build runs. Default: {DEFAULT_PORT}."
        ),
    )
    parser.add_argument(
        "--server-startup-timeout",
        type=int,
        default=DEFAULT_STARTUP_TIMEOUT,
        help=(
            "Seconds to wait for the django-bolt server to become "
            f"reachable on the chosen port (default: {DEFAULT_STARTUP_TIMEOUT})."
        ),
    )
    parser.add_argument(
        "--no-skip",
        action="store_true",
        help=(
            "Treat missing Node/npm as a hard failure (exit 1) instead of "
            "the default toolchain skip (exit 2)."
        ),
    )
    return parser.parse_args()


# --------------------------------------------------------------------------- #
#  Helpers
# --------------------------------------------------------------------------- #


@contextlib.contextmanager
def chdir(path: Path):
    saved = os.getcwd()
    os.chdir(path)
    try:
        yield
    finally:
        try:
            os.chdir(saved)
        except FileNotFoundError:
            os.chdir(Path.home())


def have_node() -> bool:
    return bool(shutil.which("node")) and bool(shutil.which("npm"))


def http_request(
    method: str,
    url: str,
    *,
    body: Optional[Dict[str, Any]] = None,
    headers: Optional[Dict[str, str]] = None,
    timeout: int = 10,
) -> Tuple[int, Any]:
    """Tiny stdlib HTTP client. Returns ``(status_code, parsed_body)``.

    The body is decoded as JSON when possible; falls back to the raw
    string. ``urllib.error.HTTPError`` exceptions are caught and
    surfaced via the same return shape so the caller can assert on
    non-2xx responses without try/except boilerplate.
    """

    data: Optional[bytes] = None
    req_headers: Dict[str, str] = {"Accept": "application/json"}
    if headers:
        req_headers.update(headers)
    if body is not None:
        req_headers.setdefault("Content-Type", "application/json")
        data = json.dumps(body).encode("utf-8")

    request = urllib.request.Request(
        url, data=data, headers=req_headers, method=method
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout) as resp:
            status = resp.getcode()
            raw = resp.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as exc:
        status = exc.code
        raw = exc.read().decode("utf-8", errors="replace") if exc.fp else ""

    parsed: Any
    if not raw:
        parsed = None
    else:
        try:
            parsed = json.loads(raw)
        except json.JSONDecodeError:
            parsed = raw
    return status, parsed


def wait_for_server(url: str, timeout_s: int) -> bool:
    """Poll ``url`` until any HTTP response (2xx, 4xx, 5xx) is returned.

    Used right after starting the django-bolt subprocess to know when
    the Rust HTTP layer has finished binding. We accept *any* HTTP
    response (including 401 / 405) as proof that the server is up —
    only connection errors / timeouts mean we should keep waiting.
    """

    deadline = time.monotonic() + timeout_s
    while time.monotonic() < deadline:
        try:
            request = urllib.request.Request(
                url,
                method="GET",
                headers={"Accept": "application/json"},
            )
            with urllib.request.urlopen(request, timeout=2) as resp:
                resp.read()
            return True
        except urllib.error.HTTPError:
            return True  # any HTTP response means the server is up
        except (urllib.error.URLError, ConnectionError, OSError, TimeoutError):
            time.sleep(0.5)
    return False


def update_wrapper_env(env_path: Path, key: str, value: str) -> None:
    """Update or append ``key=value`` in a wrapper-style ``.env`` file."""

    if not env_path.is_file():
        env_path.write_text(f"{key}={value}\n", encoding="utf-8")
        return

    lines = env_path.read_text(encoding="utf-8").splitlines()
    new_lines: List[str] = []
    found = False
    for line in lines:
        if line.startswith(f"{key}="):
            new_lines.append(f"{key}={value}")
            found = True
        else:
            new_lines.append(line)
    if not found:
        new_lines.append(f"{key}={value}")
    env_path.write_text("\n".join(new_lines) + "\n", encoding="utf-8")


def generate_one_service(
    *,
    repo_root: Path,
    wrapper_dir: Path,
    skeleton: str,
    service_label: str,
) -> str:
    """Run :func:`generate_project` from inside the wrapper's parent dir."""

    with chdir(wrapper_dir.parent):
        slug = generate_project(
            root=repo_root,
            skel_name=skeleton,
            proj_name=wrapper_dir.name,
            service_name=service_label,
        )
    render_agents_template(
        target=wrapper_dir,
        service_subdir=slug,
        skeleton_name=skeleton,
        project_name=wrapper_dir.name,
    )
    return slug


def collect_react_bundle(frontend_dir: Path) -> str:
    """Concatenate every JS file under ``dist/assets/`` into one string."""

    dist_assets = frontend_dir / "dist" / "assets"
    if not dist_assets.is_dir():
        raise AssertionError(
            f"React build did not produce dist/assets/ at {dist_assets}"
        )
    js_files = sorted(dist_assets.glob("*.js"))
    if not js_files:
        raise AssertionError(
            f"No JavaScript files found under {dist_assets}"
        )
    chunks: List[str] = []
    for js in js_files:
        try:
            chunks.append(js.read_text(encoding="utf-8", errors="replace"))
        except OSError as exc:
            raise AssertionError(f"Could not read {js}: {exc}")
    return "\n".join(chunks)


# --------------------------------------------------------------------------- #
#  Main test flow
# --------------------------------------------------------------------------- #


def main() -> int:
    args = parse_args()

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)
    wrapper = repo_root / "_test_projects" / PROJECT_NAME

    print()
    print("=== React + Django-Bolt integration test ===")
    print(f"  wrapper: {wrapper}")
    print(f"  port:    {args.port}")
    print()

    # ----- 0. Toolchain probe ------------------------------------------- #
    if not have_node():
        msg = "Node.js / npm not installed (required for the React build)"
        if args.no_skip:
            print(f"  ✗ {msg}")
            return EXIT_FAIL
        print(f"  · skipping ({msg})")
        return EXIT_SETUP

    backend_url = f"http://127.0.0.1:{args.port}"
    final_exit = EXIT_OK
    server_proc: Optional[subprocess.Popen] = None
    log_fp = None
    server_log: Optional[Path] = None

    try:
        # ----- 1. Clean wrapper ----------------------------------------- #
        if wrapper.exists():
            print(f"  cleaning previous {wrapper}")
            shutil.rmtree(wrapper)
        wrapper.parent.mkdir(parents=True, exist_ok=True)

        # ----- 2. Generate django-bolt + ts-react ----------------------- #
        print()
        print("Generating services...")
        backend_slug = generate_one_service(
            repo_root=repo_root,
            wrapper_dir=wrapper,
            skeleton=BACKEND_SKEL,
            service_label=BACKEND_SERVICE_NAME,
        )
        print(f"  + {backend_slug}/  ({BACKEND_SKEL})")

        frontend_slug = generate_one_service(
            repo_root=repo_root,
            wrapper_dir=wrapper,
            skeleton=FRONTEND_SKEL,
            service_label=FRONTEND_SERVICE_NAME,
        )
        print(f"  + {frontend_slug}/  ({FRONTEND_SKEL})")

        # ----- 3. Update BACKEND_URL in the wrapper .env ---------------- #
        print()
        print(f"Setting BACKEND_URL={backend_url} in <wrapper>/.env")
        update_wrapper_env(wrapper / ".env", "BACKEND_URL", backend_url)

        # Sanity-check that .env was actually updated. The Vite plugin
        # reads from this file at build time, so a stale value here
        # would silently produce a bundle pointing at the wrong host.
        env_text = (wrapper / ".env").read_text(encoding="utf-8")
        assert f"BACKEND_URL={backend_url}" in env_text, (
            f"BACKEND_URL update did not stick in {wrapper / '.env'}"
        )

        # ----- 4. Build the React frontend ------------------------------ #
        # The Vite plugin in vite.config.ts walks up to the wrapper .env
        # we just updated, so the bundle bakes the new BACKEND_URL into
        # config.backendUrl. Re-running `npm run build` here is required
        # because the gen step builds with the default port 8000.
        print()
        print("Re-building the React frontend with the updated BACKEND_URL...")
        frontend_dir = wrapper / frontend_slug
        build_started = time.monotonic()
        result = subprocess.run(
            ["npm", "run", "build"],
            cwd=frontend_dir,
            check=False,
            capture_output=True,
            text=True,
            timeout=300,
        )
        if result.returncode != 0:
            print("  ✗ npm run build failed")
            print(f"    stderr: {result.stderr.strip()[-2000:]}")
            return EXIT_FAIL
        print(f"  ✓ React build OK in {time.monotonic() - build_started:.1f}s")

        # ----- 5. Verify the bundle bakes in the right values ----------- #
        print()
        print("Inspecting the React bundle...")
        bundle = collect_react_bundle(frontend_dir)

        expected_strings = {
            "BACKEND_URL value": backend_url,
            "items endpoint path": "/api/items",
            "auth login path": "/api/auth/login",
            "Bearer header": "Bearer",
            "JWT issuer (devskel)": "devskel",
        }
        missing = [
            label
            for label, needle in expected_strings.items()
            if needle not in bundle
        ]
        if missing:
            print(f"  ✗ React bundle is missing expected strings: {missing}")
            return EXIT_FAIL
        print(
            f"  ✓ bundle ({len(bundle)} chars) contains all expected strings"
        )
        for label, needle in expected_strings.items():
            print(f"     · {label}: '{needle}'")

        # ----- 6. Run django-bolt migrations ---------------------------- #
        # The skel intentionally ships without an `app/migrations/0001_*.py`
        # file because pytest runs with `--nomigrations` and the model
        # layout typically changes when a user adapts the skel for their
        # own entity. For a real server startup we need a real migration
        # for the `app` app, so we run `makemigrations` first.
        print()
        print("Running django-bolt migrations...")
        backend_dir = wrapper / backend_slug
        venv_python = backend_dir / ".venv" / "bin" / "python"
        if not venv_python.is_file():
            print(f"  ✗ python venv missing at {venv_python}")
            return EXIT_FAIL

        result = subprocess.run(
            [str(venv_python), "manage.py", "makemigrations", "app", "--noinput"],
            cwd=backend_dir,
            check=False,
            capture_output=True,
            text=True,
            timeout=120,
        )
        if result.returncode != 0:
            print("  ✗ makemigrations failed")
            print(f"    stderr: {result.stderr.strip()[-2000:]}")
            return EXIT_FAIL
        print(f"  ✓ makemigrations: {result.stdout.strip().splitlines()[-1] if result.stdout.strip() else 'no changes'}")

        result = subprocess.run(
            [str(venv_python), "manage.py", "migrate", "--noinput"],
            cwd=backend_dir,
            check=False,
            capture_output=True,
            text=True,
            timeout=180,
        )
        if result.returncode != 0:
            print("  ✗ migrate failed")
            print(f"    stderr: {result.stderr.strip()[-2000:]}")
            return EXIT_FAIL
        print("  ✓ migrations applied")

        # ----- 7. Start the django-bolt server in the background -------- #
        print()
        print(f"Starting django-bolt server on 127.0.0.1:{args.port}...")
        server_log = backend_dir / "test-server.log"
        log_fp = open(server_log, "wb")
        server_env = os.environ.copy()
        # Make sure the wrapper-shared .env values are visible to the
        # subprocess (the django settings.py loader walks up to find
        # them, but explicit env wins).
        server_env["BACKEND_URL"] = backend_url
        server_proc = subprocess.Popen(
            [
                str(venv_python),
                "manage.py",
                "runbolt",
                "--host",
                "127.0.0.1",
                "--port",
                str(args.port),
            ],
            cwd=backend_dir,
            stdout=log_fp,
            stderr=subprocess.STDOUT,
            env=server_env,
        )

        # Wait for readiness — the items endpoint requires auth so we'll
        # see a 401, which counts as "server is up" for our purposes.
        if not wait_for_server(
            f"{backend_url}/api/items", timeout_s=args.server_startup_timeout
        ):
            print("  ✗ server did not become ready in time")
            print()
            print("  ----- server log (last 4000 chars) -----")
            try:
                print(server_log.read_text(encoding="utf-8")[-4000:])
            except OSError:
                pass
            return EXIT_FAIL
        print("  ✓ server is up")

        # ----- 8. Exercise the items API end-to-end --------------------- #
        print()
        print("Exercising the cross-stack items API flow...")

        # Sub-step 1: register
        status, body = http_request(
            "POST",
            f"{backend_url}/api/auth/register",
            body={
                "username": TEST_USERNAME,
                "email": "react-test@example.com",
                "password": TEST_PASSWORD,
                "password_confirm": TEST_PASSWORD,
            },
        )
        assert status == 201, (
            f"register expected 201, got {status}: {body}"
        )
        user_payload = body.get("user", {}) if isinstance(body, dict) else {}
        user_id = user_payload.get("id")
        assert user_id, f"register response missing user.id: {body}"
        print(f"  ✓ POST /api/auth/register → 201 (user_id={user_id})")

        # Sub-step 2: login → JWT
        status, body = http_request(
            "POST",
            f"{backend_url}/api/auth/login",
            body={"username": TEST_USERNAME, "password": TEST_PASSWORD},
        )
        assert status == 200, f"login expected 200, got {status}: {body}"
        token = (
            (body.get("access") or body.get("token"))
            if isinstance(body, dict)
            else None
        )
        assert token, f"login response missing access token: {body}"
        print(
            f"  ✓ POST /api/auth/login → 200 (jwt len={len(token)}, "
            f"first 12 chars='{token[:12]}...')"
        )

        auth_headers = {"Authorization": f"Bearer {token}"}

        # Sub-step 3: list items (initial state)
        status, body = http_request(
            "GET",
            f"{backend_url}/api/items",
            headers=auth_headers,
        )
        assert status == 200, (
            f"GET /api/items expected 200, got {status}: {body}"
        )
        initial_items = body if isinstance(body, list) else (
            body.get("results", []) if isinstance(body, dict) else []
        )
        print(
            f"  ✓ GET /api/items → 200 (initial count={len(initial_items)})"
        )

        # Sub-step 4: create an item
        status, body = http_request(
            "POST",
            f"{backend_url}/api/items",
            body={
                "name": TEST_ITEM_NAME,
                "description": TEST_ITEM_DESCRIPTION,
                "is_completed": False,
            },
            headers=auth_headers,
        )
        assert status == 201, (
            f"POST /api/items expected 201, got {status}: {body}"
        )
        new_id = body.get("id") if isinstance(body, dict) else None
        assert new_id, f"create response missing id: {body}"
        assert body.get("name") == TEST_ITEM_NAME, (
            f"create response name mismatch: {body}"
        )
        assert body.get("is_completed") is False, (
            f"create response is_completed should be False: {body}"
        )
        print(
            f"  ✓ POST /api/items → 201 (id={new_id}, "
            f"name='{body.get('name')}')"
        )

        # Sub-step 5: list again — new item should appear
        status, body = http_request(
            "GET",
            f"{backend_url}/api/items",
            headers=auth_headers,
        )
        assert status == 200
        items_after = body if isinstance(body, list) else (
            body.get("results", []) if isinstance(body, dict) else []
        )
        names = [i.get("name") for i in items_after if isinstance(i, dict)]
        assert TEST_ITEM_NAME in names, (
            f"new item not in list after create: {names}"
        )
        assert len(items_after) == len(initial_items) + 1, (
            f"expected list to grow by 1: before={len(initial_items)} "
            f"after={len(items_after)}"
        )
        print(
            f"  ✓ GET /api/items → 200 (count={len(items_after)}, "
            f"new item visible)"
        )

        # Sub-step 6: retrieve the item by id
        status, body = http_request(
            "GET",
            f"{backend_url}/api/items/{new_id}",
            headers=auth_headers,
        )
        assert status == 200, (
            f"GET /api/items/{new_id} expected 200, got {status}: {body}"
        )
        assert body.get("id") == new_id
        assert body.get("name") == TEST_ITEM_NAME
        print(f"  ✓ GET /api/items/{new_id} → 200 (round-trip OK)")

        # Sub-step 7: complete via @action endpoint
        status, body = http_request(
            "POST",
            f"{backend_url}/api/items/{new_id}/complete",
            headers=auth_headers,
        )
        assert status in (200, 201), (
            f"POST /api/items/{new_id}/complete expected 200/201, "
            f"got {status}: {body}"
        )
        assert body.get("is_completed") is True, (
            f"complete response should set is_completed=True: {body}"
        )
        print(
            f"  ✓ POST /api/items/{new_id}/complete → {status} "
            f"(is_completed=True)"
        )

        # Sub-step 8: anonymous request must be rejected
        status, _body = http_request("GET", f"{backend_url}/api/items")
        assert status in (401, 403), (
            f"anonymous GET /api/items expected 401/403, got {status}"
        )
        print(
            f"  ✓ GET /api/items without token → {status} "
            f"(JWT enforcement works)"
        )

        # Sub-step 9: invalid token must be rejected
        status, _body = http_request(
            "GET",
            f"{backend_url}/api/items",
            headers={"Authorization": "Bearer not-a-real-token"},
        )
        assert status in (401, 403), (
            f"invalid-token GET /api/items expected 401/403, got {status}"
        )
        print(
            f"  ✓ GET /api/items with invalid token → {status} "
            f"(JWT validation works)"
        )

        print()
        print("=== ALL CHECKS PASSED ===")

    except AssertionError as exc:
        print()
        print(f"  ✗ assertion failed: {exc}")
        if server_log and server_log.is_file():
            print()
            print("  ----- server log (last 4000 chars) -----")
            try:
                print(server_log.read_text(encoding="utf-8")[-4000:])
            except OSError:
                pass
        final_exit = EXIT_FAIL
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as exc:
        print()
        print(f"  ✗ subprocess error: {exc}")
        final_exit = EXIT_FAIL
    except Exception as exc:  # noqa: BLE001 — surface anything we missed
        print()
        print(f"  ✗ unexpected error: {exc!r}")
        final_exit = EXIT_FAIL
    finally:
        # Stop the server cleanly. SIGTERM, then SIGKILL on timeout.
        if server_proc is not None and server_proc.poll() is None:
            print()
            print(f"Stopping server (pid {server_proc.pid})...")
            try:
                server_proc.terminate()
                try:
                    server_proc.wait(timeout=10)
                except subprocess.TimeoutExpired:
                    print("  (SIGTERM timed out, sending SIGKILL)")
                    server_proc.kill()
                    try:
                        server_proc.wait(timeout=5)
                    except subprocess.TimeoutExpired:
                        pass
            except OSError:
                pass

        if log_fp is not None:
            try:
                log_fp.close()
            except OSError:
                pass

        # Cleanup unless --keep was passed or the test failed (we keep
        # failing runs around so the user can poke at the artifacts).
        if args.keep:
            print()
            print(f"  (kept on disk: {wrapper})")
        elif final_exit != EXIT_OK:
            print()
            print(f"  (kept on disk for inspection: {wrapper})")
        else:
            print()
            print(f"Cleaning up {wrapper}...")
            shutil.rmtree(wrapper, ignore_errors=True)

    return final_exit


if __name__ == "__main__":
    sys.exit(main())
