#!/usr/bin/env python3
"""End-to-end integration test: django-bolt backend + React frontend.

Generates a wrapper containing both ``python-django-bolt-skel`` and
``ts-react-skel``, configures ``BACKEND_URL`` to a non-conflicting
port, builds the React frontend (verifying the URL is baked into the
bundle), starts the django-bolt server in the background, and
exercises the canonical ``register → login → CRUD → complete → reject
anonymous → reject invalid token`` flow over real HTTP using the same
shape the React ``src/api/items.ts`` client uses.

This is the cross-stack proof that:

1. ``_bin/skel-gen`` can generate a wrapper containing the canonical
   React + django-bolt full-stack pair.
2. The wrapper-shared ``BACKEND_URL`` env var is consistently consumed
   by both services (the React Vite plugin bakes it into the bundle;
   django-bolt binds the matching port).
3. The React skel's ``src/api/items.ts`` client + the django-bolt
   skel's ``ItemViewSet`` agree on URL paths, request shapes, JWT
   bearer header, and response shapes.
4. The end-to-end flow works against a live django-bolt server bound
   to the same port the React bundle expects.

Usage::

    _bin/test-react-django-bolt-integration              # full run
    _bin/test-react-django-bolt-integration --keep       # leave wrapper on disk
    _bin/test-react-django-bolt-integration --port 19876 # custom port
    _bin/test-react-django-bolt-integration --no-skip    # fail on missing Node

Exit codes::

    0 — every check passed
    1 — at least one check failed
    2 — toolchain (Node / npm / Python) missing or setup error

The implementation lives in :mod:`_frontend_backend_lib`; this script
just declares the django-bolt-specific :class:`BackendSpec` (server
argv + ``makemigrations`` / ``migrate`` pre-server setup) and forwards
to :func:`run_react_backend_integration`. Mirrors the structure of
``_bin/test-react-fastapi-integration`` so adding a third backend is a
~80-line copy-paste.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

from dev_skel_lib import DevSkelConfig, detect_root, load_config  # noqa: E402

from _frontend_backend_lib import (  # noqa: E402
    DEFAULT_PORT,
    DEFAULT_STARTUP_TIMEOUT,
    BackendSpec,
    run_react_backend_integration,
)


PROJECT_NAME = "test-react-django-bolt"
BACKEND_SKEL = "python-django-bolt-skel"
BACKEND_SERVICE_NAME = "Items API"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Integration test that generates a wrapper containing "
            "python-django-bolt-skel + ts-react-skel, builds the React "
            "frontend, starts the django-bolt backend, and verifies the "
            "items API end-to-end via real HTTP."
        ),
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help=(
            "Leave the generated wrapper at "
            "_test_projects/test-react-django-bolt on disk after the test "
            "finishes. Useful for poking at the build or running the "
            "server manually."
        ),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help=(
            "TCP port the django-bolt backend should bind to. The wrapper "
            f"BACKEND_URL is rewritten to http://127.0.0.1:<port> before "
            f"the React build runs. Default: {DEFAULT_PORT}."
        ),
    )
    parser.add_argument(
        "--server-startup-timeout",
        type=int,
        default=DEFAULT_STARTUP_TIMEOUT,
        help=(
            "Seconds to wait for the django-bolt server to become "
            f"reachable on the chosen port (default: {DEFAULT_STARTUP_TIMEOUT})."
        ),
    )
    parser.add_argument(
        "--no-skip",
        action="store_true",
        help=(
            "Treat missing Node/npm as a hard failure (exit 1) instead of "
            "the default toolchain skip (exit 2)."
        ),
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)

    # The django-bolt skel intentionally ships without an
    # `app/migrations/0001_*.py` file because pytest runs with
    # `--nomigrations` and the model layout typically changes when a
    # user adapts the skel for their own entity. For a real server
    # startup we need real migrations for the `app` app, so we run
    # `makemigrations` first, then `migrate`. The `--noinput` flags
    # keep the runs non-interactive.
    spec = BackendSpec(
        skeleton=BACKEND_SKEL,
        service_name=BACKEND_SERVICE_NAME,
        server_argv_template=[
            ".venv/bin/python",
            "manage.py",
            "runbolt",
            "--host",
            "{host}",
            "--port",
            "{port}",
        ],
        pre_server_setup=[
            (
                "makemigrations",
                [
                    ".venv/bin/python",
                    "manage.py",
                    "makemigrations",
                    "app",
                    "--noinput",
                ],
            ),
            (
                "migrate",
                [
                    ".venv/bin/python",
                    "manage.py",
                    "migrate",
                    "--noinput",
                ],
            ),
        ],
    )

    return run_react_backend_integration(
        project_name=PROJECT_NAME,
        title="React + Django-Bolt integration test",
        spec=spec,
        repo_root=repo_root,
        port=args.port,
        server_startup_timeout=args.server_startup_timeout,
        keep=args.keep,
        no_skip=args.no_skip,
    )


if __name__ == "__main__":
    sys.exit(main())
