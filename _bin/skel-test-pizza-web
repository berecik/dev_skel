def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description=(
            "Pizza-web E2E: generate pizzeria, ask ./ai to add "
            "restaurant + wait-time UI in React, then drive the "
            "ordering scenario in a real browser via Playwright."
        ),
    )
    p.add_argument("--keep", action="store_true",
                   help="leave the generated wrapper on disk")
    p.add_argument("--backend-port", type=int, default=DEFAULT_BACKEND_PORT)
    p.add_argument("--frontend-port", type=int, default=DEFAULT_FRONTEND_PORT)
    p.add_argument("--server-startup-timeout", type=int, default=DEFAULT_STARTUP_TIMEOUT)
    p.add_argument("--ai-timeout-m", type=int, default=20)
    p.add_argument("--ai-fix-timeout-m", type=int, default=8)
    p.add_argument("--playwright-timeout-s", type=int, default=180)
    p.add_argument("--no-skip", action="store_true")
    p.add_argument("--skip-ai", action="store_true",
                   help="skip the ./ai apply step (run E2E against vanilla "
                        "skeleton — useful for iterating on the spec)")
    return p.parse_args()


def main() -> int:
    args = parse_args()
    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)
    wrapper = repo_root / "_test_projects" / PROJECT_NAME
    backend_url = f"http://127.0.0.1:{args.backend_port}"
    frontend_url = f"http://127.0.0.1:{args.frontend_port}"

    print()
    print("=== Pizza-Web E2E Test ===")
    print(f"  wrapper:       {wrapper}")
    print(f"  backend port:  {args.backend_port}")
    print(f"  frontend port: {args.frontend_port}")
    print()

    if not ollama_reachable():
        msg = "Ollama is not reachable"
        if args.no_skip:
            print(f"  ✗ {msg}")
            return EXIT_FAIL
        print(f"  · skipping ({msg})")
        return EXIT_SETUP

    if not have_node():
        if args.no_skip:
            print("  ✗ Node.js not installed")
            return EXIT_FAIL
        print("  · Node.js not found; skipping")
        return EXIT_SETUP

    final_exit = EXIT_OK
    backend_proc: Optional[subprocess.Popen] = None
    frontend_proc: Optional[subprocess.Popen] = None
    backend_log_fp = None

    try:
        # Phase 1: generate
        print("Phase 1: generating pizzeria baseline (FastAPI + React)...")
        backend_slug, react_slug = generate_pizzeria_project(
            repo_root, wrapper, args.backend_port, with_react=True,
        )
        backend_dir = wrapper / backend_slug
        react_dir = wrapper / react_slug

        # Phase 2: baseline V_pizza HTTP exercise (must pass before any
        # UI work). Identical to the canonical pizzeria runner so we
        # know the starting state is sound before paying the ./ai +
        # Playwright cost.
        print()
        print("Phase 2: V_pizza HTTP baseline...")
        backend_proc, backend_log_fp, backend_log = _start_backend(
            backend_dir, wrapper, args.backend_port, backend_url,
        )
        if not wait_for_server(
            f"{backend_url}/docs", timeout_s=args.server_startup_timeout,
        ):
            print("  ✗ backend did not become ready")
            return EXIT_FAIL
        exercise_pizzeria_api(backend_url)
        print("  ✓ V_pizza HTTP baseline green")
        _reservation._stop_backend(backend_proc, backend_log_fp)
        backend_proc, backend_log_fp = None, None

        if not args.skip_ai:
            # Phase 3: git init + ./ai apply on the React service
            print()
            print("Phase 3: git-init + ./ai apply on React service...")
            _git_init_baseline(wrapper, react_dir)
            invoke_ai_apply(
                wrapper, react_slug, REACT_UI_PROMPT,
                timeout_s=args.ai_timeout_m * 60,
                fix_timeout_m=args.ai_fix_timeout_m,
            )
            # Phase 3b: restore wrapper-shared React contract files
            # that the agent may have rewritten incorrectly (dropping
            # re-exports the rest of the codebase depends on).
            _restore_react_contract_files(react_dir)
            # Phase 3c: rewrite common React anti-patterns in the
            # agent's new files (e.g. wrong localStorage token key).
            _sanitize_react_outputs(react_dir)

        # Phase 4: install Playwright + write spec
        print()
        print("Phase 4: install Playwright + write spec...")
        _install_playwright(react_dir)
        _write_playwright_config_and_spec(react_dir)

        # Phase 5: boot backend + frontend
        print()
        print("Phase 5: booting backend + frontend dev servers...")
        # Inject CORS so the React dev server can reach the backend
        # from a different origin, and patch /api/orders so the
        # restaurant (superuser) can see every order to approve.
        _patch_backend_cors(backend_dir)
        _patch_orders_admin_visibility(backend_dir)
        _reset_shared_db(wrapper)
        backend_proc, backend_log_fp, backend_log = _start_backend(
            backend_dir, wrapper, args.backend_port, backend_url,
        )
        if not wait_for_server(
            f"{backend_url}/docs", timeout_s=args.server_startup_timeout,
        ):
            print("  ✗ backend did not start")
            return EXIT_FAIL
        frontend_proc = _start_frontend(react_dir, args.frontend_port, backend_url)
        if not wait_for_server(
            frontend_url, timeout_s=args.server_startup_timeout,
        ):
            print("  ✗ frontend dev server did not start")
            return EXIT_FAIL
        print("  ✓ both servers up")

        # Phase 6: Playwright E2E
        print()
        print("Phase 6: Playwright E2E (client → restaurant → wait-time)...")
        # Default-seeded usernames from common-wrapper.sh:
        ok = _run_playwright(
            react_dir,
            backend_url=backend_url, frontend_url=frontend_url,
            client_user="user", client_pass="secret",
            admin_user="admin", admin_pass="secret",
            timeout_s=args.playwright_timeout_s,
        )
        if not ok:
            print("  ✗ Playwright E2E failed")
            final_exit = EXIT_FAIL
        else:
            print("  ✓ Playwright E2E passed")
            print()
            print("=== ALL CHECKS PASSED (V_pizza HTTP + Web E2E) ===")

    except (AssertionError, RuntimeError) as exc:
        print()
        print(f"  ✗ {exc}")
        final_exit = EXIT_FAIL
    except Exception as exc:  # noqa: BLE001
        print()
        print(f"  ✗ unexpected: {exc!r}")
        final_exit = EXIT_FAIL
    finally:
        if frontend_proc is not None and frontend_proc.poll() is None:
            frontend_proc.terminate()
            try:
                frontend_proc.wait(timeout=10)
            except subprocess.TimeoutExpired:
                frontend_proc.kill()
        _reservation._stop_backend(backend_proc, backend_log_fp)
        if args.keep:
            print(f"  --keep: wrapper left at {wrapper}")
        elif wrapper.exists():
            shutil.rmtree(wrapper, ignore_errors=True)
    return final_exit


if __name__ == "__main__":
    sys.exit(main())
