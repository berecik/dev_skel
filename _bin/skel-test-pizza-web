# Playwright spec for the client-orders → restaurant-approves →
# client-sees-wait-time scenario. Written to ``e2e/pizza-flow.spec.ts``
# inside the React service so ``npx playwright test`` picks it up via
# the default glob.
PLAYWRIGHT_SPEC = r"""import { test, expect, type Page } from '@playwright/test';

const BACKEND = process.env.PIZZA_BACKEND_URL!;
const FRONTEND = process.env.PIZZA_FRONTEND_URL!;
const CLIENT_USER = process.env.PIZZA_CLIENT_USER!;
const CLIENT_PASS = process.env.PIZZA_CLIENT_PASS!;
const ADMIN_USER = process.env.PIZZA_ADMIN_USER!;
const ADMIN_PASS = process.env.PIZZA_ADMIN_PASS!;

const TIMEOUT = 60_000;
test.setTimeout(TIMEOUT * 2);

// Helper: log in via the login form.
async function login(page: Page, username: string, password: string) {
  await page.goto(FRONTEND + '/');
  const userInput = page
    .getByLabel(/user(name)?/i)
    .or(page.locator('input[name="username"]'))
    .or(page.locator('input[type="text"]'));
  const passInput = page
    .getByLabel(/password/i)
    .or(page.locator('input[name="password"]'))
    .or(page.locator('input[type="password"]'));
  await userInput.first().fill(username);
  await passInput.first().fill(password);
  await page
    .getByRole('button', { name: /sign in|log in|login/i })
    .first()
    .click();
  // Wait for any indication we left the login page.
  await expect(
    page
      .getByText(/logout|sign out|welcome|menu|restaurant|my orders/i)
      .or(page.getByTestId(/^nav-/))
      .first()
  ).toBeVisible({ timeout: TIMEOUT });
}

// Helper: click a nav button (test-id `nav-<view>` preferred, fall
// back to a button whose text matches the view name).
async function navTo(page: Page, view: 'menu'|'restaurant'|'status') {
  const labelMap: Record<string, RegExp> = {
    menu: /menu/i,
    restaurant: /restaurant/i,
    status: /status|my orders/i,
  };
  const btn = page
    .getByTestId('nav-' + view)
    .or(page.getByRole('button', { name: labelMap[view] }))
    .or(page.getByRole('link', { name: labelMap[view] }));
  if (await btn.count()) {
    await btn.first().click();
  }
}

test('client orders pizza, restaurant confirms, client sees wait time', async ({ browser }) => {
  // --- 1. Seed catalog via HTTP so the test doesn't depend on a
  //        catalog-admin UI ---------------------------------------
  const adminCtx = await browser.newContext();
  const adminPage = await adminCtx.newPage();
  // Login HTTP-side to get an admin token for catalog seeding.
  const adminLogin = await adminPage.request.post(`${BACKEND}/api/auth/login`, {
    data: { username: ADMIN_USER, password: ADMIN_PASS },
  });
  expect(adminLogin.ok()).toBeTruthy();
  const adminBody = await adminLogin.json();
  const adminToken = adminBody.access || adminBody.access_token || adminBody.token;
  expect(adminToken).toBeTruthy();
  const auth = { Authorization: `Bearer ${adminToken}` };

  const margherita = await adminPage.request.post(`${BACKEND}/api/catalog`, {
    data: { name: 'Margherita', price: 12.5, category: 'pizza', available: true },
    headers: auth,
  });
  if (margherita.status() === 201 || margherita.status() === 200) {
    /* ok */
  } else if (margherita.status() === 409 || margherita.status() === 400) {
    // already seeded by an earlier run; not fatal
  } else {
    throw new Error(`catalog seed failed: ${margherita.status()}`);
  }

  // --- 2. Client logs in via the UI ----------------------------------
  const clientCtx = await browser.newContext();
  const clientPage = await clientCtx.newPage();
  await login(clientPage, CLIENT_USER, CLIENT_PASS);

  // --- 3. Client places an order via UI ----------------------------
  await navTo(clientPage, 'menu');
  // The agent's prompt asks for buttons of shape
  // ``data-testid="order-pizza-button-<id>"``. Probe that first, then
  // fall back to ANY button whose text mentions "Order".
  const orderButton = clientPage
    .getByTestId(/^order-pizza-button(-\d+)?$/)
    .or(clientPage.getByRole('button', { name: /^order\b/i }))
    .or(clientPage.getByRole('button', { name: /order.*pizza|place order|order now/i }));
  await expect(orderButton.first()).toBeVisible({ timeout: TIMEOUT });
  await orderButton.first().click();
  // Give the multi-step POST chain time to land.
  await clientPage.waitForTimeout(2000);

  // --- 4. Read back the order id via HTTP. ``/api/orders`` returns
  //        ONLY the requesting user's orders (per the wrapper
  //        contract), so we must query with the CLIENT's token.
  //        If the UI's placeOrder failed silently OR didn't trigger
  //        the full chain, drive the missing steps via HTTP so the
  //        rest of the test can exercise approval. ----------------
  const clientLogin = await clientPage.request.post(`${BACKEND}/api/auth/login`, {
    data: { username: CLIENT_USER, password: CLIENT_PASS },
  });
  const cBody = await clientLogin.json();
  const cToken = cBody.access || cBody.access_token || cBody.token;
  const cAuth = { Authorization: `Bearer ${cToken}` };

  // Wait up to 5s for the UI's placeOrder to land an order on the
  // server.
  let orders: any[] = [];
  for (let i = 0; i < 10; i++) {
    const r = await clientPage.request.get(`${BACKEND}/api/orders`, { headers: cAuth });
    if (r.ok()) {
      orders = await r.json();
      if (Array.isArray(orders) && orders.length) break;
    }
    await clientPage.waitForTimeout(500);
  }
  if (!Array.isArray(orders) || orders.length === 0) {
    // UI's placeOrder didn't get any order onto the server — drive
    // the create+submit chain via HTTP so the rest of the test can
    // still verify the approve + status flow.
    const menu = await clientPage.request.get(`${BACKEND}/api/catalog`, { headers: cAuth });
    const menuItems = await menu.json();
    expect(menuItems.length).toBeGreaterThan(0);
    const createR = await clientPage.request.post(`${BACKEND}/api/orders`, {
      data: {}, headers: cAuth,
    });
    expect(createR.ok()).toBeTruthy();
    const draft = await createR.json();
    await clientPage.request.post(`${BACKEND}/api/orders/${draft.id}/lines`, {
      data: { catalog_item_id: menuItems[0].id, quantity: 1 }, headers: cAuth,
    });
    await clientPage.request.put(`${BACKEND}/api/orders/${draft.id}/address`, {
      data: { street: 'Test St', city: 'Warszawa', zip_code: '00-001', phone: '+48 1' },
      headers: cAuth,
    });
    await clientPage.request.post(`${BACKEND}/api/orders/${draft.id}/submit`, {
      data: {}, headers: cAuth,
    });
    const r = await clientPage.request.get(`${BACKEND}/api/orders`, { headers: cAuth });
    orders = await r.json();
  }
  const pending = (Array.isArray(orders) ? orders : [])
    .filter((o: any) => o.status === 'pending' || o.status === 'draft')
    .sort((a: any, b: any) => (a.id < b.id ? 1 : -1));
  expect(pending.length).toBeGreaterThan(0);
  let orderId = pending[0].id as number;

  // If still in 'draft' (UI got partway), submit via HTTP.
  if (pending[0].status === 'draft') {
    const lines = pending[0].lines || pending[0].positions || [];
    if (!lines.length) {
      const menu = await clientPage.request.get(`${BACKEND}/api/catalog`, { headers: cAuth });
      const menuItems = await menu.json();
      if (Array.isArray(menuItems) && menuItems.length) {
        await clientPage.request.post(`${BACKEND}/api/orders/${orderId}/lines`, {
          data: { catalog_item_id: menuItems[0].id, quantity: 1 }, headers: cAuth,
        });
      }
    }
    await clientPage.request.put(`${BACKEND}/api/orders/${orderId}/address`, {
      data: { street: 'Test St 1', city: 'Warszawa', zip_code: '00-001', phone: '+48 100 200 300' },
      headers: cAuth,
    });
    await clientPage.request.post(`${BACKEND}/api/orders/${orderId}/submit`, {
      data: {}, headers: cAuth,
    });
  }

  // --- 5. Restaurant logs in (new browser context) and approves -----
  const restPage = await adminCtx.newPage();
  await login(restPage, ADMIN_USER, ADMIN_PASS);
  await navTo(restPage, 'restaurant');

  // Fill the wait + feedback inputs first (some UIs require values
  // BEFORE the approve button is clickable; harmless if optional).
  const waitInput = restPage
    .getByTestId(new RegExp(`wait-input-${orderId}`))
    .or(restPage.getByTestId('wait-minutes-input'))
    .or(restPage.locator('input[name="wait_minutes"]'))
    .or(restPage.locator('input[type="number"]'))
    .first();
  await expect(waitInput).toBeVisible({ timeout: TIMEOUT });
  await waitInput.fill('25');
  const feedbackInput = restPage
    .getByTestId(new RegExp(`feedback-input-${orderId}`))
    .or(restPage.getByTestId('feedback-input'))
    .or(restPage.locator('input[name="feedback"], textarea[name="feedback"]'))
    .or(restPage.locator('input[type="text"]').nth(0))
    .first();
  await feedbackInput.fill('Your pizza is being prepared!');
  const approveButton = restPage
    .getByTestId(new RegExp(`approve-button-${orderId}`))
    .or(restPage.getByTestId(new RegExp(`restaurant-approve-${orderId}`)))
    .or(restPage.getByRole('button', { name: /approve|confirm/i }))
    .first();
  await approveButton.click();
  // Allow the POST to land.
  await restPage.waitForTimeout(2000);

  // --- 6. Client views status and sees the wait time. Reload the
  //        page first because some agent useEffects only refetch on
  //        ``isAuthenticated`` change, not on view change. ----------
  await clientPage.reload();
  await navTo(clientPage, 'status');
  await clientPage.waitForTimeout(2000);

  const waitText = clientPage
    .getByTestId(new RegExp(`wait-display-${orderId}`))
    .or(clientPage.getByTestId('client-wait-time'))
    .or(clientPage.getByText(/\b25\b/))
    .first();
  await expect(waitText).toBeVisible({ timeout: TIMEOUT });
  const fbText = clientPage
    .getByTestId(new RegExp(`feedback-display-${orderId}`))
    .or(clientPage.getByTestId('client-feedback'))
    .or(clientPage.getByText(/pizza is being prepared/i))
    .first();
  await expect(fbText).toBeVisible({ timeout: TIMEOUT });
});
"""

