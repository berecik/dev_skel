#!/usr/bin/env python3
"""End-to-end integration test: Django (DRF + simplejwt) backend + Flutter frontend.

Generates a wrapper containing both ``python-django-skel`` and
``flutter-skel``, configures ``BACKEND_URL`` to a non-conflicting
port, re-copies the wrapper-shared ``.env`` into the Flutter project's
bundled asset, runs ``flutter pub get`` + ``flutter build web``
(verifying the URL is bundled into the asset), runs ``migrate``
against an isolated per-test SQLite file, starts Django's
``runserver --noreload`` in the background, and exercises the
canonical ``register -> login -> CRUD -> complete`` flow over real
HTTP.

The HTTP exercise hits the BACKEND directly (not the Flutter app),
proving that the same items API contract works for both frontends.
The Flutter-specific value-add is the bundled-``.env`` inspection,
which confirms ``flutter_dotenv`` will read the right ``BACKEND_URL``
at runtime.

Usage::

    _bin/skel-test-flutter-django              # full run
    _bin/skel-test-flutter-django --keep       # leave wrapper on disk
    _bin/skel-test-flutter-django --port 18783 # custom port
    _bin/skel-test-flutter-django --no-skip    # fail on missing Flutter

Exit codes::

    0 — every check passed
    1 — at least one check failed
    2 — toolchain (Flutter / Python) missing or setup error
"""

from __future__ import annotations

import argparse
import shutil
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

from dev_skel_lib import DevSkelConfig, detect_root, load_config  # noqa: E402

from _frontend_backend_lib import (  # noqa: E402
    DEFAULT_STARTUP_TIMEOUT,
    EXIT_FAIL,
    EXIT_SETUP,
    FLUTTER_FRONTEND,
    BackendSpec,
    run_frontend_backend_integration,
)


PROJECT_NAME = "test-flutter-django"
BACKEND_SKEL = "python-django-skel"
BACKEND_SERVICE_NAME = "Items API"

FLUTTER_DEFAULT_PORT = 18783


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Integration test that generates a wrapper containing "
            "python-django-skel + flutter-skel, builds the Flutter web "
            "bundle, starts Django's runserver, and verifies the items "
            "API end-to-end via real HTTP."
        ),
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help=(
            "Leave the generated wrapper at "
            "_test_projects/test-flutter-django on disk after the test "
            "finishes. Useful for poking at the build or running the "
            "server manually."
        ),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=FLUTTER_DEFAULT_PORT,
        help=(
            "TCP port the Django backend should bind to. The wrapper "
            f"BACKEND_URL is rewritten to http://127.0.0.1:<port> before "
            f"the Flutter web build runs. Default: {FLUTTER_DEFAULT_PORT}."
        ),
    )
    parser.add_argument(
        "--server-startup-timeout",
        type=int,
        default=max(DEFAULT_STARTUP_TIMEOUT, 60),
        help=(
            "Seconds to wait for the Django server to become reachable "
            f"on the chosen port (default: {max(DEFAULT_STARTUP_TIMEOUT, 60)})."
        ),
    )
    parser.add_argument(
        "--no-skip",
        action="store_true",
        help=(
            "Treat missing Flutter SDK or Python as a hard failure (exit 1) "
            "instead of the default toolchain skip (exit 2)."
        ),
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if not shutil.which("python3"):
        msg = "python3 not on PATH (required to run the Django backend)"
        if args.no_skip:
            print(f"  \u2717 {msg}")
            return EXIT_FAIL
        print(f"  \u00b7 skipping ({msg})")
        return EXIT_SETUP

    cfg: DevSkelConfig = load_config()
    repo_root = detect_root(SCRIPT_DIR, cfg.skel_dir)

    # Run `migrate` against the per-test SQLite file BEFORE the
    # server starts so the schema exists.
    pre_setup = [
        (
            "migrate",
            [".venv/bin/python", "manage.py", "migrate", "--noinput", "-v", "0"],
        ),
    ]

    spec = BackendSpec(
        skeleton=BACKEND_SKEL,
        service_name=BACKEND_SERVICE_NAME,
        server_argv_template=[
            ".venv/bin/python",
            "manage.py",
            "runserver",
            "--noreload",
            "--insecure",
            "{host}:{port}",
        ],
        pre_server_setup=pre_setup,
        extra_env={
            "SERVICE_HOST": "127.0.0.1",
            "SERVICE_PORT": str(args.port),
            "DATABASE_URL": "sqlite:///flutter_django_test.db",
            "DJANGO_ALLOWED_HOSTS": "*",
        },
    )

    return run_frontend_backend_integration(
        frontend=FLUTTER_FRONTEND,
        project_name=PROJECT_NAME,
        title="Flutter + Django integration test",
        spec=spec,
        repo_root=repo_root,
        port=args.port,
        server_startup_timeout=args.server_startup_timeout,
        keep=args.keep,
        no_skip=args.no_skip,
    )


if __name__ == "__main__":
    sys.exit(main())
