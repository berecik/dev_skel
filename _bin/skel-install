#!/usr/bin/env python3
"""Install dev_skel into DEV_DIR using Python implementation."""

from dev_skel_lib import install_dev_dir, load_config


def main() -> None:
    cfg = load_config()
    print(f"Installing dev skeleton to {cfg.dev_dir}...")
    install_dev_dir(cfg)
    print("Install complete!")


if __name__ == "__main__":
    main()
