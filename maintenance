#!/usr/bin/env bash
set -euo pipefail

# Maintenance test runner
#
# Runs the CI-equivalent test suite locally:
#   1. Clean test artifacts
#   2. Test all generators (create + smoke-build each skeleton)
#   3. Shared-DB cross-stack contract test
#   4. Per-skeleton e2e tests (test_skel)
#
# Usage:
#   ./maintenance              # full run
#   ./maintenance --quick      # generators + shared-db only (no e2e)
#   ./maintenance --ci         # CI mode: skip toolchains not installed

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

QUICK=false
for arg in "$@"; do
  case $arg in
    --quick) QUICK=true ;;
    --ci) export CI=true ;;
  esac
done

STEP=0
TOTAL=4
[[ "$QUICK" == true ]] && TOTAL=3

run_step() {
  STEP=$((STEP + 1))
  echo ""
  echo -e "${YELLOW}>>> Step ${STEP}/${TOTAL}: $1${NC}"
  if ! eval "$2"; then
    echo -e "${RED}FAILED: $1${NC}"
    exit 1
  fi
}

echo -e "${GREEN}=== Maintenance: running full test suite ===${NC}"

run_step "make clean-test" "make clean-test"
run_step "make test-generators" "make test-generators"
run_step "make test-shared-db-python" "make test-shared-db-python"

if [[ "$QUICK" != true ]]; then
  run_step "./test (per-skeleton e2e)" "./test"
fi

echo ""
echo -e "${GREEN}All ${STEP} maintenance steps passed.${NC}"
