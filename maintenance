#!/usr/bin/env bash
set -euo pipefail

# Maintenance test runner
#
# This script runs all tests required by the default maintenance scenario:
#   1. make clean-test
#   2. make test-generators
#   3. ./test (per-skeleton e2e tests via test_skel)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Colors (match root test script)
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}=== Maintenance: running full test suite ===${NC}"

echo ""
echo -e "${YELLOW}>>> Step 1/3: make clean-test${NC}"
if ! make clean-test; then
  echo -e "${RED}make clean-test failed${NC}"
  exit 1
fi

echo ""
echo -e "${YELLOW}>>> Step 2/3: make test-generators${NC}"
if ! make test-generators; then
  echo -e "${RED}make test-generators failed${NC}"
  exit 1
fi

echo ""
echo -e "${YELLOW}>>> Step 3/3: ./test (per-skeleton e2e tests)${NC}"
if ! ./test; then
  echo -e "${RED}./test failed${NC}"
  exit 1
fi

echo ""
echo -e "${GREEN}Maintenance tests completed successfully.${NC}"
